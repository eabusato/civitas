  CONIURA settings_schema_push(specs, CONIURA settings_spec_make("object_storage.region", SETTINGS_VALUE_VERBUM, FALSUM, FALSUM, VERUM, "us-east-1", "CIVITAS_OBJECT_STORAGE__REGION", FALSUM, "", "", FALSUM))
  CONIURA settings_schema_push(specs, CONIURA settings_spec_make("object_storage.use_tls", SETTINGS_VALUE_BOOL, FALSUM, FALSUM, VERUM, "true", "CIVITAS_OBJECT_STORAGE__USE_TLS", FALSUM, "", "", FALSUM))

  CONIURA settings_schema_push(specs, CONIURA settings_spec_make("search.enabled", SETTINGS_VALUE_BOOL, FALSUM, FALSUM, VERUM, "false", "CIVITAS_SEARCH__ENABLED", FALSUM, "", "", FALSUM))
  CONIURA settings_schema_push(specs, CONIURA settings_spec_make("search.backend", SETTINGS_VALUE_VERBUM, FALSUM, FALSUM, FALSUM, "", "CIVITAS_SEARCH__BACKEND", FALSUM, "", "", VERUM))
  CONIURA settings_schema_push(specs, CONIURA settings_spec_make("search.url", SETTINGS_VALUE_VERBUM, FALSUM, FALSUM, FALSUM, "", "CIVITAS_SEARCH__URL", FALSUM, "", "", VERUM))
  CONIURA settings_schema_push(specs, CONIURA settings_spec_make("search.index_prefix", SETTINGS_VALUE_VERBUM, FALSUM, FALSUM, FALSUM, "", "CIVITAS_SEARCH__INDEX_PREFIX", FALSUM, "", "", VERUM))

  CONIURA settings_schema_push(specs, CONIURA settings_spec_make("secrets.legacy_global_key_enabled", SETTINGS_VALUE_BOOL, FALSUM, FALSUM, VERUM, "false", "CIVITAS_SECRETS__LEGACY_GLOBAL_KEY_ENABLED", FALSUM, "", "", FALSUM))
  CONIURA settings_schema_push(specs, CONIURA settings_spec_make("secrets.legacy_global_key_material_env", SETTINGS_VALUE_VERBUM, FALSUM, VERUM, FALSUM, "", "CIVITAS_SECRETS__LEGACY_GLOBAL_KEY_MATERIAL_ENV", FALSUM, "", "", VERUM))

  CONIURA settings_schema_push(specs, CONIURA settings_spec_make("secrets.session.enabled", SETTINGS_VALUE_BOOL, FALSUM, FALSUM, VERUM, "true", "CIVITAS_SECRETS__SESSION__ENABLED", FALSUM, "", "", FALSUM))
