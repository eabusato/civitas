  CONIURA settings_schema_push(specs, CONIURA settings_spec_make("object_storage.enabled", SETTINGS_VALUE_BOOL, FALSUM, FALSUM, VERUM, "false", "CIVITAS_OBJECT_STORAGE__ENABLED", FALSUM, "", "", FALSUM))
