  CONIURA settings_schema_push(specs, CONIURA settings_spec_make("object_storage.bucket", SETTINGS_VALUE_VERBUM, FALSUM, FALSUM, FALSUM, "", "CIVITAS_OBJECT_STORAGE__BUCKET", FALSUM, "", "", FALSUM))
