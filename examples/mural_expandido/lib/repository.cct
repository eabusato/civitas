SIGILLUM MuralExpandidoUser
  id: REX
  handle: VERBUM
  display_name: VERBUM
  email: VERBUM
  password_hash: VERBUM
  bio: VERBUM
  avatar_url: VERBUM
  locale: VERBUM
  is_admin: VERUM
  created_at_unix: REX
