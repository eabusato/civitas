  updated_at_unix: REX
  comment_count: REX
  like_count: REX
  love_count: REX
  bookmark_count: REX
  view_count: REX
  viewer_liked: VERUM
  viewer_loved: VERUM
  viewer_bookmarked: VERUM
  viewer_follows_author: VERUM
