  locale: VERBUM
  tags_csv: VERBUM
FIN SIGILLUM

RITUALE muralx_repository_auth_config() REDDE AuthConfig
  EVOCA AuthConfig cfg AD CONIURA auth_config_default()
  VINCIRE cfg.iteracoes AD 100000
  REDDE cfg
EXPLICIT RITUALE

RITUALE muralx_db_open(MuralExpandidoConfig cfg) REDDE SPECULUM NIHIL
  CONIURA mkdir_all(CONIURA path_dirname(cfg.database_path))
  REDDE CONIURA db_open(cfg.database_path)
EXPLICIT RITUALE

RITUALE muralx_now_unix() REDDE REX
  REDDE CONIURA datetime_to_unix(CONIURA datetime_now())
EXPLICIT RITUALE

RITUALE muralx_user_empty() REDDE MuralExpandidoUser
  EVOCA MuralExpandidoUser out
  VINCIRE out.id AD 0
  VINCIRE out.handle AD ""
  VINCIRE out.display_name AD ""
  VINCIRE out.email AD ""
  VINCIRE out.password_hash AD ""
  VINCIRE out.bio AD ""
  VINCIRE out.avatar_url AD ""
  VINCIRE out.locale AD "pt-BR"
  VINCIRE out.is_admin AD FALSUM
  VINCIRE out.created_at_unix AD 0
  REDDE out
EXPLICIT RITUALE

RITUALE muralx_user_lookup_empty() REDDE MuralExpandidoUserLookup
  EVOCA MuralExpandidoUserLookup out
  VINCIRE out.found AD FALSUM
  VINCIRE out.user AD CONIURA muralx_user_empty()
  REDDE out
EXPLICIT RITUALE

