INCIPIT grimoire "fase21_21b_filters_html"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/trace_panel/trace_panel.cct"
ADVOCARE "../../../../lib/civitas/trace_store/trace_store.cct"
ADVOCARE "cct/http.cct"
ADVOCARE "cct/path.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM root AD CONIURA phase21_reset_root("21b_filters_html")
  EVOCA VERBUM trace_dir AD CONIURA path_join(root, "traces")
  EVOCA TraceStore store AD CONIURA trace_store_open(CONIURA phase21_trace_db_path("21b_filters_html"), trace_dir, 20, 24)
  EVOCA VERBUM first_path AD CONIURA phase21_write_sample_trace(trace_dir, "trace-filter-ok")
  EVOCA VERBUM second_path AD CONIURA phase21_write_sample_trace(trace_dir, "trace-filter-err")
  CONIURA trace_store_index_trace(SPECULUM store, "trace-filter-ok", "/api/posts", "GET", 200, 180, 4, "user-1", first_path, 1700)
  CONIURA trace_store_index_trace(SPECULUM store, "trace-filter-err", "/admin/panel", "GET", 500, 420, 4, "user-1", second_path, 1701)
  EVOCA TracePanelConfig cfg AD CONIURA trace_panel_default_config(SPECULUM store)
  EVOCA HttpRequest req AD CONIURA http_request_new("GET", "/civitas/traces?status=500&min_duration=300&path=admin")
  EVOCA HttpResponse res AD CONIURA trace_panel_handle(req, cfg)
  CONIURA trace_store_close(SPECULUM store)
  SI CONIURA http_response_status(res) != 200
    REDDE 1
  FIN SI
  SI CONIURA find(CONIURA http_response_body(res), "trace-filter-err") == -1
    REDDE 2
  FIN SI
  SI CONIURA find(CONIURA http_response_body(res), "trace-filter-ok") != -1
    REDDE 3
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
