INCIPIT grimoire "fase21_21a_compare_and_dark_mode"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/trace_render/trace_render.cct"
ADVOCARE "cct/trace.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA Trace left AD CONIURA phase21_sample_trace("trace-left")
  EVOCA Trace right AD CONIURA phase21_sample_trace("trace-right")
  EVOCA TraceRenderConfig cfg AD CONIURA phase21_render_config("21a_compare_and_dark_mode")
  VINCIRE cfg.width AD 1400
  VINCIRE cfg.dark_mode AD VERUM
  EVOCA VERBUM svg AD CONIURA trace_render_compare(left, right, cfg)
  CONIURA trace_free(SPECULUM left)
  CONIURA trace_free(SPECULUM right)
  SI CONIURA find(svg, "compare-divider") == -1
    REDDE 1
  FIN SI
  SI CONIURA find(svg, "trace-left") == -1
    REDDE 2
  FIN SI
  SI CONIURA find(svg, "trace-right") == -1
    REDDE 3
  FIN SI
  SI CONIURA find(svg, "data-route-id=\"api.users.list\"") == -1
    REDDE 4
  FIN SI
  SI CONIURA find(svg, "trace-packet") == -1
    REDDE 5
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
