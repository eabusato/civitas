INCIPIT grimoire "fase21_21a_render_svg_basic"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/trace_render/trace_render.cct"
ADVOCARE "cct/trace.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA Trace trace AD CONIURA phase21_sample_trace("trace-basic")
  EVOCA TraceRenderResult rendered AD CONIURA trace_render_svg(trace, CONIURA phase21_render_config("21a_render_svg_basic"))
  CONIURA trace_free(SPECULUM trace)
  SI rendered.span_count != 4
    REDDE 1
  FIN SI
  SI rendered.duration_ms != 180
    REDDE 2
  FIN SI
  SI CONIURA find(rendered.svg, "<svg") == -1
    REDDE 3
  FIN SI
  SI CONIURA find(rendered.svg, "data-route-id=\"api.users.list\"") == -1
    REDDE 4
  FIN SI
  SI CONIURA find(rendered.svg, "trace-packet") == -1
    REDDE 5
  FIN SI
  SI CONIURA find(rendered.svg, "handler.users_list") == -1
    REDDE 6
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
