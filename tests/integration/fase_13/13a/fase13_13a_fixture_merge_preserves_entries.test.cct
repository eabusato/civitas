INCIPIT grimoire "fase13_13a_fixture_merge_preserves_entries"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/fixtures/fixture.cct"
ADVOCARE "cct/fluxus.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA FixtureSuite a AD CONIURA fixture_suite_new("a", FkReference)
  EVOCA FixtureSuite b AD CONIURA fixture_suite_new("b", FkTest)
  EVOCA FixtureEntry cat
  EVOCA FixtureEntry post
  CONIURA fixture_entry_fill(SPECULUM cat, "categorias", "1")
  CONIURA fixture_entry_fill(SPECULUM post, "posts", "9")
  CONIURA fixture_suite_add_entry(SPECULUM a, cat)
  CONIURA fixture_suite_add_entry(SPECULUM b, post)
  EVOCA FixtureSuite merged AD CONIURA fixture_suite_merge(a, b)
  SI CONIURA fluxus_len(merged.entradas) != 2
    REDDE 1
  FIN SI
  EVOCA SPECULUM FixtureEntry first AD CONIURA fluxus_get(merged.entradas, 0)
  EVOCA SPECULUM FixtureEntry second AD CONIURA fluxus_get(merged.entradas, 1)
  SI CONIURA compare((*first).modelo, "categorias") != 0 VEL CONIURA compare((*second).modelo, "posts") != 0
    REDDE 2
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
