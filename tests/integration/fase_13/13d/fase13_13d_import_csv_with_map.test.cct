INCIPIT grimoire "fase13_13d_import_csv_with_map"

ADVOCARE "../support/common.cct"
ADVOCARE "support.cct"
ADVOCARE "../../../../lib/civitas/data_io/data_io.cct"
ADVOCARE "../../../../lib/civitas/data_io/data_import.cct"
ADVOCARE "cct/db_sqlite.cct"
ADVOCARE "cct/fs.cct"
ADVOCARE "cct/path.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM root AD CONIURA phase13_tmp_dir("13d_import_csv_with_map")
  CONIURA phase13_reset_dir(root)
  EVOCA SPECULUM NIHIL db AD CONIURA db_open(CONIURA path_join(root, "test.db"))
  CONIURA phase13_seed_schema(db)
  EVOCA VERBUM path AD CONIURA path_join(root, "cats.csv")
  CONIURA write_all(path, "Nome,Slug,Ativo\nTech,tech,1\nVida,vida,0\n")
  EVOCA CsvColMap mapa AD CONIURA csv_col_map_new()
  CONIURA csv_col_map_add(mapa, "Nome", "nome")
  CONIURA csv_col_map_add(mapa, "Slug", "slug")
  CONIURA csv_col_map_add(mapa, "Ativo", "ativo")
  EVOCA DataIoResult r AD CONIURA data_import_csv(db, path, "categorias", CONIURA phase13_model_categoria(), mapa)
  SI r.ok != 2
    REDDE 1
  FIN SI
  SI CONIURA db_scalar_int(db, "SELECT COUNT(*) FROM categorias WHERE slug = 'vida'") != 1
    REDDE 2
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
