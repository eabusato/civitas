INCIPIT grimoire "fase13_13d_import_export_toml"

ADVOCARE "../support/common.cct"
ADVOCARE "support.cct"
ADVOCARE "../../../../lib/civitas/data_io/data_io.cct"
ADVOCARE "../../../../lib/civitas/data_io/data_import.cct"
ADVOCARE "../../../../lib/civitas/data_io/data_export.cct"
ADVOCARE "cct/db_sqlite.cct"
ADVOCARE "cct/fs.cct"
ADVOCARE "cct/path.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM root AD CONIURA phase13_tmp_dir("13d_import_export_toml")
  CONIURA phase13_reset_dir(root)
  EVOCA SPECULUM NIHIL db AD CONIURA db_open(CONIURA path_join(root, "test.db"))
  CONIURA phase13_seed_schema(db)
  EVOCA VERBUM in_path AD CONIURA path_join(root, "cats.toml")
  CONIURA write_all(in_path, "[[rows]]\nnome = \"Tech\"\nslug = \"tech\"\nativo = true\n\n[[rows]]\nnome = \"Vida\"\nslug = \"vida\"\nativo = false\n")
  EVOCA DataIoResult ir AD CONIURA data_import_toml(db, in_path, "categorias", CONIURA phase13_model_categoria())
  SI ir.ok != 2
    REDDE 1
  FIN SI
  EVOCA VERBUM out_path AD CONIURA path_join(root, "out.toml")
  EVOCA DataIoResult er AD CONIURA data_export_toml(db, "categorias", CONIURA phase13_model_categoria(), out_path)
  SI er.ok != 2
    REDDE 2
  FIN SI
  EVOCA VERBUM out AD CONIURA read_all(out_path)
  SI NON CONIURA contains(out, "slug = \"tech\"")
    REDDE 3
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
