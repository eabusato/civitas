INCIPIT grimoire "fase13_13d_backfill_slugs"

ADVOCARE "../support/common.cct"
ADVOCARE "support.cct"
ADVOCARE "../../../../lib/civitas/data_io/data_io.cct"
ADVOCARE "../../../../lib/civitas/data_io/data_backfill.cct"
ADVOCARE "cct/db_sqlite.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL db AD CONIURA phase13_db_open("13d_backfill_slugs")
  CONIURA phase13_seed_schema(db)
  CONIURA db_exec(db, "INSERT INTO categorias (id, nome, slug, ativo) VALUES (1, 'Tech', 'tech', 1)")
  CONIURA db_exec(db, "INSERT INTO posts (titulo, slug, categoria_id, email) VALUES ('Meu Post Incrivel', '', 1, NULL)")
  EVOCA DataIoResult r AD CONIURA data_backfill_slugs(db, "posts", "titulo", "slug")
  SI r.ok != 1
    REDDE 1
  FIN SI
  SI CONIURA compare(CONIURA db_scalar_text(db, "SELECT slug FROM posts WHERE id = 1"), "meu-post-incrivel") != 0
    REDDE 2
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
