INCIPIT grimoire "fase13_13c_assert_helpers_count_exists"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/test_db/test_db.cct"
ADVOCARE "../../../../lib/civitas/test_db/test_db_setup.cct"
ADVOCARE "../../../../lib/civitas/test_db/test_db_assert.cct"
ADVOCARE "cct/db_sqlite.cct"

RITUALE main() REDDE REX
  EVOCA TestDb tdb AD CONIURA test_db_open_memory()
  CONIURA test_db_run_migrations(tdb, CONIURA phase13_registry_basic())
  CONIURA db_exec(tdb.db, "INSERT INTO categorias (nome, slug, ativo) VALUES ('Tech', 'tech', 1)")
  CONIURA db_exec(tdb.db, "INSERT INTO categorias (nome, slug, ativo) VALUES ('Vida', 'vida', 0)")
  SI CONIURA test_db_count(tdb, "categorias") != 2
    REDDE 1
  FIN SI
  SI CONIURA test_db_count_where(tdb, "categorias", "slug", "tech") != 1
    REDDE 2
  FIN SI
  SI NON CONIURA test_db_exists(tdb, "categorias", "slug", "vida")
    REDDE 3
  FIN SI
  SI NON CONIURA test_db_exists_id(tdb, "categorias", 2)
    REDDE 4
  FIN SI
  CONIURA test_db_close(tdb)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
