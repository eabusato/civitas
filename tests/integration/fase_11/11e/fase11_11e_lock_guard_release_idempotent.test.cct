INCIPIT grimoire "fase11_11e_lock_guard_release_idempotent"

ADVOCARE "../../../../lib/civitas/locks/locks.cct"
ADVOCARE "../../../../lib/civitas/locks/locks_guard.cct"
ADVOCARE "../../../../lib/civitas/locks/locks_keys.cct"
ADVOCARE "cct/db_postgres.cct"
ADVOCARE "cct/db_postgres_lock.cct"
ADVOCARE "cct/result.cct"

RITUALE main() REDDE REX
  EVOCA Db db
  VINCIRE db.conn AD NIHIL
  VINCIRE db.last_error AD ""
  VINCIRE db.open AD FALSUM
  EVOCA PgLockKey key AD CONIURA lock_key_cron("publish")
  EVOCA PgLockHandle handle AD CONIURA pg_lock_handle_make(key, PG_LOCK_SCOPE_SESSION, FALSUM)
  EVOCA LockGuard guard AD CONIURA lock_guard_new(handle)
  EVOCA SPECULUM NIHIL first AD CONIURA lock_guard_release(db, SPECULUM guard)
  SI CONIURA result_is_err GENUS(VERUM, VERBUM)(first)
    REDDE 1
  FIN SI
  EVOCA SPECULUM NIHIL second AD CONIURA lock_guard_release(db, SPECULUM guard)
  SI CONIURA result_is_err GENUS(VERUM, VERBUM)(second)
    REDDE 2
  FIN SI
  SI NON guard.released
    REDDE 3
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
