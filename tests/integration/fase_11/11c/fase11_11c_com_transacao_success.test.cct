INCIPIT grimoire "fase11_11c_com_transacao_success"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/db_handle/db_handle.cct"
ADVOCARE "../../../../lib/civitas/transaction/transaction.cct"
ADVOCARE "cct/db_sqlite.cct"

RITUALE tx_success(DbHandle dbh) REDDE VERUM
  CONIURA dbh_exec(dbh, "INSERT INTO items(id) VALUES(1)", CONIURA dbh_params_new())
  REDDE VERUM
EXPLICIT RITUALE

RITUALE main() REDDE REX
  EVOCA DbHandle dbh AD CONIURA phase11_dbh_sqlite("11c_com_transacao_success")
  CONIURA db_exec(dbh.sqlite_conn, "CREATE TABLE items(id INTEGER PRIMARY KEY)")
  EVOCA TxContext ctx AD CONIURA tx_context_new()
  SI NON CONIURA com_transacao(dbh, tx_success, SPECULUM ctx)
    REDDE 1
  FIN SI
  SI CONIURA dbh_scalar_int(dbh, "SELECT COUNT(*) FROM items") != 1
    REDDE 2
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
