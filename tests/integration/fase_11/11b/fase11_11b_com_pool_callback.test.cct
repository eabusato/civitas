INCIPIT grimoire "fase11_11b_com_pool_callback"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/pool/pool.cct"
ADVOCARE "../../../../lib/civitas/pool/pool_sqlite.cct"
ADVOCARE "../../../../lib/civitas/db_handle/db_handle.cct"
ADVOCARE "cct/db_sqlite.cct"

RITUALE insert_via_pool(DbHandle dbh) REDDE VERUM
  CONIURA db_exec(dbh.sqlite_conn, "CREATE TABLE IF NOT EXISTS items(id INTEGER PRIMARY KEY)")
  CONIURA dbh_exec(dbh, "INSERT INTO items(id) VALUES(1)", CONIURA dbh_params_new())
  REDDE VERUM
EXPLICIT RITUALE

RITUALE main() REDDE REX
  CONIURA phase11_reset_dir(CONIURA phase11_tmp_dir("11b_com_pool_callback"))
  EVOCA SPECULUM NIHIL pool AD CONIURA pool_new_sqlite(CONIURA phase11_db_path("11b_com_pool_callback"), NIHIL)
  SI NON CONIURA com_pool(pool, insert_via_pool)
    REDDE 1
  FIN SI
  EVOCA SPECULUM NIHIL handle_ptr AD CONIURA pool_acquire(pool)
  EVOCA SPECULUM DbHandle dbh_ptr AD handle_ptr
  SI CONIURA dbh_scalar_int(*dbh_ptr, "SELECT COUNT(*) FROM items") != 1
    REDDE 2
  FIN SI
  CONIURA pool_release(pool, handle_ptr)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
