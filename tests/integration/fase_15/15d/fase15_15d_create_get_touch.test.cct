INCIPIT grimoire "fase15_15d_create_get_touch"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/session/session.cct"
ADVOCARE "../../../../lib/civitas/session/session_store.cct"
ADVOCARE "cct/db_sqlite.cct"
ADVOCARE "cct/option.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL db AD CONIURA phase15_session_db_open("15d_create_get_touch")
  EVOCA SessionConfig cfg AD CONIURA session_config_default()
  VINCIRE cfg.ttl_segundos AD 3600
  EVOCA Session sess AD CONIURA session_create(db, cfg, "user-1", "127.0.0.1", "Agent/1.0")
  SI CONIURA len(sess.id) == 0 VEL CONIURA compare(sess.user_id, "user-1") != 0
    CONIURA db_close(db)
    REDDE 1
  FIN SI
  EVOCA REX before_exp AD sess.expira_em
  EVOCA SPECULUM NIHIL opt AD CONIURA session_lookup(db, sess.id)
  SI CONIURA option_is_none GENUS(Session)(opt)
    CONIURA option_free GENUS(Session)(opt)
    CONIURA db_close(db)
    REDDE 2
  FIN SI
  EVOCA Session loaded AD CONIURA option_unwrap GENUS(Session)(opt)
  CONIURA option_free GENUS(Session)(opt)
  SI CONIURA compare(loaded.user_id, "user-1") != 0
    CONIURA db_close(db)
    REDDE 3
  FIN SI
  CONIURA session_touch(db, cfg, sess.id)
  VINCIRE opt AD CONIURA session_lookup(db, sess.id)
  EVOCA Session touched AD CONIURA option_unwrap GENUS(Session)(opt)
  CONIURA option_free GENUS(Session)(opt)
  CONIURA db_close(db)
  SI touched.expira_em < before_exp
    REDDE 4
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
