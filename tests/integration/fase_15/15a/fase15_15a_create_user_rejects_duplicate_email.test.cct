INCIPIT grimoire "fase15_15a_create_user_rejects_duplicate_email"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/auth/auth.cct"
ADVOCARE "../../../../lib/civitas/auth/auth_users.cct"
ADVOCARE "cct/db_sqlite.cct"
ADVOCARE "cct/result.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL db AD CONIURA phase15_auth_db_open("15a_create_user_rejects_duplicate_email")
  EVOCA AuthConfig cfg AD CONIURA auth_config_default()
  CONIURA auth_criar_usuario(db, cfg, "dup@example.com", "S3nh@Forte!")
  EVOCA SPECULUM NIHIL res AD CONIURA auth_criar_usuario(db, cfg, "dup@example.com", "S3nh@Forte!")
  SI NON CONIURA result_is_err GENUS(User, AuthError)(res)
    CONIURA db_close(db)
    REDDE 1
  FIN SI
  SI CONIURA compare(CONIURA auth_error_name(CONIURA result_unwrap_err GENUS(User, AuthError)(res)), "AuthEmailJaExiste") != 0
    CONIURA db_close(db)
    REDDE 2
  FIN SI
  CONIURA db_close(db)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
