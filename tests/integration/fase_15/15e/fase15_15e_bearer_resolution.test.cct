INCIPIT grimoire "fase15_15e_bearer_resolution"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/auth/auth.cct"
ADVOCARE "../../../../lib/civitas/auth/auth_users.cct"
ADVOCARE "../../../../lib/civitas/session/session.cct"
ADVOCARE "../../../../lib/civitas/auth_token/auth_token.cct"
ADVOCARE "../../../../lib/civitas/auth_token/auth_token_issue.cct"
ADVOCARE "../../../../lib/civitas/auth_middleware/auth_context.cct"
ADVOCARE "../../../../lib/civitas/auth_middleware/auth_middleware.cct"
ADVOCARE "../../../../lib/civitas/auth_middleware/auth_guards.cct"
ADVOCARE "../../../../lib/civitas/request_core.cct"
ADVOCARE "cct/context_local.cct"
ADVOCARE "cct/db_sqlite.cct"
ADVOCARE "cct/map.cct"
ADVOCARE "cct/result.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL db AD CONIURA phase15_auth_stack_db_open("15e_bearer_resolution")
  EVOCA AuthConfig auth_cfg AD CONIURA auth_config_default()
  EVOCA SPECULUM NIHIL user_res AD CONIURA auth_criar_usuario(db, auth_cfg, "api@example.com", "S3nh@Forte!")
  EVOCA User user AD CONIURA result_unwrap GENUS(User, AuthError)(user_res)
  EVOCA TokenConfig tok_cfg AD CONIURA token_config_new("segredo_hmac_32bytes_min_123456789", 3600, 86400)
  EVOCA SessionConfig ses_cfg AD CONIURA session_config_default()
  EVOCA AuthMiddlewareConfig mw_cfg AD CONIURA auth_middleware_config_new(tok_cfg, ses_cfg)
  EVOCA VERBUM token AD CONIURA token_issue(tok_cfg, user.id, "posts.write")
  EVOCA SPECULUM NIHIL headers AD CONIURA map_init GENUS(VERBUM, VERBUM)()
  CONIURA map_insert GENUS(VERBUM, VERBUM)(headers, "authorization", CONIURA concat("Bearer ", token))
  EVOCA SPECULUM NIHIL req_res AD CONIURA request_build("GET", "/", "HTTP/1.1", headers, "", "127.0.0.1", "http", "example.test", "rid", "", "", "")
  EVOCA WebRequest req AD CONIURA result_unwrap GENUS(WebRequest, VERBUM)(req_res)
  EVOCA LocalContext ctx AD CONIURA local_context_new()
  CONIURA local_context_open(SPECULUM ctx)
  CONIURA auth_middleware_apply(db, mw_cfg, req, SPECULUM ctx)
  EVOCA AuthContext ac AD CONIURA auth_context_ler(ctx)
  CONIURA db_close(db)
  SI NON ac.autenticado VEL CONIURA compare(ac.user_id, user.id) != 0 VEL CONIURA compare(ac.via, "bearer") != 0
    REDDE 1
  FIN SI
  SI NON CONIURA auth_guard_escopo(ctx, "posts.write")
    REDDE 2
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
