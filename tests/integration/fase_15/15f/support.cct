INCIPIT grimoire "fase15_15f_support"

ADVOCARE "cct/db_sqlite.cct"
ADVOCARE "cct/fluxus.cct"
ADVOCARE "cct/verbum.cct"

RITUALE phase15_15f_insert_attempt(SPECULUM NIHIL db, VERBUM chave, REX timestamp, VERUM sucesso) REDDE NIHIL
  EVOCA SPECULUM NIHIL stmt AD CONIURA db_prepare(db, "INSERT INTO auth_attempts (chave, timestamp, sucesso) VALUES (?, ?, ?)")
  CONIURA stmt_bind_text(stmt, 1, chave)
  CONIURA stmt_bind_int(stmt, 2, timestamp)
  SI sucesso
    CONIURA stmt_bind_int(stmt, 3, 1)
  ALITER
    CONIURA stmt_bind_int(stmt, 3, 0)
  FIN SI
  CONIURA stmt_step(stmt)
  CONIURA stmt_finalize(stmt)
  REDDE
EXPLICIT RITUALE

RITUALE phase15_15f_fluxus_contains(SPECULUM NIHIL lista, VERBUM esperado) REDDE VERUM
  EVOCA REX i AD 0
  EVOCA REX n AD CONIURA fluxus_len(lista)
  DUM i < n
    EVOCA SPECULUM VERBUM ptr AD CONIURA fluxus_get(lista, i)
    SI CONIURA compare(*ptr, esperado) == 0
      REDDE VERUM
    FIN SI
    VINCIRE i AD i + 1
  FIN DUM
  REDDE FALSUM
EXPLICIT RITUALE

EXPLICIT grimoire
