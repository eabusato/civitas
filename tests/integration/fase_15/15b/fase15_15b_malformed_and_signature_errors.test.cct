INCIPIT grimoire "fase15_15b_malformed_and_signature_errors"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/auth_token/auth_token.cct"
ADVOCARE "../../../../lib/civitas/auth_token/auth_token_issue.cct"
ADVOCARE "../../../../lib/civitas/auth_token/auth_token_verify.cct"
ADVOCARE "cct/db_sqlite.cct"
ADVOCARE "cct/result.cct"
ADVOCARE "cct/verbum.cct"

RITUALE expect_error(SPECULUM NIHIL db, TokenConfig cfg, VERBUM token, VERBUM expected) REDDE REX
  EVOCA SPECULUM NIHIL res AD CONIURA token_verify(db, cfg, token)
  SI NON CONIURA result_is_err GENUS(TokenPayload, TokenError)(res)
    REDDE 1
  FIN SI
  SI CONIURA compare(CONIURA token_error_name(CONIURA result_unwrap_err GENUS(TokenPayload, TokenError)(res)), expected) != 0
    REDDE 2
  FIN SI
  REDDE 0
EXPLICIT RITUALE

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL db AD CONIURA phase15_auth_token_db_open("15b_malformed_and_signature_errors")
  EVOCA TokenConfig cfg AD CONIURA token_config_new("segredo_hmac_32bytes_min_123456789", 3600, 86400)
  EVOCA VERBUM good AD CONIURA token_issue(cfg, "user-123", "posts.read")
  EVOCA REX malformed_rc AD CONIURA expect_error(db, cfg, "abc.def", "TokenMalformado")
  SI malformed_rc != 0
    CONIURA db_close(db)
    REDDE malformed_rc
  FIN SI

  EVOCA VERBUM bad_sig AD CONIURA concat(good, "x")
  EVOCA REX sig_rc AD CONIURA expect_error(db, cfg, bad_sig, "TokenAssinaturaInvalida")
  CONIURA db_close(db)
  SI sig_rc != 0
    REDDE 10 + sig_rc
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
