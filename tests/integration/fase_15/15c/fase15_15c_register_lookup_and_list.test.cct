INCIPIT grimoire "fase15_15c_register_lookup_and_list"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/permissions/permissions.cct"
ADVOCARE "../../../../lib/civitas/permissions/permissions_db.cct"
ADVOCARE "cct/db_sqlite.cct"
ADVOCARE "cct/fluxus.cct"
ADVOCARE "cct/option.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL db AD CONIURA phase15_permissions_db_open("15c_register_lookup_and_list")
  EVOCA REX id1 AD CONIURA perm_registrar(db, "posts.editar", "Editar posts")
  EVOCA REX id2 AD CONIURA perm_registrar(db, "posts.deletar", "Deletar posts")
  SI id1 <= 0 VEL id2 <= 0
    CONIURA db_close(db)
    REDDE 1
  FIN SI
  EVOCA SPECULUM NIHIL opt AD CONIURA perm_buscar_por_codigo(db, "posts.editar")
  SI CONIURA option_is_none GENUS(Permission)(opt)
    CONIURA option_free GENUS(Permission)(opt)
    CONIURA db_close(db)
    REDDE 2
  FIN SI
  EVOCA Permission p AD CONIURA option_unwrap GENUS(Permission)(opt)
  CONIURA option_free GENUS(Permission)(opt)
  SI CONIURA compare(p.descricao, "Editar posts") != 0
    CONIURA db_close(db)
    REDDE 3
  FIN SI
  EVOCA SPECULUM NIHIL lista AD CONIURA perm_listar_todas(db)
  SI CONIURA fluxus_len(lista) != 2
    CONIURA fluxus_free(lista)
    CONIURA db_close(db)
    REDDE 4
  FIN SI
  CONIURA fluxus_free(lista)
  CONIURA db_close(db)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
