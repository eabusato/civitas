INCIPIT grimoire "fase15_15c_auth_decorator_uses_db_permissions"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/auth/auth_decorators.cct"
ADVOCARE "../../../../lib/civitas/permissions/permissions_db.cct"
ADVOCARE "../../../../lib/civitas/permissions/permissions_assign.cct"
ADVOCARE "cct/context_local.cct"
ADVOCARE "cct/db_sqlite.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL db AD CONIURA phase15_permissions_db_open("15c_auth_decorator_uses_db_permissions")
  CONIURA perm_registrar(db, "posts.editar", "Editar posts")
  EVOCA LocalContext ctx AD CONIURA phase15_ctx_authenticated("user-1", "session", "")
  SI CONIURA auth_requires_permission_check(db, ctx, "posts.editar")
    CONIURA db_close(db)
    REDDE 1
  FIN SI
  CONIURA user_perm_conceder(db, "user-1", "posts.editar")
  SI NON CONIURA auth_requires_permission_check(db, ctx, "posts.editar")
    CONIURA db_close(db)
    REDDE 2
  FIN SI
  CONIURA db_close(db)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
