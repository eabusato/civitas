INCIPIT grimoire "fase15_15c_group_and_direct_permissions"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/permissions/permissions_db.cct"
ADVOCARE "../../../../lib/civitas/permissions/permissions_assign.cct"
ADVOCARE "../../../../lib/civitas/permissions/permissions_check.cct"
ADVOCARE "cct/db_sqlite.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL db AD CONIURA phase15_permissions_db_open("15c_group_and_direct_permissions")
  CONIURA perm_registrar(db, "posts.editar", "Editar posts")
  CONIURA perm_registrar(db, "posts.deletar", "Deletar posts")
  CONIURA user_perm_conceder(db, "user-1", "posts.editar")
  SI NON CONIURA usuario_tem_permissao(db, "user-1", "posts.editar")
    CONIURA db_close(db)
    REDDE 1
  FIN SI
  EVOCA REX gid AD CONIURA group_criar(db, "moderadores")
  CONIURA group_adicionar_permissao(db, gid, "posts.deletar")
  CONIURA user_group_adicionar(db, "user-1", gid)
  SI NON CONIURA usuario_tem_permissao(db, "user-1", "posts.deletar")
    CONIURA db_close(db)
    REDDE 2
  FIN SI
  CONIURA user_group_remover(db, "user-1", gid)
  SI CONIURA usuario_tem_permissao(db, "user-1", "posts.deletar")
    CONIURA db_close(db)
    REDDE 3
  FIN SI
  CONIURA db_close(db)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
