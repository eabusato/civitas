INCIPIT grimoire "fase15_15g_session_and_request_helpers"

ADVOCARE "../../../../lib/civitas/auth_test/auth_test.cct"
ADVOCARE "../../../../lib/civitas/auth_test/auth_test_user.cct"
ADVOCARE "../../../../lib/civitas/auth_test/auth_test_token.cct"
ADVOCARE "../../../../lib/civitas/auth_test/auth_test_session.cct"
ADVOCARE "../../../../lib/civitas/auth_test/auth_test_request.cct"
ADVOCARE "../../../../lib/civitas/test_db/test_db.cct"
ADVOCARE "../../../../lib/civitas/test_db/test_db_setup.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA TestDb tdb AD CONIURA test_db_open_memory()
  EVOCA VERBUM user_id AD ""
  EVOCA VERBUM session_id AD ""
  EVOCA VERBUM token AD ""
  CONIURA auth_test_schema_up(tdb)
  VINCIRE user_id AD CONIURA auth_test_criar_usuario_unico_id(tdb)
  VINCIRE session_id AD CONIURA auth_test_criar_sessao_id(tdb, user_id)
  SI CONIURA compare(CONIURA auth_test_session_cookie(session_id), CONIURA concat("test_session=", session_id)) != 0
    CONIURA test_db_close(tdb)
    REDDE 1
  FIN SI
  VINCIRE token AD CONIURA auth_test_gerar_token(user_id, "api.read")
  SI CONIURA find(CONIURA auth_test_bearer_header(token), "Bearer ") != 0
    CONIURA test_db_close(tdb)
    REDDE 2
  FIN SI
  SI CONIURA len(CONIURA auth_test_req_logado_cookie(tdb, "GET", "/painel")) == 0
    CONIURA test_db_close(tdb)
    REDDE 3
  FIN SI
  SI CONIURA len(CONIURA auth_test_req_token_usuario_header(tdb, "GET", "/api", "posts.write")) == 0
    CONIURA test_db_close(tdb)
    REDDE 4
  FIN SI
  CONIURA test_db_close(tdb)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
