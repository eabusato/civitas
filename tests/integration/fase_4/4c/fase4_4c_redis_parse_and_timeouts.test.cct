INCIPIT grimoire "fase4_4c_redis_parse_and_timeouts_test"

ADVOCARE "support.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM root AD CONIURA phase4_4c_tmp_dir("4c_redis_parse")
  EVOCA VERBUM content AD "[app]\nname = \"desviados\"\nallowed_hosts = [\"127.0.0.1\"]\n\n[media]\nroot_dir = \"media\"\n\n[redis]\nurl = \"redis://:sekret@cache.internal:6380/4\"\nnamespace = \"desviados\"\nconnect_timeout_ms = 1500\nread_timeout_ms = 2500\n"
  SI CONIURA compare(CONIURA phase4_4c_redis_host_from_content(root, content), "cache.internal") != 0
    REDDE 1
  FIN SI
  SI CONIURA phase4_4c_redis_port_from_content(root, content) != 6380
    REDDE 2
  FIN SI
  SI CONIURA phase4_4c_redis_db_from_content(root, content) != 4
    REDDE 3
  FIN SI
  SI CONIURA phase4_4c_redis_connect_timeout_from_content(root, content) != 1500
    REDDE 4
  FIN SI
  SI CONIURA phase4_4c_redis_read_timeout_from_content(root, content) != 2500
    REDDE 5
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
