INCIPIT grimoire "fase4_4c_media_tools_required_missing_test"

ADVOCARE "support.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM root AD CONIURA phase4_4c_tmp_dir("4c_media_tools_required_missing")
  SI NON CONIURA phase4_4c_media_tools_is_err_from_content(
    root,
    "[app]\nname = \"desviados\"\nallowed_hosts = [\"127.0.0.1\"]\n\n[media]\nroot_dir = \"media\"\nffmpeg_required = true\nffmpeg_path = \"tests/tmp/fase_4/bin/nao-existe-ffmpeg\"\n"
  )
    REDDE 1
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
