INCIPIT grimoire "fase4_4c_missing_media_root_fails_test"

ADVOCARE "support.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM root AD CONIURA phase4_4c_tmp_dir("4c_missing_media_root")
  SI NON CONIURA phase4_4c_storage_is_err_from_content(
    root,
    "[app]\nname = \"desviados\"\nallowed_hosts = [\"127.0.0.1\"]\n"
  )
    REDDE 1
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
