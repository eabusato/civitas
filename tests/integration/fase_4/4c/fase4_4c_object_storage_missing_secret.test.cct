INCIPIT grimoire "fase4_4c_object_storage_missing_secret_test"

ADVOCARE "support.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM root AD CONIURA phase4_4c_tmp_dir("4c_object_storage_missing_secret")
  SI NON CONIURA phase4_4c_storage_is_err_from_content(
    root,
    "[app]\nname = \"desviados\"\nallowed_hosts = [\"127.0.0.1\"]\n\n[media]\nroot_dir = \"media\"\nobject_storage_enabled = true\n\n[object_storage]\nenabled = true\nendpoint = \"https://objects.example.com\"\nbucket = \"desviados\"\naccess_key = \"AKIA\"\n"
  )
    REDDE 1
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
