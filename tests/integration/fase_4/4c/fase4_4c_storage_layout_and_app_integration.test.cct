INCIPIT grimoire "fase4_4c_storage_layout_and_app_integration_test"

ADVOCARE "support.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM root AD CONIURA phase4_4c_tmp_dir("4c_storage_layout_and_app")
  SI NON CONIURA phase4_4c_app_storage_layout_ok_from_content(
    root,
    "[app]\nname = \"desviados\"\nallowed_hosts = [\"127.0.0.1\"]\n\n[media]\nroot_dir = \"var/media\"\ncreate_missing_dirs = true\n"
  )
    REDDE 2
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
