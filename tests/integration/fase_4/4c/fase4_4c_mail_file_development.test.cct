INCIPIT grimoire "fase4_4c_mail_file_development_test"

ADVOCARE "support.cct"
ADVOCARE "cct/path.cct"
ADVOCARE "cct/fs.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM root AD CONIURA phase4_4c_tmp_dir("4c_mail_file_development")
  EVOCA VERBUM out_dir AD CONIURA path_join(root, "mail_out")
  EVOCA VERBUM content AD CONIURA concat(
    "[app]\nname = \"desviados\"\nallowed_hosts = [\"127.0.0.1\"]\n\n[media]\nroot_dir = \"media\"\n\n[mail]\nbackend = \"file\"\nout_dir = \"",
    CONIURA concat(out_dir, "\"\ndefault_from = \"ops@example.com\"\n")
  )
  SI CONIURA compare(CONIURA phase4_4c_mail_backend_name_from_content(root, content), "file") != 0
    REDDE 1
  FIN SI
  SI NON CONIURA phase4_4c_mail_open_ok_from_content(root, content)
    REDDE 2
  FIN SI
  SI NON CONIURA is_dir(out_dir)
    REDDE 3
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
