INCIPIT grimoire "fase4_4c_proxy_and_search_rules_test"

ADVOCARE "support.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM root_ok AD CONIURA phase4_4c_tmp_dir("4c_proxy_ok")
  SI CONIURA phase4_4c_proxy_trusted_count_from_content(
    root_ok,
    "[app]\nname = \"desviados\"\nenvironment = \"production\"\nallowed_hosts = [\"example.com\"]\n\n[media]\nroot_dir = \"media\"\n\n[http]\ntrusted_proxies = [\"10.0.0.1\"]\ntrust_forwarded_proto = true\ntrust_forwarded_for = true\n"
  ) != 1
    REDDE 1
  FIN SI
  SI NON CONIURA phase4_4c_proxy_is_err_from_content(
    CONIURA phase4_4c_tmp_dir("4c_proxy_fail"),
    "[app]\nname = \"desviados\"\nenvironment = \"production\"\nallowed_hosts = [\"example.com\"]\n\n[media]\nroot_dir = \"media\"\n\n[http]\ntrust_forwarded_proto = true\n"
  )
    REDDE 2
  FIN SI
  SI CONIURA phase4_4c_search_enabled_from_content(
    CONIURA phase4_4c_tmp_dir("4c_search_disabled"),
    "[app]\nname = \"desviados\"\nallowed_hosts = [\"127.0.0.1\"]\n\n[media]\nroot_dir = \"media\"\n"
  )
    REDDE 3
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
