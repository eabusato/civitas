INCIPIT grimoire "fase4_4b_duplicate_module_and_late_registration_test"

ADVOCARE "support.cct"
ADVOCARE "../../../../lib/civitas/core/app.cct"
ADVOCARE "../../../../lib/civitas/core/app_module.cct"
ADVOCARE "cct/result.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM root AD CONIURA phase4_4b_tmp_dir("4b_duplicate_module")
  EVOCA Application app AD CONIURA phase4_4b_new_app(
    root,
    "[app]\nname = \"desviados\"\nallowed_hosts = [\"127.0.0.1\"]\n"
  )
  EVOCA AppModule module_a AD CONIURA app_module_new("alpha", "desviados.core")
  EVOCA AppModule module_b AD CONIURA app_module_new("alpha", "desviados.core")
  EVOCA SPECULUM NIHIL first_res AD CONIURA app_register_module(SPECULUM app, module_a)
  EVOCA SPECULUM NIHIL dup_res
  EVOCA SPECULUM NIHIL late_res

  SI CONIURA result_is_err GENUS(REX, VERBUM)(first_res)
    REDDE 1
  FIN SI
  VINCIRE dup_res AD CONIURA app_register_module(SPECULUM app, module_b)
  SI NON CONIURA result_is_err GENUS(REX, VERBUM)(dup_res)
    REDDE 2
  FIN SI

  SI CONIURA result_is_err GENUS(REX, VERBUM)(CONIURA app_start(SPECULUM app))
    REDDE 3
  FIN SI
  VINCIRE late_res AD CONIURA app_register_module(SPECULUM app, CONIURA app_module_new("late", "desviados.core"))
  SI NON CONIURA result_is_err GENUS(REX, VERBUM)(late_res)
    REDDE 4
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
