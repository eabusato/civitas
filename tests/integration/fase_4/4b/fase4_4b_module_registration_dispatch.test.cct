INCIPIT grimoire "fase4_4b_module_registration_dispatch_test"

ADVOCARE "support.cct"
ADVOCARE "../../fase_3/support/common.cct"
ADVOCARE "../../../../lib/civitas/core/app.cct"
ADVOCARE "../../../../lib/civitas/core/app_module.cct"
ADVOCARE "../../../../lib/civitas/request_core.cct"
ADVOCARE "../../../../lib/civitas/response.cct"
ADVOCARE "cct/result.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM root AD CONIURA phase4_4b_tmp_dir("4b_module_registration_dispatch")
  EVOCA Application app AD CONIURA phase4_4b_new_app(
    root,
    "[app]\nname = \"desviados\"\nallowed_hosts = [\"example.test\"]\n"
  )
  EVOCA AppModule module AD CONIURA app_module_new("blog", "desviados.web")
  EVOCA SPECULUM NIHIL register_res
  EVOCA SPECULUM NIHIL start_res

  VINCIRE module.register_routes_ref AD phase4_4b_register_routes
  VINCIRE module.register_middleware_ref AD phase4_4b_register_middleware
  VINCIRE register_res AD CONIURA app_register_module(SPECULUM app, module)
  SI CONIURA result_is_err GENUS(REX, VERBUM)(register_res)
    REDDE 1
  FIN SI

  VINCIRE start_res AD CONIURA app_start(SPECULUM app)
  SI CONIURA result_is_err GENUS(REX, VERBUM)(start_res)
    REDDE 2
  FIN SI

  EVOCA WebRequest req AD CONIURA phase3_request("GET", "/module")
  EVOCA WebResponse res AD CONIURA app_dispatch(SPECULUM app, req)
  SI res.status != 200
    REDDE 3
  FIN SI
  SI CONIURA compare(res.body, "module-ok") != 0
    REDDE 4
  FIN SI
  SI CONIURA compare(CONIURA response_header_or(res, "x-module-middleware", ""), "1") != 0
    REDDE 5
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
