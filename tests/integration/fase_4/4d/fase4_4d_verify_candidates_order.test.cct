INCIPIT grimoire "fase4_4d_verify_candidates_order_test"

ADVOCARE "support.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM root AD CONIURA phase4_4d_tmp_dir("4d_verify_candidates_order")
  EVOCA SPECULUM NIHIL env_pairs AD CONIURA phase4_4d_env_pairs()
  CONIURA phase4_4d_prepare_project(
    root,
    "[app]\nname = \"desviados\"\nallowed_hosts = [\"127.0.0.1\"]\n\n[secrets.session]\nactive_key_id = \"sess_2026_03\"\naccepted_previous_key_ids = [\"sess_2026_02\", \"sess_2026_01\"]\ngrace_seconds = 3600\nactive_material_env = \"CIVITAS_SECRET__SESSION__SESS_2026_03\"\nprevious_material_envs = [\"CIVITAS_SECRET__SESSION__SESS_2026_02\", \"CIVITAS_SECRET__SESSION__SESS_2026_01\"]\n\n[secrets.csrf]\nenabled = false\n\n[secrets.signed_cookie]\nenabled = false\n\n[secrets.token]\nenabled = false\n\n[secrets.temporary_link]\nenabled = false\n"
  )
  CONIURA phase4_4d_env_add(env_pairs, "CIVITAS_SECRET__SESSION__SESS_2026_03", "active")
  CONIURA phase4_4d_env_add(env_pairs, "CIVITAS_SECRET__SESSION__SESS_2026_02", "prev2")
  CONIURA phase4_4d_env_add(env_pairs, "CIVITAS_SECRET__SESSION__SESS_2026_01", "prev1")
  SI CONIURA compare(
    CONIURA phase4_4d_candidate_ids(root, root, "session", env_pairs),
    "sess_2026_03,sess_2026_02,sess_2026_01"
  ) != 0
    REDDE 1
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
