INCIPIT grimoire "fase4_4d_optional_domain_disabled_test"

ADVOCARE "support.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM root AD CONIURA phase4_4d_tmp_dir("4d_optional_domain_disabled")
  EVOCA SPECULUM NIHIL env_pairs AD CONIURA phase4_4d_env_pairs()
  EVOCA VERBUM dump
  CONIURA phase4_4d_prepare_project(
    root,
    "[app]\nname = \"desviados\"\nallowed_hosts = [\"127.0.0.1\"]\n\n[secrets.session]\nactive_key_id = \"sess_2026_03\"\ngrace_seconds = 3600\nactive_material_env = \"CIVITAS_SECRET__SESSION__SESS_2026_03\"\n\n[secrets.csrf]\nenabled = false\n\n[secrets.signed_cookie]\nenabled = false\n\n[secrets.token]\nenabled = false\n\n[secrets.temporary_link]\nenabled = false\n"
  )
  CONIURA phase4_4d_env_add(env_pairs, "CIVITAS_SECRET__SESSION__SESS_2026_03", "active")
  SI CONIURA compare(CONIURA phase4_4d_active_key_id(root, root, "session", env_pairs), "sess_2026_03") != 0
    REDDE 1
  FIN SI
  VINCIRE dump AD CONIURA phase4_4d_safe_dump(root, root, env_pairs)
  SI CONIURA find(dump, "domain=token enabled=false") == -1
    REDDE 2
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
