INCIPIT grimoire "fase4_secrets_probe"

ADVOCARE "../../../../lib/civitas/core/keyring.cct"
ADVOCARE "../../../../lib/civitas/core/secrets.cct"
ADVOCARE "../../../../lib/civitas/core/settings.cct"
ADVOCARE "../../../../lib/civitas/core/settings_schema.cct"
ADVOCARE "cct/args.cct"
ADVOCARE "cct/fmt.cct"
ADVOCARE "cct/fs.cct"
ADVOCARE "cct/result.cct"
ADVOCARE "cct/fluxus.cct"
ADVOCARE "cct/verbum.cct"

RITUALE probe_arg_normalize(VERBUM value) REDDE VERBUM
  SI CONIURA compare(value, "__civitas_empty__") == 0
    REDDE ""
  FIN SI
  REDDE value
EXPLICIT RITUALE

RITUALE probe_write_error(VERBUM out_path, VERBUM message) REDDE REX
  CONIURA write_all(out_path, CONIURA concat("ERR:", message))
  REDDE 0
EXPLICIT RITUALE

RITUALE probe_domain(VERBUM raw_domain) REDDE SecretDomain
  SI CONIURA compare(raw_domain, "session") == 0
    REDDE SECRET_DOMAIN_SESSION
  FIN SI
  SI CONIURA compare(raw_domain, "csrf") == 0
    REDDE SECRET_DOMAIN_CSRF
  FIN SI
  SI CONIURA compare(raw_domain, "signed_cookie") == 0
    REDDE SECRET_DOMAIN_SIGNED_COOKIE
  FIN SI
  SI CONIURA compare(raw_domain, "token") == 0
    REDDE SECRET_DOMAIN_TOKEN
  FIN SI
  SI CONIURA compare(raw_domain, "temporary_link") == 0
    REDDE SECRET_DOMAIN_TEMPORARY_LINK
  FIN SI
  REDDE SECRET_DOMAIN_SESSION
EXPLICIT RITUALE

RITUALE probe_join_candidate_ids(SPECULUM NIHIL candidates) REDDE VERBUM
  EVOCA VERBUM out AD ""
  EVOCA REX i AD 0
  EVOCA REX n AD CONIURA fluxus_len(candidates)
  DUM i < n
    EVOCA SPECULUM SecretKey key_ptr AD CONIURA fluxus_get(candidates, i)
    SI i != 0
      VINCIRE out AD CONIURA concat(out, ",")
    FIN SI
    VINCIRE out AD CONIURA concat(out, (*key_ptr).key_id)
    VINCIRE i AD i + 1
  FIN DUM
  REDDE out
EXPLICIT RITUALE

RITUALE main() REDDE REX
  EVOCA VERBUM project_root AD CONIURA arg(1)
  EVOCA VERBUM action AD CONIURA arg(2)
  EVOCA VERBUM domain_raw AD CONIURA probe_arg_normalize(CONIURA arg(3))
  EVOCA VERBUM value AD CONIURA probe_arg_normalize(CONIURA arg(4))
  EVOCA VERBUM out_path AD CONIURA arg(5)
  EVOCA SPECULUM Settings settings_ptr AD OBSECRO mem_alloc(MENSURA(Settings))
  EVOCA SPECULUM NIHIL settings_res AD CONIURA settings_load_with_env_fill(settings_ptr, project_root, "")
  EVOCA SPECULUM NIHIL secrets_res
  EVOCA SPECULUM SecretRegistry registry_ptr
  EVOCA SecretDomain domain AD CONIURA probe_domain(domain_raw)

  SI CONIURA result_is_err GENUS(REX, VERBUM)(settings_res)
    REDDE CONIURA probe_write_error(out_path, CONIURA result_unwrap_err GENUS(REX, VERBUM)(settings_res))
  FIN SI
  VINCIRE secrets_res AD CONIURA secrets_load(settings_ptr)
  SI CONIURA result_is_err GENUS(SecretRegistry, VERBUM)(secrets_res)
    REDDE CONIURA probe_write_error(out_path, CONIURA result_unwrap_err GENUS(SecretRegistry, VERBUM)(secrets_res))
  FIN SI
  VINCIRE registry_ptr AD OBSECRO result_unwrap_ptr(secrets_res)

  SI CONIURA compare(action, "active_key_id") == 0
    EVOCA SPECULUM NIHIL active_res AD CONIURA secrets_active_key_id(registry_ptr, domain)
    SI CONIURA result_is_err GENUS(VERBUM, VERBUM)(active_res)
      REDDE CONIURA probe_write_error(out_path, CONIURA result_unwrap_err GENUS(VERBUM, VERBUM)(active_res))
    FIN SI
    CONIURA write_all(out_path, CONIURA result_unwrap GENUS(VERBUM, VERBUM)(active_res))
    REDDE 0
  FIN SI

  SI CONIURA compare(action, "active_material") == 0
    EVOCA SPECULUM NIHIL active_res AD CONIURA secrets_active(registry_ptr, domain)
    SI CONIURA result_is_err GENUS(SecretKey, VERBUM)(active_res)
      REDDE CONIURA probe_write_error(out_path, CONIURA result_unwrap_err GENUS(SecretKey, VERBUM)(active_res))
    FIN SI
    EVOCA SecretKey active_key AD CONIURA result_unwrap GENUS(SecretKey, VERBUM)(active_res)
    CONIURA write_all(out_path, active_key.material)
    REDDE 0
  FIN SI

  SI CONIURA compare(action, "verify_candidate_ids") == 0
    EVOCA SPECULUM SecretKeyRing ring_ptr AD CONIURA secrets_ring_ptr(registry_ptr, domain)
    SI NON (*ring_ptr).enabled
      REDDE CONIURA probe_write_error(out_path, CONIURA concat("dominio de segredo desabilitado: ", CONIURA secret_domain_name(domain)))
    FIN SI
    CONIURA write_all(out_path, CONIURA probe_join_candidate_ids((*ring_ptr).verify_candidates))
    REDDE 0
  FIN SI

  SI CONIURA compare(action, "policy_grace") == 0
    EVOCA SPECULUM NIHIL policy_res AD CONIURA secrets_rotation_policy(registry_ptr, domain)
    SI CONIURA result_is_err GENUS(SecretRotationPolicy, VERBUM)(policy_res)
      REDDE CONIURA probe_write_error(out_path, CONIURA result_unwrap_err GENUS(SecretRotationPolicy, VERBUM)(policy_res))
    FIN SI
    EVOCA SecretRotationPolicy policy AD CONIURA result_unwrap GENUS(SecretRotationPolicy, VERBUM)(policy_res)
    CONIURA write_all(out_path, CONIURA stringify_int(policy.grace_seconds))
    REDDE 0
  FIN SI

  SI CONIURA compare(action, "lookup_material") == 0
    EVOCA SecretLookupResult lookup AD CONIURA secrets_lookup(registry_ptr, domain, value)
    SI NON lookup.found
      REDDE CONIURA probe_write_error(out_path, lookup.message)
    FIN SI
    CONIURA write_all(out_path, lookup.key.material)
    REDDE 0
  FIN SI

  SI CONIURA compare(action, "safe_dump") == 0
    CONIURA write_all(out_path, CONIURA secrets_safe_dump(registry_ptr))
    REDDE 0
  FIN SI

  REDDE CONIURA probe_write_error(out_path, "acao desconhecida")
EXPLICIT RITUALE

EXPLICIT grimoire
