INCIPIT grimoire "fase4_4d_grace_zero_excludes_previous_test"

ADVOCARE "support.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM root AD CONIURA phase4_4d_tmp_dir("4d_grace_zero")
  EVOCA SPECULUM NIHIL env_pairs AD CONIURA phase4_4d_env_pairs()
  CONIURA phase4_4d_prepare_project(
    root,
    "[app]\nname = \"desviados\"\nallowed_hosts = [\"127.0.0.1\"]\n\n[secrets.session]\nactive_key_id = \"sess_2026_03\"\naccepted_previous_key_ids = [\"sess_2026_02\"]\ngrace_seconds = 0\nactive_material_env = \"CIVITAS_SECRET__SESSION__SESS_2026_03\"\nprevious_material_envs = [\"CIVITAS_SECRET__SESSION__SESS_2026_02\"]\n\n[secrets.csrf]\nenabled = false\n\n[secrets.signed_cookie]\nenabled = false\n\n[secrets.token]\nenabled = false\n\n[secrets.temporary_link]\nenabled = false\n"
  )
  CONIURA phase4_4d_env_add(env_pairs, "CIVITAS_SECRET__SESSION__SESS_2026_03", "active")
  SI CONIURA compare(CONIURA phase4_4d_candidate_ids(root, root, "session", env_pairs), "sess_2026_03") != 0
    REDDE 1
  FIN SI
  SI CONIURA phase4_4d_policy_grace_seconds(root, root, "session", env_pairs) != 0
    REDDE 2
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
