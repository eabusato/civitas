INCIPIT grimoire "fase4_4d_legacy_global_without_flag_fails_test"

ADVOCARE "support.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM root AD CONIURA phase4_4d_tmp_dir("4d_legacy_global_without_flag")
  EVOCA SPECULUM NIHIL env_pairs AD CONIURA phase4_4d_env_pairs()
  EVOCA VERBUM output
  CONIURA phase4_4d_prepare_project(
    root,
    "[app]\nname = \"desviados\"\nallowed_hosts = [\"127.0.0.1\"]\n\n[secrets]\nlegacy_global_key_enabled = false\nlegacy_global_key_material_env = \"CIVITAS_SECRET__LEGACY\"\n\n[secrets.session]\nactive_key_id = \"\"\naccepted_previous_key_ids = []\ngrace_seconds = 0\nactive_material_env = \"\"\nprevious_material_envs = []\n\n[secrets.csrf]\nenabled = false\n\n[secrets.signed_cookie]\nenabled = false\n\n[secrets.token]\nenabled = false\n\n[secrets.temporary_link]\nenabled = false\n"
  )
  CONIURA phase4_4d_env_add(env_pairs, "CIVITAS_SECRET__LEGACY", "legacy-material")
  VINCIRE output AD CONIURA phase4_4d_run_probe(root, root, "active_key_id", "session", "", env_pairs)
  SI NON CONIURA phase4_4d_output_is_err(output)
    REDDE 1
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
