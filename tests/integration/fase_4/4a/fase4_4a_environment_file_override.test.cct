INCIPIT grimoire "fase4_4a_environment_file_override_test"

ADVOCARE "support.cct"
ADVOCARE "cct/path.cct"
ADVOCARE "cct/fluxus.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM root AD CONIURA phase4_4a_tmp_dir("4a_env_file")
  EVOCA SPECULUM NIHIL envs AD CONIURA fluxus_init(MENSURA(VERBUM))
  EVOCA VERBUM port_out AD ""
  EVOCA VERBUM debug_out AD ""
  EVOCA VERBUM origin_out AD ""
  EVOCA VERBUM dump_out AD ""

  CONIURA phase4_4a_reset_dir(root)
  CONIURA phase4_4a_write(
    CONIURA path_join(root, "civitas.toml"),
    "[app]\nname = \"desviados\"\nallowed_hosts = [\"localhost\"]\ndebug = false\n\n[http]\nport = 8080\n"
  )
  CONIURA phase4_4a_write(
    CONIURA path_join(root, "civitas.test.toml"),
    "[app]\ndebug = true\n\n[http]\nport = 9091\n"
  )

  VINCIRE port_out AD CONIURA phase4_4a_run_probe(root, root, "test", "get_rex", "http.port", envs)
  VINCIRE debug_out AD CONIURA phase4_4a_run_probe(root, root, "test", "get_bool", "app.debug", envs)
  VINCIRE origin_out AD CONIURA phase4_4a_run_probe(root, root, "test", "origin", "http.port", envs)
  VINCIRE dump_out AD CONIURA phase4_4a_run_probe(root, root, "test", "dump", "", envs)

  SI CONIURA compare(CONIURA trim(port_out), "9091") != 0
    REDDE 1
  FIN SI
  SI CONIURA compare(CONIURA trim(debug_out), "true") != 0
    REDDE 2
  FIN SI
  SI CONIURA compare(CONIURA trim(origin_out), "file_environment") != 0
    REDDE 3
  FIN SI
  SI CONIURA find(dump_out, "app.environment = test") == -1
    REDDE 4
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
