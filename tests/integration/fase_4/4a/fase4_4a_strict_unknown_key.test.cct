INCIPIT grimoire "fase4_4a_strict_unknown_key_test"

ADVOCARE "support.cct"
ADVOCARE "cct/fluxus.cct"
ADVOCARE "cct/path.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM root AD CONIURA phase4_4a_tmp_dir("4a_strict_unknown")
  EVOCA SPECULUM NIHIL envs AD CONIURA fluxus_init(MENSURA(VERBUM))
  EVOCA VERBUM pair AD "CIVITAS_SETTINGS_STRICT=true"
  EVOCA VERBUM out AD ""

  CONIURA phase4_4a_reset_dir(root)
  CONIURA phase4_4a_write(
    CONIURA path_join(root, "civitas.toml"),
    "[app]\nname = \"desviados\"\nallowed_hosts = [\"localhost\"]\nrogue = \"x\"\n\n[http]\nhost = \"127.0.0.1\"\nport = 8080\n"
  )
  CONIURA fluxus_push(envs, SPECULUM pair)

  VINCIRE out AD CONIURA phase4_4a_run_probe(root, root, "development", "dump", "", envs)
  SI CONIURA find(out, "ERR:") != 0
    REDDE 1
  FIN SI
  SI CONIURA find(out, "modo estrito") == -1
    REDDE 2
  FIN SI
  SI CONIURA find(out, "rogue") == -1
    REDDE 3
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
