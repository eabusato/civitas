INCIPIT grimoire "fase4_4a_load_base_and_namespace_test"

ADVOCARE "support.cct"
ADVOCARE "cct/fluxus.cct"
ADVOCARE "cct/path.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM root AD CONIURA phase4_4a_tmp_dir("4a_load_base")
  EVOCA SPECULUM NIHIL envs AD CONIURA fluxus_init(MENSURA(VERBUM))
  EVOCA VERBUM name_out AD ""
  EVOCA VERBUM port_out AD ""
  EVOCA VERBUM hosts_len_out AD ""
  EVOCA VERBUM has_host_out AD ""
  EVOCA VERBUM dump_out AD ""

  CONIURA phase4_4a_reset_dir(root)
  CONIURA phase4_4a_write(
    CONIURA path_join(root, "civitas.toml"),
    "[app]\nname = \"desviados\"\nallowed_hosts = [\"127.0.0.1\", \"localhost\"]\n\n[http]\nhost = \"127.0.0.1\"\nport = 8088\n"
  )

  VINCIRE name_out AD CONIURA phase4_4a_run_probe(root, root, "development", "get_verbum", "app.name", envs)
  VINCIRE port_out AD CONIURA phase4_4a_run_probe(root, root, "development", "get_rex", "http.port", envs)
  VINCIRE hosts_len_out AD CONIURA phase4_4a_run_probe(root, root, "development", "get_list_len", "app.allowed_hosts", envs)
  VINCIRE has_host_out AD CONIURA phase4_4a_run_probe(root, root, "development", "has_key", "http.host", envs)
  VINCIRE dump_out AD CONIURA phase4_4a_run_probe(root, root, "development", "dump", "", envs)
  SI CONIURA compare(CONIURA trim(name_out), "desviados") != 0
    REDDE 1
  FIN SI
  SI CONIURA compare(CONIURA trim(port_out), "8088") != 0
    REDDE 2
  FIN SI
  SI CONIURA compare(CONIURA trim(hosts_len_out), "2") != 0
    REDDE 3
  FIN SI
  SI CONIURA compare(CONIURA trim(has_host_out), "true") != 0
    REDDE 4
  FIN SI
  SI CONIURA find(dump_out, "app.environment = development") == -1
    REDDE 5
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
