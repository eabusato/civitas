INCIPIT grimoire "fase0_0d_release_notes_exists_test"

ADVOCARE "cct/fs.cct"

RITUALE main() REDDE REX
  SI NON CONIURA is_file("docs/release/FASE_0_RELEASE_NOTES.md")
    REDDE 1
  FIN SI
  SI NON CONIURA is_file("docs/phase_map.md")
    REDDE 2
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
