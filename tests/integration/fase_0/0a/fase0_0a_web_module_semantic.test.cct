INCIPIT grimoire "fase0_0a_web_module_semantic_test"

ADVOCARE "../support/common.cct"

RITUALE main() REDDE REX
  SI CONIURA compiler_check("lib/civitas/web/app.cct") != 0
    REDDE 1
  FIN SI
  SI CONIURA compiler_check("src/main.cct") != 0
    REDDE 2
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
