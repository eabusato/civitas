INCIPIT grimoire "fase0_0a_example_layout_test"

ADVOCARE "../support/common.cct"
ADVOCARE "cct/fs.cct"

RITUALE main() REDDE REX
  SI NON CONIURA is_dir("examples/salve_civitas")
    REDDE 1
  FIN SI
  SI NON CONIURA is_file("examples/salve_civitas/cct.toml")
    REDDE 2
  FIN SI
  SI NON CONIURA is_file("examples/salve_civitas/main.cct")
    REDDE 3
  FIN SI
  SI CONIURA compiler_check("examples/salve_civitas/main.cct") != 0
    REDDE 4
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
