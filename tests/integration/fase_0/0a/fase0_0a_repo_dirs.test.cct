INCIPIT grimoire "fase0_0a_repo_dirs_test"

ADVOCARE "../support/common.cct"
ADVOCARE "cct/fs.cct"

RITUALE main() REDDE REX
  CONIURA ensure_tmp_root()

  SI NON CONIURA is_dir("src")
    REDDE 1
  FIN SI
  SI NON CONIURA is_dir("lib/civitas/core")
    REDDE 2
  FIN SI
  SI NON CONIURA is_dir("lib/civitas/http")
    REDDE 3
  FIN SI
  SI NON CONIURA is_dir("lib/civitas/web")
    REDDE 4
  FIN SI
  SI NON CONIURA is_dir("examples")
    REDDE 5
  FIN SI
  SI NON CONIURA is_dir("tests")
    REDDE 6
  FIN SI
  SI NON CONIURA is_dir("docs")
    REDDE 7
  FIN SI

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
