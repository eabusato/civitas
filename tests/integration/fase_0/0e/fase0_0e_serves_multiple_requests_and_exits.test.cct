INCIPIT grimoire "fase0_0e_serves_multiple_requests_and_exits_test"

ADVOCARE "../support/common.cct"
ADVOCARE "cct/fs.cct"
ADVOCARE "cct/http.cct"
ADVOCARE "cct/time.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM ready AD CONIURA tmp_file("fase0_0e_multi.ready")
  EVOCA VERBUM done AD CONIURA tmp_file("fase0_0e_multi.done")
  EVOCA VERBUM log AD CONIURA tmp_file("fase0_0e_multi.server.log")
  EVOCA VERBUM cmd AD "CIVITAS_PORT=18084 CIVITAS_MAX_REQUESTS=2 "

  CONIURA cleanup_file(ready)
  CONIURA cleanup_file(done)
  CONIURA cleanup_file(log)

  SI CONIURA run_to_log("make examples", log) != 0
    REDDE 1
  FIN SI

  VINCIRE cmd AD CONIURA concat(cmd, "CIVITAS_READY_FILE=")
  VINCIRE cmd AD CONIURA concat(cmd, ready)
  VINCIRE cmd AD CONIURA concat(cmd, " CIVITAS_DONE_FILE=")
  VINCIRE cmd AD CONIURA concat(cmd, done)
  VINCIRE cmd AD CONIURA concat(cmd, " ./examples/salve_civitas/dist/salve_civitas")

  SI CONIURA spawn_to_log(cmd, log) != 0
    REDDE 2
  FIN SI
  SI NON CONIURA wait_for_file(ready, 4000)
    REDDE 3
  FIN SI
  SI CONIURA compare(CONIURA read_all(ready), "skip") == 0
    REDDE 0
  FIN SI
  CONIURA sleep_ms(50)

  EVOCA HttpResponse first AD CONIURA http_get("http://127.0.0.1:18084/")
  EVOCA HttpResponse second AD CONIURA http_get("http://127.0.0.1:18084/")

  SI CONIURA compare(CONIURA http_response_body(first), "Salve, Civitas") != 0
    REDDE 4
  FIN SI
  SI CONIURA compare(CONIURA http_response_body(second), "Salve, Civitas") != 0
    REDDE 5
  FIN SI
  SI NON CONIURA wait_for_file(done, 4000)
    REDDE 6
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
