INCIPIT grimoire "fase0_0c_make_help_targets_test"

ADVOCARE "cct/process.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM out AD CONIURA run_capture("make help")
  SI NON CONIURA contains(out, "make build")
    REDDE 1
  FIN SI
  SI NON CONIURA contains(out, "make test")
    REDDE 2
  FIN SI
  SI NON CONIURA contains(out, "make examples")
    REDDE 3
  FIN SI
  SI NON CONIURA contains(out, "make clean")
    REDDE 4
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
