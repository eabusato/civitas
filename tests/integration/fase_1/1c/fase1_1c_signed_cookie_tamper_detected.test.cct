INCIPIT grimoire "fase1_1c_signed_cookie_tamper_detected_test"

ADVOCARE "../../../../lib/civitas/cookie.cct"
ADVOCARE "cct/result.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM signed_cookie AD CONIURA cookie_sign("sid", "payload", "segredo")
  VINCIRE signed_cookie AD CONIURA concat(signed_cookie, "x")
  SI NON CONIURA result_is_err GENUS(VERBUM, VERBUM)(CONIURA cookie_verify(signed_cookie, "segredo"))
    REDDE 1
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
