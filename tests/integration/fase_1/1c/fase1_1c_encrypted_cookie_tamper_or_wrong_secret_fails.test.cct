INCIPIT grimoire "fase1_1c_encrypted_cookie_tamper_or_wrong_secret_fails_test"

ADVOCARE "../../../../lib/civitas/cookie.cct"
ADVOCARE "cct/result.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM protected AD CONIURA cookie_encrypt("sid", "segredo-do-cookie", "chave-super")
  EVOCA VERBUM tampered AD CONIURA concat(protected, "x")
  SI NON CONIURA result_is_err GENUS(VERBUM, VERBUM)(CONIURA cookie_decrypt(tampered, "chave-super"))
    REDDE 1
  FIN SI
  SI NON CONIURA result_is_err GENUS(VERBUM, VERBUM)(CONIURA cookie_decrypt(protected, "outra-chave"))
    REDDE 2
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
