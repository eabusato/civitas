INCIPIT grimoire "fase1_1b_parse_relative_target_test"

ADVOCARE "../../../../lib/civitas/url.cct"
ADVOCARE "cct/result.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL res AD CONIURA url_parse("/docs/../rota/?a=1#sec")
  SI CONIURA result_is_err GENUS(WebUrl, VERBUM)(res)
    REDDE 1
  FIN SI
  EVOCA WebUrl url AD CONIURA result_unwrap GENUS(WebUrl, VERBUM)(res)
  SI url.is_absolute
    REDDE 2
  FIN SI
  SI CONIURA compare(url.scheme, "") != 0 VEL CONIURA compare(url.host, "") != 0
    REDDE 3
  FIN SI
  SI CONIURA compare(url.path, "/docs/../rota/") != 0
    REDDE 4
  FIN SI
  SI CONIURA compare(url.normalized_path, "/rota/") != 0
    REDDE 5
  FIN SI
  SI CONIURA compare(url.query_raw, "a=1") != 0
    REDDE 6
  FIN SI
  SI CONIURA compare(url.fragment, "sec") != 0
    REDDE 7
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
