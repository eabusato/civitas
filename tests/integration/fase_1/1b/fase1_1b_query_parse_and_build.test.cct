INCIPIT grimoire "fase1_1b_query_parse_and_build_test"

ADVOCARE "../../../../lib/civitas/url.cct"
ADVOCARE "cct/option.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL params AD CONIURA url_parse_query("a=1&b=2")
  EVOCA SPECULUM NIHIL a_opt AD CONIURA url_query_get(params, "a")
  EVOCA SPECULUM NIHIL b_opt AD CONIURA url_query_get(params, "b")
  SI CONIURA option_is_none GENUS(VERBUM)(a_opt) VEL CONIURA option_is_none GENUS(VERBUM)(b_opt)
    REDDE 1
  FIN SI
  SI CONIURA compare(CONIURA option_unwrap GENUS(VERBUM)(a_opt), "1") != 0
    REDDE 2
  FIN SI
  SI CONIURA compare(CONIURA option_unwrap GENUS(VERBUM)(b_opt), "2") != 0
    REDDE 3
  FIN SI
  SI CONIURA compare(CONIURA url_build_query(params), "a=1&b=2") != 0
    REDDE 4
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
