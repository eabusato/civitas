INCIPIT grimoire "fase1_1b_percent_decode_and_invalid_preserve_test"

ADVOCARE "../../../../lib/civitas/url.cct"
ADVOCARE "cct/option.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL ok_params AD CONIURA url_parse_query("nome=Salve%20Civitas&plus=a+b")
  EVOCA SPECULUM NIHIL bad_params AD CONIURA url_parse_query("bad=%ZZ")
  EVOCA SPECULUM NIHIL nome_opt AD CONIURA url_query_get(ok_params, "nome")
  EVOCA SPECULUM NIHIL plus_opt AD CONIURA url_query_get(ok_params, "plus")
  EVOCA SPECULUM NIHIL bad_opt AD CONIURA url_query_get(bad_params, "bad")
  SI CONIURA option_is_none GENUS(VERBUM)(nome_opt) VEL CONIURA option_is_none GENUS(VERBUM)(plus_opt) VEL CONIURA option_is_none GENUS(VERBUM)(bad_opt)
    REDDE 1
  FIN SI
  SI CONIURA compare(CONIURA option_unwrap GENUS(VERBUM)(nome_opt), "Salve Civitas") != 0
    REDDE 2
  FIN SI
  SI CONIURA compare(CONIURA option_unwrap GENUS(VERBUM)(plus_opt), "a b") != 0
    REDDE 3
  FIN SI
  SI CONIURA compare(CONIURA option_unwrap GENUS(VERBUM)(bad_opt), "%ZZ") != 0
    REDDE 4
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
