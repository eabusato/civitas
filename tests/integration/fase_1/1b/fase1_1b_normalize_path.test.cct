INCIPIT grimoire "fase1_1b_normalize_path_test"

ADVOCARE "../../../../lib/civitas/url.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  SI CONIURA compare(CONIURA url_normalize_path("//a///b/./c/../"), "/a/b/") != 0
    REDDE 1
  FIN SI
  SI CONIURA compare(CONIURA url_normalize_path("/../../x"), "/x") != 0
    REDDE 2
  FIN SI
  SI CONIURA compare(CONIURA url_normalize_path("/"), "/") != 0
    REDDE 3
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
