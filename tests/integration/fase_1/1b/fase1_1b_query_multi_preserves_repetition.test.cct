INCIPIT grimoire "fase1_1b_query_multi_preserves_repetition_test"

ADVOCARE "../../../../lib/civitas/url.cct"
ADVOCARE "cct/fluxus.cct"
ADVOCARE "cct/option.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL multi AD CONIURA url_parse_query_multi("a=1&a=2&a=3")
  EVOCA SPECULUM NIHIL opt AD CONIURA url_query_multi_get(multi, "a")
  SI CONIURA option_is_none GENUS(UrlQueryMulti)(opt)
    REDDE 1
  FIN SI
  EVOCA UrlQueryMulti values AD CONIURA option_unwrap GENUS(UrlQueryMulti)(opt)
  SI CONIURA fluxus_len(values.items) != 3
    REDDE 2
  FIN SI
  EVOCA SPECULUM VERBUM v0 AD CONIURA fluxus_get(values.items, 0)
  EVOCA SPECULUM VERBUM v1 AD CONIURA fluxus_get(values.items, 1)
  EVOCA SPECULUM VERBUM v2 AD CONIURA fluxus_get(values.items, 2)
  SI CONIURA compare(*v0, "1") != 0
    REDDE 3
  FIN SI
  SI CONIURA compare(*v1, "2") != 0
    REDDE 4
  FIN SI
  SI CONIURA compare(*v2, "3") != 0
    REDDE 5
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
