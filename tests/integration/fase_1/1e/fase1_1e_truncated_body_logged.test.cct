INCIPIT grimoire "fase1_1e_truncated_body_logged_test"

ADVOCARE "../support/common.cct"
ADVOCARE "cct/fs.cct"
ADVOCARE "cct/net.cct"
ADVOCARE "cct/socket.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM ready AD CONIURA tmp_file("fase1_1e_truncated_body.ready")
  EVOCA VERBUM done AD CONIURA tmp_file("fase1_1e_truncated_body.done")
  EVOCA VERBUM log AD CONIURA tmp_file("fase1_1e_truncated_body.log")
  EVOCA VERBUM reqlog AD CONIURA tmp_file("fase1_1e_truncated_body.requests.log")
  EVOCA VERBUM stats AD CONIURA tmp_file("fase1_1e_truncated_body.stats")
  EVOCA SPECULUM NIHIL sock
  EVOCA VERBUM req AD "POST /echo HTTP/1.1"
  EVOCA VERBUM errlog AD ""

  CONIURA cleanup_file(ready)
  CONIURA cleanup_file(done)
  CONIURA cleanup_file(log)
  CONIURA cleanup_file(reqlog)
  CONIURA cleanup_file(stats)

  SI CONIURA build_probe_server(log) != 0
    REDDE 1
  FIN SI
  SI CONIURA spawn_to_log(CONIURA probe_command_with_hardening(18116, 1, ready, done, reqlog, stats, 500, 500, 500, 4096, 32, 4096), log) != 0
    REDDE 2
  FIN SI
  SI NON CONIURA wait_for_file(ready, 4000)
    REDDE 3
  FIN SI
  SI CONIURA compare(CONIURA read_all(ready), "skip") == 0
    REDDE 0
  FIN SI

  VINCIRE req AD CONIURA concat(req, CONIURA crlf())
  VINCIRE req AD CONIURA concat(req, "Host: 127.0.0.1")
  VINCIRE req AD CONIURA concat(req, CONIURA crlf())
  VINCIRE req AD CONIURA concat(req, "Content-Length: 10")
  VINCIRE req AD CONIURA concat(req, CONIURA crlf())
  VINCIRE req AD CONIURA concat(req, "Connection: close")
  VINCIRE req AD CONIURA concat(req, CONIURA crlf())
  VINCIRE req AD CONIURA concat(req, CONIURA crlf())
  VINCIRE req AD CONIURA concat(req, "abc")

  VINCIRE sock AD CONIURA open_local_socket(18116)
  SI CONIURA send_raw(sock, req) != 0
    REDDE 4
  FIN SI
  CONIURA net_close(sock)

  SI NON CONIURA wait_for_file(done, 4000)
    REDDE 5
  FIN SI
  SI NON CONIURA exists(reqlog)
    REDDE 6
  FIN SI
  VINCIRE errlog AD CONIURA read_all(reqlog)
  SI CONIURA find(errlog, "ParseErrTruncatedBody") == -1
    REDDE 7
  FIN SI
  SI CONIURA find(errlog, "body truncado antes do content-length prometido") == -1
    REDDE 8
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
