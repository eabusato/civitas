INCIPIT grimoire "fase1_1d_parse_content_type_boundary_test"

ADVOCARE "../../../../lib/civitas/mime.cct"
ADVOCARE "cct/option.cct"
ADVOCARE "cct/result.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL res AD CONIURA mime_parse_content_type("multipart/form-data; boundary=abc123")
  SI CONIURA result_is_err GENUS(ContentType, VERBUM)(res)
    REDDE 1
  FIN SI
  EVOCA ContentType parsed AD CONIURA result_unwrap GENUS(ContentType, VERBUM)(res)
  EVOCA SPECULUM NIHIL boundary_opt AD CONIURA mime_param_get(parsed, "boundary")
  SI CONIURA option_is_none GENUS(VERBUM)(boundary_opt)
    REDDE 2
  FIN SI
  SI CONIURA compare(parsed.mime.canonical, "multipart/form-data") != 0
    REDDE 3
  FIN SI
  SI CONIURA compare(CONIURA option_unwrap GENUS(VERBUM)(boundary_opt), "abc123") != 0
    REDDE 4
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
