INCIPIT grimoire "fase1_1f_access_log_contains_minimum_fields_test"

ADVOCARE "../support/common.cct"
ADVOCARE "cct/fs.cct"
ADVOCARE "cct/http.cct"
ADVOCARE "cct/net.cct"
ADVOCARE "cct/socket.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM ready AD CONIURA tmp_file("fase1_1f_access_log.ready")
  EVOCA VERBUM done AD CONIURA tmp_file("fase1_1f_access_log.done")
  EVOCA VERBUM log AD CONIURA tmp_file("fase1_1f_access_log.log")
  EVOCA VERBUM reqlog AD CONIURA tmp_file("fase1_1f_access_log.requests.log")
  EVOCA VERBUM access_log AD CONIURA tmp_file("fase1_1f_access_log.access.log")
  EVOCA VERBUM stats AD CONIURA tmp_file("fase1_1f_access_log.stats")
  EVOCA SPECULUM NIHIL sock
  EVOCA VERBUM req AD "GET /forwarded HTTP/1.1"
  EVOCA HttpResponse res
  EVOCA VERBUM line AD ""

  CONIURA cleanup_file(ready)
  CONIURA cleanup_file(done)
  CONIURA cleanup_file(log)
  CONIURA cleanup_file(reqlog)
  CONIURA cleanup_file(access_log)
  CONIURA cleanup_file(stats)

  SI CONIURA build_probe_server(log) != 0
    REDDE 1
  FIN SI
  SI CONIURA spawn_to_log(CONIURA probe_command_with_proxy(18125, 1, ready, done, reqlog, access_log, stats, "127.0.0.1", 1, 1, 0), log) != 0
    REDDE 2
  FIN SI
  SI NON CONIURA wait_for_file(ready, 4000)
    REDDE 3
  FIN SI
  SI CONIURA compare(CONIURA read_all(ready), "skip") == 0
    REDDE 0
  FIN SI

  VINCIRE req AD CONIURA concat(req, CONIURA crlf())
  VINCIRE req AD CONIURA concat(req, "Host: app.local")
  VINCIRE req AD CONIURA concat(req, CONIURA crlf())
  VINCIRE req AD CONIURA concat(req, "X-Forwarded-For: 198.51.100.10")
  VINCIRE req AD CONIURA concat(req, CONIURA crlf())
  VINCIRE req AD CONIURA concat(req, "X-Forwarded-Proto: https")
  VINCIRE req AD CONIURA concat(req, CONIURA crlf())
  VINCIRE req AD CONIURA concat(req, CONIURA crlf())

  VINCIRE sock AD CONIURA open_local_socket(18125)
  SI CONIURA send_raw(sock, req) != 0
    REDDE 4
  FIN SI
  VINCIRE res AD CONIURA read_http_response(sock)
  CONIURA net_close(sock)

  SI NON CONIURA wait_for_file(done, 4000)
    REDDE 5
  FIN SI
  SI NON CONIURA exists(access_log)
    REDDE 6
  FIN SI
  VINCIRE line AD CONIURA read_all(access_log)
  SI CONIURA find(line, "request_id=") == -1 VEL CONIURA find(line, "client_ip=198.51.100.10") == -1
    REDDE 7
  FIN SI
  SI CONIURA find(line, "scheme=https") == -1 VEL CONIURA find(line, "method=GET") == -1
    REDDE 8
  FIN SI
  SI CONIURA find(line, "path=/forwarded") == -1 VEL CONIURA find(line, "status=200") == -1
    REDDE 9
  FIN SI
  SI CONIURA find(line, "duration_ms=") == -1 VEL CONIURA find(line, "response_bytes=") == -1
    REDDE 10
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
