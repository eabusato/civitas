INCIPIT grimoire "fase1_1f_support"

ADVOCARE "cct/fluxus.cct"
ADVOCARE "cct/http.cct"
ADVOCARE "cct/verbum.cct"

RITUALE forwarded_field(VERBUM body, REX idx) REDDE VERBUM
  EVOCA SPECULUM NIHIL parts AD CONIURA split(body, "|")
  SI idx < 0 VEL idx >= CONIURA fluxus_len(parts)
    REDDE ""
  FIN SI
  EVOCA SPECULUM VERBUM item_ptr AD CONIURA fluxus_get(parts, idx)
  REDDE *item_ptr
EXPLICIT RITUALE

RITUALE response_request_id(HttpResponse res) REDDE VERBUM
  REDDE CONIURA http_response_header(res, "x-request-id", "")
EXPLICIT RITUALE

EXPLICIT grimoire
