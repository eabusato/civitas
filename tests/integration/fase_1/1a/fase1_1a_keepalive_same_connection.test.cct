INCIPIT grimoire "fase1_1a_keepalive_same_connection_test"

ADVOCARE "../support/common.cct"
ADVOCARE "cct/fs.cct"
ADVOCARE "cct/fluxus.cct"
ADVOCARE "cct/http.cct"
ADVOCARE "cct/net.cct"
ADVOCARE "cct/socket.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM ready AD CONIURA tmp_file("fase1_1a_keepalive.ready")
  EVOCA VERBUM done AD CONIURA tmp_file("fase1_1a_keepalive.done")
  EVOCA VERBUM log AD CONIURA tmp_file("fase1_1a_keepalive.log")
  EVOCA VERBUM reqlog AD CONIURA tmp_file("fase1_1a_keepalive.requests.log")
  EVOCA VERBUM stats AD CONIURA tmp_file("fase1_1a_keepalive.stats")
  EVOCA SPECULUM NIHIL sock
  EVOCA VERBUM req1 AD "GET /meta HTTP/1.1"
  EVOCA VERBUM req2 AD "GET /meta HTTP/1.1"
  EVOCA HttpResponse res1
  EVOCA HttpResponse res2
  EVOCA SPECULUM NIHIL lines
  EVOCA REX non_empty AD 0
  EVOCA REX i AD 0

  CONIURA cleanup_file(ready)
  CONIURA cleanup_file(done)
  CONIURA cleanup_file(log)
  CONIURA cleanup_file(reqlog)
  CONIURA cleanup_file(stats)

  SI CONIURA build_probe_server(log) != 0
    REDDE 1
  FIN SI
  SI CONIURA spawn_to_log(CONIURA probe_command(18104, 2, ready, done, reqlog, stats), log) != 0
    REDDE 2
  FIN SI
  SI NON CONIURA wait_for_file(ready, 4000)
    REDDE 3
  FIN SI
  SI CONIURA compare(CONIURA read_all(ready), "skip") == 0
    REDDE 0
  FIN SI

  VINCIRE req1 AD CONIURA concat(req1, CONIURA crlf())
  VINCIRE req1 AD CONIURA concat(req1, "Host: 127.0.0.1:18104")
  VINCIRE req1 AD CONIURA concat(req1, CONIURA crlf())
  VINCIRE req1 AD CONIURA concat(req1, "Connection: keep-alive")
  VINCIRE req1 AD CONIURA concat(req1, CONIURA crlf())
  VINCIRE req1 AD CONIURA concat(req1, CONIURA crlf())

  VINCIRE req2 AD CONIURA concat(req2, CONIURA crlf())
  VINCIRE req2 AD CONIURA concat(req2, "Host: 127.0.0.1:18104")
  VINCIRE req2 AD CONIURA concat(req2, CONIURA crlf())
  VINCIRE req2 AD CONIURA concat(req2, "Connection: keep-alive")
  VINCIRE req2 AD CONIURA concat(req2, CONIURA crlf())
  VINCIRE req2 AD CONIURA concat(req2, CONIURA crlf())

  VINCIRE sock AD CONIURA open_local_socket(18104)
  SI CONIURA send_raw(sock, req1) != 0
    REDDE 4
  FIN SI
  VINCIRE res1 AD CONIURA read_http_response(sock)
  SI CONIURA send_raw(sock, req2) != 0
    REDDE 5
  FIN SI
  VINCIRE res2 AD CONIURA read_http_response(sock)
  CONIURA net_close(sock)

  SI CONIURA http_response_status(res1) != 200 VEL CONIURA http_response_status(res2) != 200
    REDDE 6
  FIN SI
  SI CONIURA compare(CONIURA http_response_header(res1, "connection", ""), "keep-alive") != 0
    REDDE 7
  FIN SI
  SI NON CONIURA wait_for_file(done, 4000)
    REDDE 8
  FIN SI

  VINCIRE lines AD CONIURA read_lines(reqlog)
  DUM i < CONIURA fluxus_len(lines)
    EVOCA SPECULUM VERBUM line_ptr AD CONIURA fluxus_get(lines, i)
    SI CONIURA len(CONIURA trim(*line_ptr)) != 0
      VINCIRE non_empty AD non_empty + 1
    FIN SI
    VINCIRE i AD i + 1
  FIN DUM
  SI non_empty != 2
    REDDE 9
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
