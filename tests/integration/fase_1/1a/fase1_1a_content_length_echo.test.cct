INCIPIT grimoire "fase1_1a_content_length_echo_test"

ADVOCARE "../support/common.cct"
ADVOCARE "cct/fs.cct"
ADVOCARE "cct/http.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM ready AD CONIURA tmp_file("fase1_1a_cl.ready")
  EVOCA VERBUM done AD CONIURA tmp_file("fase1_1a_cl.done")
  EVOCA VERBUM log AD CONIURA tmp_file("fase1_1a_cl.log")
  EVOCA VERBUM reqlog AD CONIURA tmp_file("fase1_1a_cl.requests.log")
  EVOCA VERBUM stats AD CONIURA tmp_file("fase1_1a_cl.stats")

  CONIURA cleanup_file(ready)
  CONIURA cleanup_file(done)
  CONIURA cleanup_file(log)
  CONIURA cleanup_file(reqlog)
  CONIURA cleanup_file(stats)

  SI CONIURA build_probe_server(log) != 0
    REDDE 1
  FIN SI
  SI CONIURA spawn_to_log(CONIURA probe_command(18102, 1, ready, done, reqlog, stats), log) != 0
    REDDE 2
  FIN SI
  SI NON CONIURA wait_for_file(ready, 4000)
    REDDE 3
  FIN SI
  SI CONIURA compare(CONIURA read_all(ready), "skip") == 0
    REDDE 0
  FIN SI

  EVOCA HttpResponse res AD CONIURA http_post("http://127.0.0.1:18102/echo", "salve-body")
  SI CONIURA http_response_status(res) != 200
    REDDE 4
  FIN SI
  SI CONIURA compare(CONIURA http_response_body(res), "salve-body") != 0
    REDDE 5
  FIN SI
  SI NON CONIURA wait_for_file(done, 4000)
    REDDE 6
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
