INCIPIT grimoire "fase1_1a_graceful_shutdown_signal_test"

ADVOCARE "../support/common.cct"
ADVOCARE "cct/fs.cct"
ADVOCARE "cct/process.cct"
ADVOCARE "cct/time.cct"
ADVOCARE "cct/verbum.cct"

RITUALE wait_for_done_or_exit(VERBUM done, VERBUM probe_alive_cmd, REX timeout_ms) REDDE REX
  EVOCA REX elapsed AD 0
  DUM elapsed < timeout_ms
    SI CONIURA exists(done)
      REDDE 1
    FIN SI
    SI CONIURA run(probe_alive_cmd) != 0
      REDDE 2
    FIN SI
    CONIURA sleep_ms(50)
    VINCIRE elapsed AD elapsed + 50
  FIN DUM
  SI CONIURA exists(done)
    REDDE 1
  FIN SI
  SI CONIURA run(probe_alive_cmd) != 0
    REDDE 2
  FIN SI
  REDDE 0
EXPLICIT RITUALE

RITUALE main() REDDE REX
  EVOCA VERBUM ready AD CONIURA tmp_file("fase1_1a_shutdown.ready")
  EVOCA VERBUM done AD CONIURA tmp_file("fase1_1a_shutdown.done")
  EVOCA VERBUM log AD CONIURA tmp_file("fase1_1a_shutdown.log")
  EVOCA VERBUM reqlog AD CONIURA tmp_file("fase1_1a_shutdown.requests.log")
  EVOCA VERBUM stats AD CONIURA tmp_file("fase1_1a_shutdown.stats")
  EVOCA VERBUM pid_file AD CONIURA tmp_file("fase1_1a_shutdown.pid")
  EVOCA VERBUM kill_cmd AD "kill -TERM "
  EVOCA VERBUM kill_int_cmd AD "kill -INT "
  EVOCA VERBUM kill_force_cmd AD "kill -KILL "
  EVOCA VERBUM probe_alive_cmd AD "kill -0 "
  EVOCA VERBUM cmd AD ""

  CONIURA cleanup_file(ready)
  CONIURA cleanup_file(done)
  CONIURA cleanup_file(log)
  CONIURA cleanup_file(reqlog)
  CONIURA cleanup_file(stats)
  CONIURA cleanup_file(pid_file)

  SI CONIURA build_probe_server(log) != 0
    REDDE 1
  FIN SI
  VINCIRE cmd AD "exec env CIVITAS_REQUIRE_SIGNAL=1 "
  VINCIRE cmd AD CONIURA concat(cmd, CONIURA probe_command(18109, 0, ready, done, reqlog, stats))
  SI CONIURA spawn_to_log_with_pid(cmd, log, pid_file) != 0
    REDDE 2
  FIN SI
  SI NON CONIURA wait_for_file(ready, 10000)
    REDDE 3
  FIN SI
  SI CONIURA compare(CONIURA read_all(ready), "skip") == 0
    REDDE 0
  FIN SI
  SI NON CONIURA wait_for_file(pid_file, 10000)
    REDDE 4
  FIN SI

  VINCIRE kill_cmd AD CONIURA concat(kill_cmd, CONIURA trim(CONIURA read_all(pid_file)))
  VINCIRE kill_int_cmd AD CONIURA concat(kill_int_cmd, CONIURA trim(CONIURA read_all(pid_file)))
  VINCIRE kill_force_cmd AD CONIURA concat(kill_force_cmd, CONIURA trim(CONIURA read_all(pid_file)))
  VINCIRE probe_alive_cmd AD CONIURA concat(probe_alive_cmd, CONIURA trim(CONIURA read_all(pid_file)))
  SI CONIURA run(kill_cmd) != 0
    REDDE 5
  FIN SI
  EVOCA REX shutdown_state AD CONIURA wait_for_done_or_exit(done, probe_alive_cmd, 2000)
  SI shutdown_state == 0
    CONIURA run(kill_int_cmd)
    VINCIRE shutdown_state AD CONIURA wait_for_done_or_exit(done, probe_alive_cmd, 8000)
  FIN SI
  SI shutdown_state == 2
    REDDE 0
  FIN SI
  SI shutdown_state == 0
    CONIURA run(kill_force_cmd)
    SI CONIURA run(probe_alive_cmd) != 0
      REDDE 0
    FIN SI
    REDDE 6
  FIN SI
  SI CONIURA compare(CONIURA read_all(done), "skip") == 0
    REDDE 0
  FIN SI
  SI CONIURA compare(CONIURA read_all(done), "ok") != 0
    REDDE 7
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
