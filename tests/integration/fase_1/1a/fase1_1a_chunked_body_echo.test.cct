INCIPIT grimoire "fase1_1a_chunked_body_echo_test"

ADVOCARE "../support/common.cct"
ADVOCARE "cct/fs.cct"
ADVOCARE "cct/http.cct"
ADVOCARE "cct/net.cct"
ADVOCARE "cct/socket.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM ready AD CONIURA tmp_file("fase1_1a_chunked.ready")
  EVOCA VERBUM done AD CONIURA tmp_file("fase1_1a_chunked.done")
  EVOCA VERBUM log AD CONIURA tmp_file("fase1_1a_chunked.log")
  EVOCA VERBUM reqlog AD CONIURA tmp_file("fase1_1a_chunked.requests.log")
  EVOCA VERBUM stats AD CONIURA tmp_file("fase1_1a_chunked.stats")
  EVOCA SPECULUM NIHIL sock
  EVOCA VERBUM req AD "POST /echo HTTP/1.1"
  EVOCA HttpResponse res

  CONIURA cleanup_file(ready)
  CONIURA cleanup_file(done)
  CONIURA cleanup_file(log)
  CONIURA cleanup_file(reqlog)
  CONIURA cleanup_file(stats)

  SI CONIURA build_probe_server(log) != 0
    REDDE 1
  FIN SI
  SI CONIURA spawn_to_log(CONIURA probe_command(18103, 1, ready, done, reqlog, stats), log) != 0
    REDDE 2
  FIN SI
  SI NON CONIURA wait_for_file(ready, 4000)
    REDDE 3
  FIN SI
  SI CONIURA compare(CONIURA read_all(ready), "skip") == 0
    REDDE 0
  FIN SI

  VINCIRE req AD CONIURA concat(req, CONIURA crlf())
  VINCIRE req AD CONIURA concat(req, "Host: 127.0.0.1:18103")
  VINCIRE req AD CONIURA concat(req, CONIURA crlf())
  VINCIRE req AD CONIURA concat(req, "Transfer-Encoding: chunked")
  VINCIRE req AD CONIURA concat(req, CONIURA crlf())
  VINCIRE req AD CONIURA concat(req, "Connection: close")
  VINCIRE req AD CONIURA concat(req, CONIURA crlf())
  VINCIRE req AD CONIURA concat(req, CONIURA crlf())
  VINCIRE req AD CONIURA concat(req, "5")
  VINCIRE req AD CONIURA concat(req, CONIURA crlf())
  VINCIRE req AD CONIURA concat(req, "salve")
  VINCIRE req AD CONIURA concat(req, CONIURA crlf())
  VINCIRE req AD CONIURA concat(req, "6")
  VINCIRE req AD CONIURA concat(req, CONIURA crlf())
  VINCIRE req AD CONIURA concat(req, "-chunk")
  VINCIRE req AD CONIURA concat(req, CONIURA crlf())
  VINCIRE req AD CONIURA concat(req, "0")
  VINCIRE req AD CONIURA concat(req, CONIURA crlf())
  VINCIRE req AD CONIURA concat(req, CONIURA crlf())

  VINCIRE sock AD CONIURA open_local_socket(18103)
  SI CONIURA send_raw(sock, req) != 0
    REDDE 4
  FIN SI
  VINCIRE res AD CONIURA read_http_response(sock)
  CONIURA net_close(sock)

  SI CONIURA http_response_status(res) != 200
    REDDE 5
  FIN SI
  SI CONIURA compare(CONIURA http_response_body(res), "salve-chunk") != 0
    REDDE 6
  FIN SI
  SI NON CONIURA wait_for_file(done, 4000)
    REDDE 7
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
