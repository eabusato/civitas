INCIPIT grimoire "fase1_1a_invalid_request_line_returns_400_test"

ADVOCARE "../support/common.cct"
ADVOCARE "cct/fs.cct"
ADVOCARE "cct/http.cct"
ADVOCARE "cct/net.cct"
ADVOCARE "cct/socket.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM ready AD CONIURA tmp_file("fase1_1a_badline.ready")
  EVOCA VERBUM done AD CONIURA tmp_file("fase1_1a_badline.done")
  EVOCA VERBUM log AD CONIURA tmp_file("fase1_1a_badline.log")
  EVOCA VERBUM reqlog AD CONIURA tmp_file("fase1_1a_badline.requests.log")
  EVOCA VERBUM stats AD CONIURA tmp_file("fase1_1a_badline.stats")
  EVOCA SPECULUM NIHIL sock
  EVOCA VERBUM req AD "INVALIDREQUEST"
  EVOCA HttpResponse res

  CONIURA cleanup_file(ready)
  CONIURA cleanup_file(done)
  CONIURA cleanup_file(log)
  CONIURA cleanup_file(reqlog)
  CONIURA cleanup_file(stats)

  SI CONIURA build_probe_server(log) != 0
    REDDE 1
  FIN SI
  SI CONIURA spawn_to_log(CONIURA probe_command(18106, 1, ready, done, reqlog, stats), log) != 0
    REDDE 2
  FIN SI
  SI NON CONIURA wait_for_file(ready, 4000)
    REDDE 3
  FIN SI
  SI CONIURA compare(CONIURA read_all(ready), "skip") == 0
    REDDE 0
  FIN SI

  VINCIRE req AD CONIURA concat(req, CONIURA crlf())
  VINCIRE req AD CONIURA concat(req, CONIURA crlf())

  VINCIRE sock AD CONIURA open_local_socket(18106)
  SI CONIURA send_raw(sock, req) != 0
    REDDE 4
  FIN SI
  VINCIRE res AD CONIURA read_http_response(sock)
  CONIURA net_close(sock)

  SI CONIURA http_response_status(res) != 400
    REDDE 5
  FIN SI
  SI NON CONIURA wait_for_file(done, 4000)
    REDDE 6
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
