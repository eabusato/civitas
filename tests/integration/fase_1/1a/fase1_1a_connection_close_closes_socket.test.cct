INCIPIT grimoire "fase1_1a_connection_close_closes_socket_test"

ADVOCARE "../support/common.cct"
ADVOCARE "cct/fs.cct"
ADVOCARE "cct/http.cct"
ADVOCARE "cct/net.cct"
ADVOCARE "cct/socket.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM ready AD CONIURA tmp_file("fase1_1a_close.ready")
  EVOCA VERBUM done AD CONIURA tmp_file("fase1_1a_close.done")
  EVOCA VERBUM log AD CONIURA tmp_file("fase1_1a_close.log")
  EVOCA VERBUM reqlog AD CONIURA tmp_file("fase1_1a_close.requests.log")
  EVOCA VERBUM stats AD CONIURA tmp_file("fase1_1a_close.stats")
  EVOCA SPECULUM NIHIL sock
  EVOCA VERBUM req AD "GET /close HTTP/1.1"
  EVOCA HttpResponse res
  EVOCA VERBUM tail AD ""

  CONIURA cleanup_file(ready)
  CONIURA cleanup_file(done)
  CONIURA cleanup_file(log)
  CONIURA cleanup_file(reqlog)
  CONIURA cleanup_file(stats)

  SI CONIURA build_probe_server(log) != 0
    REDDE 1
  FIN SI
  SI CONIURA spawn_to_log(CONIURA probe_command(18105, 1, ready, done, reqlog, stats), log) != 0
    REDDE 2
  FIN SI
  SI NON CONIURA wait_for_file(ready, 4000)
    REDDE 3
  FIN SI
  SI CONIURA compare(CONIURA read_all(ready), "skip") == 0
    REDDE 0
  FIN SI

  VINCIRE req AD CONIURA concat(req, CONIURA crlf())
  VINCIRE req AD CONIURA concat(req, "Host: 127.0.0.1:18105")
  VINCIRE req AD CONIURA concat(req, CONIURA crlf())
  VINCIRE req AD CONIURA concat(req, "Connection: keep-alive")
  VINCIRE req AD CONIURA concat(req, CONIURA crlf())
  VINCIRE req AD CONIURA concat(req, CONIURA crlf())

  VINCIRE sock AD CONIURA open_local_socket(18105)
  SI CONIURA send_raw(sock, req) != 0
    REDDE 4
  FIN SI
  VINCIRE res AD CONIURA read_http_response(sock)
  VINCIRE tail AD CONIURA sock_recv(sock, 1)
  CONIURA net_close(sock)

  SI CONIURA http_response_status(res) != 200
    REDDE 5
  FIN SI
  SI CONIURA compare(CONIURA http_response_header(res, "connection", ""), "close") != 0
    REDDE 6
  FIN SI
  SI CONIURA len(tail) != 0
    REDDE 7
  FIN SI
  SI NON CONIURA wait_for_file(done, 4000)
    REDDE 8
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
