INCIPIT grimoire "fase1_1a_stats_snapshot_after_requests_test"

ADVOCARE "../support/common.cct"
ADVOCARE "cct/fs.cct"
ADVOCARE "cct/http.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM ready AD CONIURA tmp_file("fase1_1a_stats.ready")
  EVOCA VERBUM done AD CONIURA tmp_file("fase1_1a_stats.done")
  EVOCA VERBUM log AD CONIURA tmp_file("fase1_1a_stats.log")
  EVOCA VERBUM reqlog AD CONIURA tmp_file("fase1_1a_stats.requests.log")
  EVOCA VERBUM stats AD CONIURA tmp_file("fase1_1a_stats.snapshot")

  CONIURA cleanup_file(ready)
  CONIURA cleanup_file(done)
  CONIURA cleanup_file(log)
  CONIURA cleanup_file(reqlog)
  CONIURA cleanup_file(stats)

  SI CONIURA build_probe_server(log) != 0
    REDDE 1
  FIN SI
  SI CONIURA spawn_to_log(CONIURA probe_command(18108, 2, ready, done, reqlog, stats), log) != 0
    REDDE 2
  FIN SI
  SI NON CONIURA wait_for_file(ready, 4000)
    REDDE 3
  FIN SI
  SI CONIURA compare(CONIURA read_all(ready), "skip") == 0
    REDDE 0
  FIN SI

  SI CONIURA http_response_status(CONIURA http_get("http://127.0.0.1:18108/")) != 200
    REDDE 4
  FIN SI
  SI CONIURA http_response_status(CONIURA http_get("http://127.0.0.1:18108/stats")) != 200
    REDDE 5
  FIN SI
  SI NON CONIURA wait_for_file(done, 4000)
    REDDE 6
  FIN SI

  EVOCA VERBUM snapshot AD CONIURA read_all(stats)
  SI NON CONIURA contains(snapshot, "accepted=2")
    REDDE 7
  FIN SI
  SI NON CONIURA contains(snapshot, "handled=2")
    REDDE 8
  FIN SI
  SI NON CONIURA contains(snapshot, "active=0")
    REDDE 9
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
