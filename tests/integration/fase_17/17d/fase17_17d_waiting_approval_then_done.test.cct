INCIPIT grimoire "fase17_17d_waiting_approval_then_done"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/media_jobs/media_jobs.cct"
ADVOCARE "../../../../lib/civitas/tasks/tasks.cct"
ADVOCARE "../../../../lib/civitas/upload_descriptor/upload_descriptor.cct"
ADVOCARE "cct/fs.cct"
ADVOCARE "cct/path.cct"

RITUALE main() REDDE REX
  EVOCA Phase17Stack stack AD CONIURA phase17_stack_open("17d_waiting_approval_then_done")
  EVOCA TaskRegistry registry AD CONIURA phase17_registry_basic()
  EVOCA TaskConfig task_cfg AD CONIURA phase17_task_cfg()
  EVOCA VERBUM source_path AD CONIURA phase17_write_file(stack.root, "uploads/source.txt", "payload")
  EVOCA UploadDescriptor descriptor AD CONIURA phase17_descriptor_from_file(source_path, "text/plain", "source.txt")
  EVOCA VERBUM output_path AD CONIURA path_join(stack.root, "derived/thumb.txt")
  EVOCA MediaJobPolicy policy AD CONIURA media_policy_default()
  VINCIRE policy.require_approval AD VERUM
  EVOCA VERBUM job_id AD CONIURA media_job_enqueue(stack.dbh, descriptor, "post-1", MEDIA_JOB_THUMB, "thumb", output_path, "", policy, task_cfg)
  CONIURA task_worker_run_once(stack.dbh, task_cfg, registry, "media-worker")
  EVOCA MediaJobRecord job_before AD CONIURA media_job_find(stack.dbh, job_id)
  SI job_before.state != MEDIA_JOB_WAITING_APPROVAL
    CONIURA task_registry_free(SPECULUM registry)
    CONIURA phase17_stack_close(stack)
    REDDE 1
  FIN SI
  CONIURA media_job_mark_approved(stack.dbh, job_id, task_cfg)
  CONIURA task_worker_run_once(stack.dbh, task_cfg, registry, "media-worker")
  EVOCA MediaJobRecord job_after AD CONIURA media_job_find(stack.dbh, job_id)
  SI job_after.state != MEDIA_JOB_DONE VEL NON CONIURA exists(output_path)
    CONIURA task_registry_free(SPECULUM registry)
    CONIURA phase17_stack_close(stack)
    REDDE 2
  FIN SI
  CONIURA task_registry_free(SPECULUM registry)
  CONIURA phase17_stack_close(stack)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
