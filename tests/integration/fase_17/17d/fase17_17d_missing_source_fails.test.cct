INCIPIT grimoire "fase17_17d_missing_source_fails"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/media_jobs/media_jobs.cct"
ADVOCARE "../../../../lib/civitas/tasks/tasks.cct"
ADVOCARE "../../../../lib/civitas/upload_descriptor/upload_descriptor.cct"
ADVOCARE "cct/db_sqlite.cct"
ADVOCARE "cct/path.cct"

RITUALE main() REDDE REX
  EVOCA Phase17Stack stack AD CONIURA phase17_stack_open("17d_missing_source_fails")
  EVOCA TaskRegistry registry AD CONIURA phase17_registry_basic()
  EVOCA TaskConfig task_cfg AD CONIURA phase17_task_cfg()
  EVOCA UploadDescriptor descriptor AD CONIURA upload_descriptor_new(CONIURA path_join(stack.root, "uploads/missing.txt"), "missing-hash", 0, "text/plain", "missing.txt")
  EVOCA VERBUM output_path AD CONIURA path_join(stack.root, "derived/out.txt")
  EVOCA VERBUM job_id AD CONIURA media_job_enqueue(stack.dbh, descriptor, "post-1", MEDIA_JOB_THUMB, "thumb", output_path, "", CONIURA media_policy_default(), task_cfg)
  EVOCA TaskWorkerRun run AD CONIURA task_worker_run_once(stack.dbh, task_cfg, registry, "media-worker")
  EVOCA MediaJobRecord job AD CONIURA media_job_find(stack.dbh, job_id)
  SI run.state_after != TASK_DEAD
    CONIURA task_registry_free(SPECULUM registry)
    CONIURA phase17_stack_close(stack)
    REDDE 1
  FIN SI
  SI job.state != MEDIA_JOB_FAILED
    CONIURA task_registry_free(SPECULUM registry)
    CONIURA phase17_stack_close(stack)
    REDDE 2
  FIN SI
  SI CONIURA db_scalar_int(stack.db, "SELECT COUNT(*) FROM task_dead_letters") != 1
    CONIURA task_registry_free(SPECULUM registry)
    CONIURA phase17_stack_close(stack)
    REDDE 3
  FIN SI
  CONIURA task_registry_free(SPECULUM registry)
  CONIURA phase17_stack_close(stack)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
