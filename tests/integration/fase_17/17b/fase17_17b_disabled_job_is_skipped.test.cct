INCIPIT grimoire "fase17_17b_disabled_job_is_skipped"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/scheduled/scheduled.cct"
ADVOCARE "../../../../lib/civitas/tasks/tasks.cct"
ADVOCARE "cct/db_sqlite.cct"
ADVOCARE "cct/date.cct"

RITUALE main() REDDE REX
  EVOCA Phase17Stack stack AD CONIURA phase17_stack_open("17b_disabled_job_is_skipped")
  EVOCA TaskConfig task_cfg AD CONIURA phase17_task_cfg()
  EVOCA SchedulerConfig sched_cfg AD CONIURA phase17_scheduler_cfg()
  CONIURA scheduled_register_interval(stack.dbh, "job.disabled", "echo", "@every 5s", "{\"kind\":\"skip\"}")
  CONIURA scheduled_disable(stack.dbh, "job.disabled")
  CONIURA db_exec(stack.db, "UPDATE scheduled_jobs SET next_run_at_unix = 0 WHERE job_name = 'job.disabled'")
  SI CONIURA scheduler_tick(stack.dbh, task_cfg, sched_cfg, CONIURA datetime_now()) != 0
    CONIURA phase17_stack_close(stack)
    REDDE 1
  FIN SI
  SI CONIURA task_count_by_state(stack.dbh, "queued") != 0
    CONIURA phase17_stack_close(stack)
    REDDE 2
  FIN SI
  CONIURA phase17_stack_close(stack)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
