INCIPIT grimoire "fase17_17a_enqueue_and_count"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/tasks/tasks.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA Phase17Stack stack AD CONIURA phase17_stack_open("17a_enqueue_and_count")
  EVOCA TaskConfig cfg AD CONIURA phase17_task_cfg()
  EVOCA TaskEnqueueOptions options AD CONIURA task_enqueue_options_default()
  EVOCA VERBUM task_id AD CONIURA task_enqueue_json(stack.dbh, cfg.queue_name, "echo", "{\"hello\":\"world\"}", options, cfg)
  SI CONIURA len(task_id) == 0
    CONIURA phase17_stack_close(stack)
    REDDE 1
  FIN SI
  SI CONIURA task_count_by_state(stack.dbh, "queued") != 1
    CONIURA phase17_stack_close(stack)
    REDDE 2
  FIN SI
  CONIURA phase17_stack_close(stack)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
