INCIPIT grimoire "fase17_17a_retry_then_done"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/tasks/tasks.cct"
ADVOCARE "cct/db_sqlite.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA Phase17Stack stack AD CONIURA phase17_stack_open("17a_retry_then_done")
  EVOCA TaskConfig cfg AD CONIURA phase17_task_cfg()
  EVOCA TaskRegistry registry AD CONIURA phase17_registry_basic()
  EVOCA TaskEnqueueOptions options AD CONIURA task_enqueue_options_default()
  EVOCA VERBUM task_id AD CONIURA task_enqueue_json(stack.dbh, cfg.queue_name, "retry_once", "{\"work\":1}", options, cfg)
  EVOCA TaskWorkerRun run1 AD CONIURA task_worker_run_once(stack.dbh, cfg, registry, "worker-a")
  SI run1.state_after != TASK_RETRY
    CONIURA task_registry_free(SPECULUM registry)
    CONIURA phase17_stack_close(stack)
    REDDE 1
  FIN SI
  CONIURA db_exec(stack.db, CONIURA concat("UPDATE task_queue SET run_after_unix = 0, visible_at_unix = 0 WHERE id = '", CONIURA concat(task_id, "'")))
  EVOCA TaskWorkerRun run2 AD CONIURA task_worker_run_once(stack.dbh, cfg, registry, "worker-a")
  SI run2.state_after != TASK_DONE
    CONIURA task_registry_free(SPECULUM registry)
    CONIURA phase17_stack_close(stack)
    REDDE 2
  FIN SI
  EVOCA TaskLookup lookup AD CONIURA task_find_by_id(stack.dbh, task_id)
  SI NON lookup.found VEL lookup.task.attempts != 2
    CONIURA task_registry_free(SPECULUM registry)
    CONIURA phase17_stack_close(stack)
    REDDE 3
  FIN SI
  CONIURA task_registry_free(SPECULUM registry)
  CONIURA phase17_stack_close(stack)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
