INCIPIT grimoire "fase17_17c_purge_dead_letters"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/retention/retention.cct"
ADVOCARE "cct/db_sqlite.cct"

RITUALE main() REDDE REX
  EVOCA Phase17Stack stack AD CONIURA phase17_stack_open("17c_purge_dead_letters")
  EVOCA RetentionConfig cfg AD CONIURA retention_config_default()
  CONIURA db_exec(stack.db, "INSERT INTO task_dead_letters (task_id, queue_name, task_name, payload_json, failed_at_unix, reason_code, reason_json) VALUES ('dead-1', 'default', 'echo', '{}', 1, 'boom', '{}')")
  EVOCA RetentionReport report AD CONIURA retention_purge_dead_letters(stack.dbh, cfg, cfg.dead_letter_max_age_seconds + 100)
  SI report.deleted_count != 1
    CONIURA phase17_stack_close(stack)
    REDDE 1
  FIN SI
  SI CONIURA db_scalar_int(stack.db, "SELECT COUNT(*) FROM task_dead_letters") != 0
    CONIURA phase17_stack_close(stack)
    REDDE 2
  FIN SI
  CONIURA phase17_stack_close(stack)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
