INCIPIT grimoire "fase17_17c_purge_media_jobs"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/retention/retention.cct"
ADVOCARE "cct/db_sqlite.cct"

RITUALE main() REDDE REX
  EVOCA Phase17Stack stack AD CONIURA phase17_stack_open("17c_purge_media_jobs")
  EVOCA RetentionConfig cfg AD CONIURA retention_config_default()
  CONIURA db_exec(stack.db, "INSERT INTO media_jobs (id, object_id, descriptor_json, source_path, fallback_path, job_kind, state, input_hash, output_variant, output_path, attempts, max_attempts, timeout_ms, require_approval, approved, allow_fallback, last_error_json, result_json, created_at_unix, updated_at_unix) VALUES ('mj-1', 'obj', '{}', '/tmp/a', '', 'thumb', 'done', 'hash', 'thumb', '/tmp/b', 1, 3, 1000, 0, 0, 0, '', '', 1, 2)")
  EVOCA RetentionReport report AD CONIURA retention_purge_media_jobs(stack.dbh, cfg, cfg.media_job_max_age_seconds + 100)
  SI report.deleted_count != 1
    CONIURA phase17_stack_close(stack)
    REDDE 1
  FIN SI
  SI CONIURA db_scalar_int(stack.db, "SELECT COUNT(*) FROM media_jobs") != 0
    CONIURA phase17_stack_close(stack)
    REDDE 2
  FIN SI
  CONIURA phase17_stack_close(stack)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
