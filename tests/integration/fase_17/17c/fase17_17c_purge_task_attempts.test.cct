INCIPIT grimoire "fase17_17c_purge_task_attempts"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/retention/retention.cct"
ADVOCARE "cct/db_sqlite.cct"

RITUALE main() REDDE REX
  EVOCA Phase17Stack stack AD CONIURA phase17_stack_open("17c_purge_task_attempts")
  EVOCA RetentionConfig cfg AD CONIURA retention_config_default()
  CONIURA db_exec(stack.db, "INSERT INTO task_attempts (id, task_id, attempt_no, worker_name, started_at_unix, finished_at_unix, outcome, error_json, result_json) VALUES ('att-1', 'task-1', 1, 'w', 1, 2, 'ok', '', '')")
  EVOCA RetentionReport report AD CONIURA retention_purge_task_attempts(stack.dbh, cfg, cfg.task_attempt_max_age_seconds + 100)
  SI report.deleted_count != 1
    CONIURA phase17_stack_close(stack)
    REDDE 1
  FIN SI
  SI CONIURA db_scalar_int(stack.db, "SELECT COUNT(*) FROM task_attempts") != 0
    CONIURA phase17_stack_close(stack)
    REDDE 2
  FIN SI
  CONIURA phase17_stack_close(stack)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
