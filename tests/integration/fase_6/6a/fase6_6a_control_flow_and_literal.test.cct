INCIPIT grimoire "fase6_6a_control_flow_and_literal_test"

ADVOCARE "../support/common.cct"
ADVOCARE "cct/fs.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM root AD CONIURA phase6_tmp_dir("6a_control_flow_and_literal")
  EVOCA VERBUM generated AD ""
  EVOCA VERBUM html AD ""

  CONIURA phase6_init_project(root)
  CONIURA phase6_write_template(
    root,
    "flow.html",
    "{% EVOCA BlogPageContext %}\n{% SI NON is_admin %}guest{% ALITER %}admin{% FIN SI %}\n{% DUM post IN posts %}[{{ loop.count }}:{{ post.titulo }}]{% FIN DUM %}\n{% LITERAL \"{{\" %}\n"
  )

  VINCIRE generated AD CONIURA phase6_compile_file_ok(root, "flow.html")
  VINCIRE html AD CONIURA phase6_render_blog_template(root, "gen/flow.cct", "flow", "")

  SI CONIURA find(html, "guest") == -1
    REDDE 1
  FIN SI
  SI CONIURA find(html, "[1:Primeiro &lt;Post&gt;]") == -1
    REDDE 2
  FIN SI
  SI CONIURA find(html, "{{") == -1
    REDDE 3
  FIN SI
  SI NON CONIURA is_file(generated)
    REDDE 4
  FIN SI

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
