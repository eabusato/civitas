INCIPIT grimoire "fase6_6d_pagination_first_page_test"

ADVOCARE "../../../../lib/civitas/template_extras/pagination.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA PaginationConfig cfg AD CONIURA pagination_config_default("/posts", 1, 3)
  EVOCA VERBUM html AD CONIURA pagination_html(cfg)

  SI CONIURA find(html, "pagination-prev") != -1
    REDDE 1
  FIN SI
  SI CONIURA find(html, "pagination-next") == -1
    REDDE 2
  FIN SI
  SI CONIURA find(html, "aria-current=\"page\"") == -1
    REDDE 3
  FIN SI
  SI CONIURA find(html, "/posts?page=2") == -1
    REDDE 4
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
