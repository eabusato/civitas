INCIPIT grimoire "fase6_6d_qs_remove_and_merge_test"

ADVOCARE "../../../../lib/civitas/template_extras/qs.cct"
ADVOCARE "cct/map.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL params AD CONIURA map_init GENUS(VERBUM, VERBUM)()
  EVOCA VERBUM url AD CONIURA qs_remove("/posts?categoria=tech&page=3#secao", "page")
  EVOCA VERBUM merged AD ""

  CONIURA map_insert GENUS(VERBUM, VERBUM)(params, "sort", "recentes")
  CONIURA map_insert GENUS(VERBUM, VERBUM)(params, "locale", "pt-BR")
  VINCIRE merged AD CONIURA qs_merge(url, params)

  SI CONIURA find(merged, "page=") != -1
    REDDE 1
  FIN SI
  SI CONIURA find(merged, "categoria=tech") == -1
    REDDE 2
  FIN SI
  SI CONIURA find(merged, "sort=recentes") == -1
    REDDE 3
  FIN SI
  SI CONIURA find(merged, "locale=pt-BR") == -1
    REDDE 4
  FIN SI
  SI CONIURA find(merged, "#secao") == -1
    REDDE 5
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
