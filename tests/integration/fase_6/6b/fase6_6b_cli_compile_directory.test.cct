INCIPIT grimoire "fase6_6b_cli_compile_directory_test"

ADVOCARE "../support/common.cct"
ADVOCARE "cct/fs.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM root AD CONIURA phase6_tmp_dir("6b_cli_compile_directory")
  EVOCA VERBUM cmd AD ""

  CONIURA phase6_init_project(root)
  CONIURA phase6_build_template_compiler_or_fail()
  CONIURA phase6_write_template(root, "one.html", "{% EVOCA BlogPageContext %}\n<p>1</p>\n")
  CONIURA phase6_write_template(root, "partials/two.html", "{% EVOCA PostCardContext %}\n<p>{{ titulo }}</p>\n")

  VINCIRE cmd AD CONIURA concat("bin/cct-template-compile --dir ", CONIURA phase6_project_templates_dir(root))
  VINCIRE cmd AD CONIURA concat(cmd, " --out-dir ")
  VINCIRE cmd AD CONIURA concat(cmd, CONIURA phase6_project_gen_dir(root))

  SI CONIURA phase6_run(cmd) != 0
    REDDE 1
  FIN SI
  SI NON CONIURA is_file(CONIURA phase6_generated_path(root, "one.html"))
    REDDE 2
  FIN SI
  SI NON CONIURA is_file(CONIURA phase6_generated_path(root, "partials/two.html"))
    REDDE 3
  FIN SI

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
