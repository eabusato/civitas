INCIPIT grimoire "fase6_6b_cli_help_and_usage_test"

ADVOCARE "../support/common.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM help_out AD ""

  CONIURA phase6_build_template_compiler_or_fail()
  VINCIRE help_out AD CONIURA phase6_run_capture("bin/cct-template-compile --help")

  SI CONIURA find(help_out, "--template <path.html>") == -1
    REDDE 1
  FIN SI
  SI CONIURA find(help_out, "--dir <templates-dir>") == -1
    REDDE 2
  FIN SI
  SI CONIURA phase6_run("bin/cct-template-compile") == 0
    REDDE 3
  FIN SI

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
