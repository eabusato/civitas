INCIPIT grimoire "fase6_6b_generated_module_runs_test"

ADVOCARE "../support/common.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM root AD CONIURA phase6_tmp_dir("6b_generated_module_runs")
  EVOCA VERBUM html AD ""

  CONIURA phase6_init_project(root)
  CONIURA phase6_write_template(
    root,
    "renderable.html",
    "{% EVOCA BlogPageContext %}\n<h1>{{ page_title }}</h1><p>{{ nome|lower }}</p>\n"
  )
  CONIURA phase6_compile_file_ok(root, "renderable.html")
  VINCIRE html AD CONIURA phase6_render_blog_template(root, "gen/renderable.cct", "renderable", "")

  SI CONIURA find(html, "<h1>Painel &lt;Admin&gt;</h1><p>ada &lt;lovelace&gt;</p>") == -1
    REDDE 1
  FIN SI

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
