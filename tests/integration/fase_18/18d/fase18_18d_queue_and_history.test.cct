INCIPIT grimoire "fase18_18d_queue_and_history"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/admin_moderation/admin_moderation.cct"
ADVOCARE "../../../../lib/civitas/admin_moderation/admin_moderation_schema.cct"
ADVOCARE "../../../../lib/civitas/admin_moderation/admin_moderation_queue.cct"
ADVOCARE "../../../../lib/civitas/admin_moderation/admin_moderation_decide.cct"
ADVOCARE "../../../../lib/civitas/db_handle/db_handle.cct"
ADVOCARE "../../../../lib/civitas/tasks/tasks.cct"
ADVOCARE "cct/date.cct"
ADVOCARE "cct/verbum.cct"

RITUALE test_queue_and_history() REDDE NIHIL
  EVOCA Phase18Stack stack AD CONIURA phase18_stack_open("18d_queue_history")
  EVOCA TaskConfig task_cfg AD CONIURA task_config_default()
  CONIURA moderation_schema_up(stack.dbh)
  CONIURA tasks_schema_up(stack.dbh)
  EVOCA ModerationItem item
  VINCIRE item.id AD "mod-1"
  VINCIRE item.kind AD MODERATION_COMMENT
  VINCIRE item.state AD MOD_PENDING
  VINCIRE item.object_id AD "comment-1"
  VINCIRE item.object_type AD "comment"
  VINCIRE item.submitter_id AD "user-1"
  VINCIRE item.content_preview_json AD "{\"body\":\"hello\"}"
  VINCIRE item.report_reason AD ""
  VINCIRE item.assigned_to AD ""
  VINCIRE item.priority AD 10
  VINCIRE item.created_at_unix AD CONIURA datetime_to_unix(CONIURA datetime_now())
  VINCIRE item.updated_at_unix AD item.created_at_unix
  CONIURA moderation_item_create(stack.dbh, item)
  EVOCA VERBUM queue_json AD CONIURA moderation_queue_list(stack.dbh, MODERATION_COMMENT, MOD_PENDING)
  SI CONIURA find(queue_json, "\"id\":\"mod-1\"") == -1
    IACE "moderation queue missing item"
  FIN SI
  SI CONIURA compare(CONIURA moderation_decide(stack.dbh, "mod-1", "hide", "spam", "mod-a", FALSUM, task_cfg), "hidden") != 0
    IACE "moderation decide state mismatch"
  FIN SI
  EVOCA VERBUM history_json AD CONIURA moderation_history_json(stack.dbh, "mod-1")
  SI CONIURA find(history_json, "\"action\":\"hide\"") == -1
    IACE "moderation history missing action"
  FIN SI
  CONIURA phase18_stack_close(stack)
  REDDE
EXPLICIT RITUALE

RITUALE principalis() REDDE NIHIL
  CONIURA test_queue_and_history()
  REDDE
EXPLICIT RITUALE

EXPLICIT grimoire
