INCIPIT grimoire "fase18_common"

ADVOCARE "../../../../lib/civitas/admin/admin.cct"
ADVOCARE "../../../../lib/civitas/admin/admin_audit.cct"
ADVOCARE "../../../../lib/civitas/admin/admin_auth.cct"
ADVOCARE "../../../../lib/civitas/admin/admin_bulk.cct"
ADVOCARE "../../../../lib/civitas/admin/admin_crud.cct"
ADVOCARE "../../../../lib/civitas/admin/admin_inline.cct"
ADVOCARE "../../../../lib/civitas/admin/admin_inline_query.cct"
ADVOCARE "../../../../lib/civitas/admin/admin_inline_routes.cct"
ADVOCARE "../../../../lib/civitas/admin/admin_inline_save.cct"
ADVOCARE "../../../../lib/civitas/admin/admin_inline_schema.cct"
ADVOCARE "../../../../lib/civitas/admin/admin_inline_submit.cct"
ADVOCARE "../../../../lib/civitas/admin/admin_list.cct"
ADVOCARE "../../../../lib/civitas/admin/admin_registry.cct"
ADVOCARE "../../../../lib/civitas/admin/admin_router.cct"
ADVOCARE "../../../../lib/civitas/admin/admin_schema.cct"
ADVOCARE "../../../../lib/civitas/db_handle/db_handle.cct"
ADVOCARE "../../../../lib/civitas/db_handle/db_handle_sqlite.cct"
ADVOCARE "../../../../lib/civitas/model/model.cct"
ADVOCARE "../../../../lib/civitas/permissions/permissions_assign.cct"
ADVOCARE "../../../../lib/civitas/permissions/permissions_db.cct"
ADVOCARE "../../../../lib/civitas/permissions/permissions_schema.cct"
ADVOCARE "../../../../lib/civitas/router.cct"
ADVOCARE "cct/db_sqlite.cct"
ADVOCARE "cct/fs.cct"
ADVOCARE "cct/fluxus.cct"
ADVOCARE "cct/json.cct"
ADVOCARE "cct/path.cct"
ADVOCARE "cct/verbum.cct"

SIGILLUM Phase18Stack
  root: VERBUM
  db: SPECULUM NIHIL
  dbh: DbHandle
  registry: SPECULUM NIHIL
FIN SIGILLUM

RITUALE phase18_root(VERBUM test_name) REDDE VERBUM
  REDDE CONIURA path_join("tests/tmp/fase_18", test_name)
EXPLICIT RITUALE

RITUALE phase18_delete_tree(VERBUM path) REDDE NIHIL
  SI NON CONIURA exists(path)
    REDDE
  FIN SI
  SI CONIURA is_file(path)
    CONIURA delete_file(path)
    REDDE
  FIN SI
  EVOCA SPECULUM NIHIL entries AD CONIURA list_dir(path)
  EVOCA REX i AD 0
  EVOCA REX n AD CONIURA fluxus_len(entries)
  DUM i < n
    EVOCA SPECULUM VERBUM name_ptr AD CONIURA fluxus_get(entries, i)
    CONIURA phase18_delete_tree(CONIURA path_join(path, *name_ptr))
    VINCIRE i AD i + 1
  FIN DUM
  CONIURA fluxus_free(entries)
  CONIURA delete_dir(path)
  REDDE
EXPLICIT RITUALE

RITUALE phase18_reset_root(VERBUM test_name) REDDE VERBUM
  EVOCA VERBUM root AD CONIURA phase18_root(test_name)
  SI CONIURA exists(root)
    CONIURA phase18_delete_tree(root)
  FIN SI
  CONIURA mkdir_all(root)
  REDDE root
EXPLICIT RITUALE

RITUALE phase18_db_path(VERBUM test_name) REDDE VERBUM
  REDDE CONIURA path_join(CONIURA phase18_root(test_name), "phase18.db")
EXPLICIT RITUALE

RITUALE phase18_stack_open(VERBUM test_name) REDDE Phase18Stack
  EVOCA Phase18Stack out
  VINCIRE out.root AD CONIURA phase18_reset_root(test_name)
  VINCIRE out.db AD CONIURA db_open(CONIURA phase18_db_path(test_name))
  EVOCA DbHandle sqlite_dbh AD CONIURA dbh_from_sqlite(out.db)
  CONIURA dbh_fill(SPECULUM out.dbh, sqlite_dbh)
  EVOCA SPECULUM AdminRegistry registry_ptr AD OBSECRO mem_alloc(MENSURA(AdminRegistry))
  CONIURA admin_registry_fill(registry_ptr)
  VINCIRE out.registry AD registry_ptr
  CONIURA permissions_schema_up(out.db)
  CONIURA admin_schema_up(out.dbh)
  REDDE out
EXPLICIT RITUALE

RITUALE phase18_stack_close(Phase18Stack stack) REDDE NIHIL
  EVOCA SPECULUM DbHandle dbh_ptr AD SPECULUM stack.dbh
  CONIURA dbh_close(dbh_ptr)
  REDDE
EXPLICIT RITUALE

RITUALE phase18_post_model_fill(SPECULUM ModelDef def) REDDE NIHIL
  VINCIRE (*def).tabela AD "posts"
  VINCIRE (*def).campos AD CONIURA fluxus_init(MENSURA(FieldDef))
  VINCIRE (*def).indices AD CONIURA fluxus_init(MENSURA(IndexDef))
  VINCIRE (*def).hook_before_save AD ""
  VINCIRE (*def).hook_after_save AD ""
  VINCIRE (*def).hook_before_delete AD ""
  VINCIRE (*def).hook_after_delete AD ""
  VINCIRE (*def).storage_policy AD ""
  CONIURA model_def_add_int(*def, "id", VERUM, VERUM, VERUM)
  CONIURA model_def_add_text(*def, "title", VERUM, FALSUM)
  CONIURA model_def_add_text(*def, "state", VERUM, FALSUM)
  CONIURA model_def_add_text(*def, "author_id", VERUM, FALSUM)
  CONIURA model_def_add_datetime(*def, "created_at", VERUM, FALSUM)
  REDDE
EXPLICIT RITUALE

RITUALE phase18_comment_model_fill(SPECULUM ModelDef def) REDDE NIHIL
  VINCIRE (*def).tabela AD "comments"
  VINCIRE (*def).campos AD CONIURA fluxus_init(MENSURA(FieldDef))
  VINCIRE (*def).indices AD CONIURA fluxus_init(MENSURA(IndexDef))
  VINCIRE (*def).hook_before_save AD ""
  VINCIRE (*def).hook_after_save AD ""
  VINCIRE (*def).hook_before_delete AD ""
  VINCIRE (*def).hook_after_delete AD ""
  VINCIRE (*def).storage_policy AD ""
  CONIURA model_def_add_int(*def, "id", VERUM, VERUM, VERUM)
  CONIURA model_def_add_fk(*def, "post_id", "posts", "id", VERUM)
  CONIURA model_def_add_text(*def, "body", VERUM, FALSUM)
  CONIURA model_def_add_text(*def, "state", VERUM, FALSUM)
  REDDE
EXPLICIT RITUALE

RITUALE phase18_create_post_tables(DbHandle dbh) REDDE NIHIL
  EVOCA DbParams params AD CONIURA dbh_params_new()
  CONIURA dbh_exec(dbh, "CREATE TABLE IF NOT EXISTS posts (id INTEGER PRIMARY KEY AUTOINCREMENT, title TEXT NOT NULL, state TEXT NOT NULL, author_id TEXT NOT NULL, created_at INTEGER NOT NULL)", params)
  CONIURA dbh_exec(dbh, "CREATE TABLE IF NOT EXISTS comments (id INTEGER PRIMARY KEY AUTOINCREMENT, post_id INTEGER NOT NULL, body TEXT NOT NULL, state TEXT NOT NULL)", params)
  CONIURA dbh_params_free(SPECULUM params)
  REDDE
EXPLICIT RITUALE

RITUALE phase18_register_post_admin(SPECULUM Phase18Stack stack) REDDE SPECULUM NIHIL
  CONIURA phase18_create_post_tables((*stack).dbh)
  EVOCA ModelDef model
  EVOCA AdminModelConfig cfg
  CONIURA phase18_post_model_fill(SPECULUM model)
  CONIURA admin_model_config_fill(SPECULUM cfg, "Post", model)
  CONIURA admin_model_config_set_permissions_prefix(SPECULUM cfg, "admin.posts")
  CONIURA admin_model_config_set_ordering(SPECULUM cfg, "created_at")
  CONIURA admin_model_config_set_page_size(SPECULUM cfg, 2)
  CONIURA admin_register((*stack).registry, (*stack).dbh, cfg)
  REDDE CONIURA admin_registry_find((*stack).registry, "Post")
EXPLICIT RITUALE

RITUALE phase18_comment_admin_config() REDDE AdminModelConfig
  EVOCA ModelDef model
  EVOCA AdminModelConfig cfg
  CONIURA phase18_comment_model_fill(SPECULUM model)
  CONIURA admin_model_config_fill(SPECULUM cfg, "Comment", model)
  CONIURA admin_model_config_set_permissions_prefix(SPECULUM cfg, "admin.comments")
  CONIURA admin_model_config_set_ordering(SPECULUM cfg, "id")
  CONIURA admin_model_config_set_page_size(SPECULUM cfg, 10)
  REDDE cfg
EXPLICIT RITUALE

RITUALE phase18_comment_inline_config() REDDE AdminInlineConfig
  EVOCA AdminModelConfig comment_cfg AD CONIURA phase18_comment_admin_config()
  REDDE CONIURA admin_inline_config_default("comments", "Post", comment_cfg, "post_id")
EXPLICIT RITUALE

RITUALE phase18_register_comment_inline(SPECULUM Phase18Stack stack) REDDE AdminInlineConfig
  EVOCA AdminInlineConfig inline_cfg AD CONIURA phase18_comment_inline_config()
  CONIURA admin_inline_schema_up((*stack).dbh)
  CONIURA admin_inline_register((*stack).dbh, inline_cfg)
  REDDE inline_cfg
EXPLICIT RITUALE

RITUALE phase18_insert_post(SPECULUM NIHIL db, VERBUM title, VERBUM state, VERBUM author_id, REX created_at) REDDE NIHIL
  EVOCA SPECULUM NIHIL stmt AD CONIURA db_prepare(db, "INSERT INTO posts (title, state, author_id, created_at) VALUES (?, ?, ?, ?)")
  CONIURA stmt_bind_text(stmt, 1, title)
  CONIURA stmt_bind_text(stmt, 2, state)
  CONIURA stmt_bind_text(stmt, 3, author_id)
  CONIURA stmt_bind_int(stmt, 4, created_at)
  CONIURA stmt_step(stmt)
  CONIURA stmt_finalize(stmt)
  REDDE
EXPLICIT RITUALE

RITUALE phase18_insert_comment(SPECULUM NIHIL db, REX post_id, VERBUM body, VERBUM state) REDDE NIHIL
  EVOCA SPECULUM NIHIL stmt AD CONIURA db_prepare(db, "INSERT INTO comments (post_id, body, state) VALUES (?, ?, ?)")
  CONIURA stmt_bind_int(stmt, 1, post_id)
  CONIURA stmt_bind_text(stmt, 2, body)
  CONIURA stmt_bind_text(stmt, 3, state)
  CONIURA stmt_step(stmt)
  CONIURA stmt_finalize(stmt)
  REDDE
EXPLICIT RITUALE

RITUALE phase18_grant_admin_posts(SPECULUM NIHIL db, VERBUM user_id) REDDE NIHIL
  CONIURA perm_registrar(db, "admin.posts.list", "list posts")
  CONIURA perm_registrar(db, "admin.posts.create", "create posts")
  CONIURA perm_registrar(db, "admin.posts.edit", "edit posts")
  CONIURA perm_registrar(db, "admin.posts.delete", "delete posts")
  CONIURA perm_registrar(db, "admin.posts.bulk", "bulk posts")
  CONIURA user_perm_conceder(db, user_id, "admin.posts.*")
  REDDE
EXPLICIT RITUALE

EXPLICIT grimoire
