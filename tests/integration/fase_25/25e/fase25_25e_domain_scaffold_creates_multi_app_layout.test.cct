INCIPIT grimoire "fase25_25e_domain_scaffold_creates_multi_app_layout"

ADVOCARE "support.cct"
ADVOCARE "../../../../lib/civitas/civitas_new/civitas_new.cct"
ADVOCARE "cct/fs.cct"
ADVOCARE "cct/path.cct"
ADVOCARE "cct/result.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM root AD CONIURA phase25e_reset_root("25e_domain_scaffold_creates_multi_app_layout")
  EVOCA CivitasNewConfig cfg AD CONIURA civitas_new_cfg_with_style("cosmos25", TemplateMinimal, StyleDomain, root, FALSUM)
  SI CONIURA result_is_err GENUS(REX, VERBUM)(CONIURA civitas_new_create(cfg))
    REDDE 1
  FIN SI
  SI NON CONIURA exists(CONIURA path_join(root, "cosmos25/apps/public/urls.cct"))
    REDDE 2
  FIN SI
  SI NON CONIURA exists(CONIURA path_join(root, "cosmos25/apps/accounts/views/index.cct"))
    REDDE 3
  FIN SI
  SI NON CONIURA exists(CONIURA path_join(root, "cosmos25/apps/backoffice/tests/test_backoffice.cct"))
    REDDE 4
  FIN SI
  SI NON CONIURA exists(CONIURA path_join(root, "cosmos25/apps/shared/services/index.cct"))
    REDDE 5
  FIN SI
  SI NON CONIURA exists(CONIURA path_join(root, "cosmos25/apps/shared/urls.cct"))
    REDDE 6
  FIN SI
  SI NON CONIURA phase25e_contains(CONIURA path_join(root, "cosmos25/project/urls.cct"), "ADVOCARE \"../apps/public/urls.cct\"")
    REDDE 7
  FIN SI
  SI NON CONIURA phase25e_contains(CONIURA path_join(root, "cosmos25/project/urls.cct"), "CONIURA accounts_urls_register()")
    REDDE 8
  FIN SI
  SI NON CONIURA phase25e_contains(CONIURA path_join(root, "cosmos25/README.md"), "apps/public`, `apps/accounts`, `apps/backoffice`")
    REDDE 9
  FIN SI
  SI CONIURA phase25e_compile_file(CONIURA path_join(root, "cosmos25/project/main.cct")) != 0
    REDDE 10
  FIN SI
  SI CONIURA phase25e_compile_file(CONIURA path_join(root, "cosmos25/project/urls.cct")) != 0
    REDDE 11
  FIN SI
  SI CONIURA phase25e_compile_file(CONIURA path_join(root, "cosmos25/apps/public/urls.cct")) != 0
    REDDE 12
  FIN SI
  SI CONIURA phase25e_compile_file(CONIURA path_join(root, "cosmos25/apps/accounts/urls.cct")) != 0
    REDDE 13
  FIN SI
  SI CONIURA phase25e_compile_file(CONIURA path_join(root, "cosmos25/apps/shared/urls.cct")) != 0
    REDDE 14
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
