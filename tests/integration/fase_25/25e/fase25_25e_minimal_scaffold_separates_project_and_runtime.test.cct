INCIPIT grimoire "fase25_25e_minimal_scaffold_separates_project_and_runtime"

ADVOCARE "support.cct"
ADVOCARE "../../../../lib/civitas/civitas_new/civitas_new.cct"
ADVOCARE "cct/fs.cct"
ADVOCARE "cct/path.cct"
ADVOCARE "cct/result.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM root AD CONIURA phase25e_reset_root("25e_minimal_scaffold_separates_project_and_runtime")
  EVOCA CivitasNewConfig cfg AD CONIURA civitas_new_cfg("quartz", TemplateMinimal, root, FALSUM)
  SI CONIURA result_is_err GENUS(REX, VERBUM)(CONIURA civitas_new_create(cfg))
    REDDE 1
  FIN SI
  SI NON CONIURA exists(CONIURA path_join(root, "quartz/project/main.cct"))
    REDDE 2
  FIN SI
  SI NON CONIURA exists(CONIURA path_join(root, "quartz/apps/core/urls.cct"))
    REDDE 3
  FIN SI
  SI NON CONIURA exists(CONIURA path_join(root, "quartz/settings/base.toml"))
    REDDE 4
  FIN SI
  SI NON CONIURA exists(CONIURA path_join(root, "quartz/data/db"))
    REDDE 5
  FIN SI
  SI NON CONIURA exists(CONIURA path_join(root, "quartz/.civitas/cache"))
    REDDE 6
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
