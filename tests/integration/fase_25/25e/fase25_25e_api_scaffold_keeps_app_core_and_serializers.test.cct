INCIPIT grimoire "fase25_25e_api_scaffold_keeps_app_core_and_serializers"

ADVOCARE "support.cct"
ADVOCARE "../../../../lib/civitas/civitas_new/civitas_new.cct"
ADVOCARE "cct/fs.cct"
ADVOCARE "cct/path.cct"
ADVOCARE "cct/result.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM root AD CONIURA phase25e_reset_root("25e_api_scaffold_keeps_app_core_and_serializers")
  EVOCA CivitasNewConfig cfg AD CONIURA civitas_new_cfg("helios25", TemplateApi, root, FALSUM)
  SI CONIURA result_is_err GENUS(REX, VERBUM)(CONIURA civitas_new_create(cfg))
    REDDE 1
  FIN SI
  SI NON CONIURA exists(CONIURA path_join(root, "helios25/apps/core/serializers/index.cct"))
    REDDE 2
  FIN SI
  SI NON CONIURA phase25e_contains(CONIURA path_join(root, "helios25/civitas.toml"), "models = \"apps/core/models\"")
    REDDE 3
  FIN SI
  SI CONIURA exists(CONIURA path_join(root, "helios25/src"))
    REDDE 4
  FIN SI
  SI CONIURA phase25e_compile_file(CONIURA path_join(root, "helios25/project/main.cct")) != 0
    REDDE 5
  FIN SI
  SI CONIURA phase25e_compile_file(CONIURA path_join(root, "helios25/apps/core/urls.cct")) != 0
    REDDE 6
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
