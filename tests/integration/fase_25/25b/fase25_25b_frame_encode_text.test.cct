INCIPIT grimoire "fase25_25b_frame_encode_text"

ADVOCARE "../../../../lib/civitas/websocket/websocket.cct"
ADVOCARE "cct/encoding.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA WsFrame frame AD CONIURA ws_frame_new(WS_TEXT, "hi", VERUM)
  EVOCA VERBUM raw AD CONIURA ws_frame_encode(frame)
  SI CONIURA len(raw) != 4
    REDDE 1
  FIN SI
  SI CONIURA verbum_byte_value(raw, 0) != 129
    REDDE 1
  FIN SI
  SI CONIURA verbum_byte_value(raw, 1) != 2
    REDDE 1
  FIN SI
  SI CONIURA verbum_byte_value(raw, 2) != 104
    REDDE 1
  FIN SI
  SI CONIURA verbum_byte_value(raw, 3) != 105
    REDDE 1
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
