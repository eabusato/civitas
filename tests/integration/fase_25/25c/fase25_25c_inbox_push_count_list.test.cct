INCIPIT grimoire "fase25_25c_inbox_push_count_list"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/sse_presence/sse_presence.cct"
ADVOCARE "cct/db_sqlite.cct"
ADVOCARE "cct/fluxus.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL db AD CONIURA phase25_db_open("25c_inbox_push_count_list")
  CONIURA sse_presence_schema_up(db)
  CONIURA sse_inbox_push(db, 40, "comment", "{\"id\":1}")
  CONIURA sse_inbox_push(db, 40, "like", "{\"id\":2}")

  SI CONIURA sse_inbox_count_unread(db, 40) != 2
    CONIURA db_close(db)
    REDDE 1
  FIN SI

  EVOCA SPECULUM NIHIL items AD CONIURA sse_inbox_list(db, 40, 10, 0)
  SI CONIURA fluxus_len(items) != 2
    CONIURA db_close(db)
    REDDE 1
  FIN SI

  EVOCA SPECULUM InboxEntry first AD CONIURA fluxus_get(items, 0)
  SI CONIURA compare((*first).tipo, "like") != 0
    CONIURA db_close(db)
    REDDE 1
  FIN SI
  SI CONIURA compare((*first).payload, "{\"id\":2}") != 0
    CONIURA db_close(db)
    REDDE 1
  FIN SI

  CONIURA db_close(db)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
