INCIPIT grimoire "fase25_25a_signal_bridge"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/sse/sse.cct"
ADVOCARE "../../../../lib/civitas/signals.cct"
ADVOCARE "cct/db_sqlite.cct"
ADVOCARE "cct/fluxus.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL db AD CONIURA phase25_db_open("25a_signal_bridge")
  EVOCA SPECULUM SseBus bus AD CONIURA sse_bus_new(db, "signals")
  EVOCA NamedSignalRegistry registry AD CONIURA named_signal_registry_new()

  CONIURA sse_bus_on_signal(SPECULUM registry, bus, "editorial.published", "published")
  CONIURA signal_emit_named_text(SPECULUM registry, "editorial.published", "{\"slug\":\"neon\"}")

  EVOCA SPECULUM NIHIL eventos AD CONIURA sse_bus_poll(bus)
  SI CONIURA fluxus_len(eventos) != 1
    CONIURA db_close(db)
    REDDE 1
  FIN SI

  EVOCA SPECULUM SseEvent ev AD CONIURA fluxus_get(eventos, 0)
  SI CONIURA compare((*ev).evento, "published") != 0
    CONIURA db_close(db)
    REDDE 1
  FIN SI
  SI CONIURA compare((*ev).dados, "{\"slug\":\"neon\"}") != 0
    CONIURA db_close(db)
    REDDE 1
  FIN SI

  CONIURA db_close(db)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
