INCIPIT grimoire "fase25_25a_event_to_string"

ADVOCARE "../../../../lib/civitas/sse/sse.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SseEvent ev AD CONIURA sse_event_new("chat.message", "alpha\nbeta")
  CONIURA sse_event_set_id(SPECULUM ev, "42")
  CONIURA sse_event_set_retry(SPECULUM ev, 3000)
  EVOCA VERBUM raw AD CONIURA sse_event_to_string(ev)

  SI NON CONIURA contains(raw, "retry: 3000\n")
    REDDE 1
  FIN SI
  SI NON CONIURA contains(raw, "id: 42\n")
    REDDE 1
  FIN SI
  SI NON CONIURA contains(raw, "event: chat.message\n")
    REDDE 1
  FIN SI
  SI NON CONIURA contains(raw, "data: alpha\n")
    REDDE 1
  FIN SI
  SI NON CONIURA contains(raw, "data: beta\n")
    REDDE 1
  FIN SI
  SI NON CONIURA ends_with(raw, "\n\n")
    REDDE 1
  FIN SI

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
