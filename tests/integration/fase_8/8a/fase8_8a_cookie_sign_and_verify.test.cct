INCIPIT grimoire "fase8_8a_cookie_sign_and_verify_test"

ADVOCARE "support.cct"
ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/session/session.cct"
ADVOCARE "cct/option.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM id AD CONIURA session_id_new()
  EVOCA VERBUM cookie AD CONIURA session_cookie_sign(id, "segredo-8a")
  EVOCA SPECULUM NIHIL verified AD CONIURA session_cookie_verify(cookie, "segredo-8a")

  SI CONIURA option_is_none GENUS(VERBUM)(verified)
    REDDE 1
  FIN SI
  SI CONIURA compare(CONIURA option_unwrap GENUS(VERBUM)(verified), id) != 0
    REDDE 2
  FIN SI
  CONIURA option_free GENUS(VERBUM)(verified)

  VINCIRE verified AD CONIURA session_cookie_verify(CONIURA concat(cookie, "x"), "segredo-8a")
  SI NON CONIURA option_is_none GENUS(VERBUM)(verified)
    REDDE 3
  FIN SI
  CONIURA option_free GENUS(VERBUM)(verified)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
