INCIPIT grimoire "fase8_8d_json_contains_all_fields_and_numeric_size_test"

ADVOCARE "support.cct"
ADVOCARE "../../../../lib/civitas/upload_descriptor/upload_descriptor.cct"
ADVOCARE "cct/json.cct"
ADVOCARE "cct/verbum.cct"
ADVOCARE "cct/verbum_scan.cct"

RITUALE main() REDDE REX
  EVOCA UploadDescriptor d AD CONIURA upload_descriptor_new("uploads/report.pdf", "hash-z", 512, "application/pdf", "report.pdf")
  EVOCA VERBUM payload AD CONIURA upload_descriptor_to_json(d)
  EVOCA SPECULUM NIHIL c AD CONIURA cursor_init(payload)
  EVOCA Json root AD CONIURA json_parse_value(payload, c)
  CONIURA cursor_free(c)

  SI NON CONIURA json_is_obj(root)
    REDDE 1
  FIN SI
  SI CONIURA json_obj_len(root) != 6
    REDDE 2
  FIN SI
  SI NON CONIURA json_is_str(CONIURA json_get_key(root, "path"))
    REDDE 3
  FIN SI
  SI NON CONIURA json_is_str(CONIURA json_get_key(root, "hash"))
    REDDE 4
  FIN SI
  SI NON CONIURA json_is_num(CONIURA json_get_key(root, "size"))
    REDDE 5
  FIN SI
  SI NON CONIURA json_is_str(CONIURA json_get_key(root, "mime"))
    REDDE 6
  FIN SI
  SI NON CONIURA json_is_str(CONIURA json_get_key(root, "original_name"))
    REDDE 7
  FIN SI
  SI NON CONIURA json_is_str(CONIURA json_get_key(root, "state"))
    REDDE 8
  FIN SI
  SI cast GENUS(REX)(CONIURA json_expect_num(CONIURA json_get_key(root, "size"))) != 512
    REDDE 9
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
