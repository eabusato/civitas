INCIPIT grimoire "fase2_2a_cookie_extraction_test"

ADVOCARE "../../../../lib/civitas/request_http.cct"
ADVOCARE "../../../../lib/civitas/request.cct"
ADVOCARE "cct/http.cct"
ADVOCARE "cct/option.cct"
ADVOCARE "cct/result.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA HttpRequest raw AD CONIURA http_request_new("GET", "/")
  EVOCA SPECULUM NIHIL req_res
  EVOCA SPECULUM NIHIL cookie_opt

  CONIURA http_headers_set_or_push(CONIURA http_request_headers_handle(raw), "Cookie", "sid=abc; theme=amber")
  VINCIRE req_res AD CONIURA request_from_http(raw, "127.0.0.1", "http", "example.test", "req-4")
  SI CONIURA result_is_err GENUS(WebRequest, VERBUM)(req_res)
    REDDE 1
  FIN SI

  VINCIRE cookie_opt AD CONIURA request_cookie(CONIURA result_unwrap GENUS(WebRequest, VERBUM)(req_res), "theme")
  SI CONIURA option_is_none GENUS(VERBUM)(cookie_opt)
    REDDE 2
  FIN SI
  SI CONIURA compare(CONIURA option_unwrap GENUS(VERBUM)(cookie_opt), "amber") != 0
    REDDE 3
  FIN SI

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
