INCIPIT grimoire "fase2_2a_header_case_insensitive_test"

ADVOCARE "../../../../lib/civitas/request_http.cct"
ADVOCARE "../../../../lib/civitas/request.cct"
ADVOCARE "cct/http.cct"
ADVOCARE "cct/map.cct"
ADVOCARE "cct/option.cct"
ADVOCARE "cct/result.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA HttpRequest raw AD CONIURA http_request_new("GET", "/hello")
  EVOCA SPECULUM NIHIL req_res
  EVOCA SPECULUM NIHIL header_opt

  CONIURA http_headers_set_or_push(CONIURA http_request_headers_handle(raw), "X-Trace-Id", "abc123")
  VINCIRE req_res AD CONIURA request_from_http(raw, "127.0.0.1", "http", "example.test", "req-1")
  SI CONIURA result_is_err GENUS(WebRequest, VERBUM)(req_res)
    REDDE 1
  FIN SI

  EVOCA WebRequest req AD CONIURA result_unwrap GENUS(WebRequest, VERBUM)(req_res)
  VINCIRE header_opt AD CONIURA request_header(req, "x-trace-id")
  SI CONIURA option_is_none GENUS(VERBUM)(header_opt)
    REDDE 20 + CONIURA map_len GENUS(VERBUM, VERBUM)(req.headers)
  FIN SI
  SI CONIURA compare(CONIURA option_unwrap GENUS(VERBUM)(header_opt), "abc123") != 0
    REDDE 3
  FIN SI

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
