INCIPIT grimoire "fase2_2a_as_text_and_metadata_test"

ADVOCARE "../../../../lib/civitas/request_server.cct"
ADVOCARE "../../../../lib/civitas/request.cct"
ADVOCARE "../../../../lib/civitas/http/server.cct"
ADVOCARE "cct/result.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA HttpRawRequest raw
  VINCIRE raw.method AD "POST"
  VINCIRE raw.target AD "/echo"
  VINCIRE raw.version AD "HTTP/1.1"
  VINCIRE raw.headers AD CONIURA http_server_headers_new()
  VINCIRE raw.body AD "salve"
  VINCIRE raw.request_id AD "req-6"
  VINCIRE raw.client_ip AD "203.0.113.8"
  VINCIRE raw.scheme AD "https"
  VINCIRE raw.original_host AD "civitas.test"
  VINCIRE raw.proxy_addr AD "10.0.0.1:8080"
  VINCIRE raw.remote_addr AD "10.0.0.1:8080"
  VINCIRE raw.local_addr AD "127.0.0.1:8080"
  VINCIRE raw.keep_alive AD VERUM
  VINCIRE raw.started_ms AD 0

  EVOCA SPECULUM NIHIL req_res AD CONIURA request_from_raw(raw)
  SI CONIURA result_is_err GENUS(WebRequest, VERBUM)(req_res)
    REDDE 1
  FIN SI

  EVOCA WebRequest req AD CONIURA result_unwrap GENUS(WebRequest, VERBUM)(req_res)
  EVOCA SPECULUM NIHIL text_res AD CONIURA request_as_text(req)
  SI CONIURA result_is_err GENUS(VERBUM, VERBUM)(text_res)
    REDDE 2
  FIN SI
  SI CONIURA compare(CONIURA result_unwrap GENUS(VERBUM, VERBUM)(text_res), "salve") != 0
    REDDE 3
  FIN SI
  SI CONIURA compare(req.client_ip, "203.0.113.8") != 0
    REDDE 4
  FIN SI
  SI CONIURA compare(req.request_id, "req-6") != 0
    REDDE 5
  FIN SI
  SI NON CONIURA request_is_secure(req)
    REDDE 6
  FIN SI

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
