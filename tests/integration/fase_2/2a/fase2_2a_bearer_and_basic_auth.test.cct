INCIPIT grimoire "fase2_2a_bearer_and_basic_auth_test"

ADVOCARE "../../../../lib/civitas/request_http.cct"
ADVOCARE "../../../../lib/civitas/request.cct"
ADVOCARE "cct/encoding.cct"
ADVOCARE "cct/http.cct"
ADVOCARE "cct/option.cct"
ADVOCARE "cct/result.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA HttpRequest bearer_raw AD CONIURA http_request_new("GET", "/api")
  CONIURA http_headers_set_or_push(CONIURA http_request_headers_handle(bearer_raw), "Authorization", "Bearer token-123")
  EVOCA SPECULUM NIHIL bearer_req_res AD CONIURA request_from_http(bearer_raw, "127.0.0.1", "http", "example.test", "req-10")
  SI CONIURA result_is_err GENUS(WebRequest, VERBUM)(bearer_req_res)
    REDDE 1
  FIN SI

  EVOCA SPECULUM NIHIL token_opt AD CONIURA request_bearer_token(CONIURA result_unwrap GENUS(WebRequest, VERBUM)(bearer_req_res))
  SI CONIURA option_is_none GENUS(VERBUM)(token_opt)
    REDDE 2
  FIN SI
  SI CONIURA compare(CONIURA option_unwrap GENUS(VERBUM)(token_opt), "token-123") != 0
    REDDE 3
  FIN SI

  EVOCA HttpRequest basic_raw AD CONIURA http_request_new("GET", "/admin")
  EVOCA VERBUM encoded AD CONIURA base64_encode("alfa:bravo")
  CONIURA http_headers_set_or_push(CONIURA http_request_headers_handle(basic_raw), "Authorization", CONIURA concat("Basic ", encoded))
  EVOCA SPECULUM NIHIL basic_req_res AD CONIURA request_from_http(basic_raw, "127.0.0.1", "http", "example.test", "req-11")
  SI CONIURA result_is_err GENUS(WebRequest, VERBUM)(basic_req_res)
    REDDE 4
  FIN SI

  EVOCA SPECULUM NIHIL auth_res AD CONIURA request_basic_auth(CONIURA result_unwrap GENUS(WebRequest, VERBUM)(basic_req_res))
  SI CONIURA result_is_err GENUS(WebRequestBasicAuth, VERBUM)(auth_res)
    REDDE 5
  FIN SI
  EVOCA WebRequestBasicAuth auth AD CONIURA result_unwrap GENUS(WebRequestBasicAuth, VERBUM)(auth_res)
  SI CONIURA compare(auth.username, "alfa") != 0
    REDDE 6
  FIN SI
  SI CONIURA compare(auth.password, "bravo") != 0
    REDDE 7
  FIN SI

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
