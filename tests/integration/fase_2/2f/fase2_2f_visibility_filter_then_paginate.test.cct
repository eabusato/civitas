INCIPIT grimoire "fase2_2f_visibility_filter_then_paginate_test"

ADVOCARE "support.cct"
ADVOCARE "../../../../lib/civitas/pagination.cct"
ADVOCARE "../../../../lib/civitas/visibility.cct"
ADVOCARE "cct/fluxus.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL items AD CONIURA fluxus_init(MENSURA(VisibilityFilterItem))
  EVOCA VisibilityFilterItem a
  EVOCA VisibilityFilterItem b
  EVOCA VisibilityFilterItem c
  EVOCA SPECULUM NIHIL visible
  EVOCA PaginationRequest p AD CONIURA pagination_default(1)
  EVOCA PaginationMeta meta

  VINCIRE a.label AD "a"
  VINCIRE a.policy AD VISIBILITY_PUBLIC
  VINCIRE b.label AD "b"
  VINCIRE b.policy AD VISIBILITY_PRIVATE
  VINCIRE c.label AD "c"
  VINCIRE c.policy AD VISIBILITY_PUBLIC

  CONIURA fluxus_push(items, SPECULUM a)
  CONIURA fluxus_push(items, SPECULUM b)
  CONIURA fluxus_push(items, SPECULUM c)

  VINCIRE visible AD CONIURA visibility_filter_public_only(items)
  SI CONIURA fluxus_len(visible) != 2
    REDDE 1
  FIN SI

  VINCIRE p.page AD 1
  VINCIRE p.page_size AD 1
  VINCIRE p.sort_by AD "created_at"
  VINCIRE p.sort_direction AD SORT_DESC
  VINCIRE meta AD CONIURA pagination_meta(p, CONIURA fluxus_len(visible))

  SI meta.total_items != 2
    REDDE 2
  FIN SI
  SI meta.total_pages != 2
    REDDE 3
  FIN SI
  SI meta.has_next != VERUM
    REDDE 4
  FIN SI

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
