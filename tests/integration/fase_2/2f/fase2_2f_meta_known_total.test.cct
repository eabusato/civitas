INCIPIT grimoire "fase2_2f_meta_known_total_test"

ADVOCARE "../../../../lib/civitas/pagination.cct"

RITUALE main() REDDE REX
  EVOCA PaginationRequest p AD CONIURA pagination_default(10)
  VINCIRE p.page AD 3
  VINCIRE p.page_size AD 10
  VINCIRE p.sort_by AD "created_at"
  VINCIRE p.sort_direction AD SORT_DESC

  EVOCA PaginationMeta meta AD CONIURA pagination_meta(p, 95)

  SI meta.page != 3
    REDDE 1
  FIN SI
  SI meta.total_pages != 10
    REDDE 2
  FIN SI
  SI meta.offset != 20
    REDDE 3
  FIN SI
  SI meta.limit != 10
    REDDE 4
  FIN SI
  SI meta.has_prev != VERUM
    REDDE 5
  FIN SI
  SI meta.has_next != VERUM
    REDDE 6
  FIN SI
  SI meta.total_known != VERUM
    REDDE 7
  FIN SI

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
