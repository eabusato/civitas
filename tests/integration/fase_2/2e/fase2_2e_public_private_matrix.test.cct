INCIPIT grimoire "fase2_2e_public_private_matrix_test"

ADVOCARE "support.cct"
ADVOCARE "../../../../lib/civitas/visibility.cct"

RITUALE main() REDDE REX
  EVOCA VisibilityContext anon_html AD CONIURA phase2_visibility_ctx(FALSUM, FALSUM, FALSUM, FALSUM, VISIBILITY_SURFACE_HTML)
  EVOCA VisibilityContext owner_html AD CONIURA phase2_visibility_ctx(VERUM, VERUM, FALSUM, FALSUM, VISIBILITY_SURFACE_HTML)
  EVOCA VisibilityContext auth_html AD CONIURA phase2_visibility_ctx(VERUM, FALSUM, FALSUM, FALSUM, VISIBILITY_SURFACE_HTML)
  EVOCA VisibilityContext mod_admin AD CONIURA phase2_visibility_ctx(VERUM, FALSUM, FALSUM, VERUM, VISIBILITY_SURFACE_ADMIN)

  SI CONIURA visibility_decide(VISIBILITY_PUBLIC, anon_html) != VISIBILITY_ALLOW
    REDDE 1
  FIN SI
  SI CONIURA visibility_decide(VISIBILITY_PRIVATE, anon_html) != VISIBILITY_REQUIRE_LOGIN
    REDDE 2
  FIN SI
  SI CONIURA visibility_decide(VISIBILITY_PRIVATE, owner_html) != VISIBILITY_ALLOW
    REDDE 3
  FIN SI
  SI CONIURA visibility_decide(VISIBILITY_PRIVATE, auth_html) != VISIBILITY_DENY
    REDDE 4
  FIN SI
  SI CONIURA visibility_decide(VISIBILITY_PRIVATE, mod_admin) != VISIBILITY_ALLOW
    REDDE 5
  FIN SI

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
