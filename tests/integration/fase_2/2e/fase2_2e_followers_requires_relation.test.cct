INCIPIT grimoire "fase2_2e_followers_requires_relation_test"

ADVOCARE "support.cct"
ADVOCARE "../../../../lib/civitas/visibility.cct"

RITUALE main() REDDE REX
  EVOCA VisibilityContext anon_html AD CONIURA phase2_visibility_ctx(FALSUM, FALSUM, FALSUM, FALSUM, VISIBILITY_SURFACE_HTML)
  EVOCA VisibilityContext auth_html AD CONIURA phase2_visibility_ctx(VERUM, FALSUM, FALSUM, FALSUM, VISIBILITY_SURFACE_HTML)
  EVOCA VisibilityContext follower_html AD CONIURA phase2_visibility_ctx(VERUM, FALSUM, VERUM, FALSUM, VISIBILITY_SURFACE_HTML)
  EVOCA VisibilityContext mod_api AD CONIURA phase2_visibility_ctx(VERUM, FALSUM, FALSUM, VERUM, VISIBILITY_SURFACE_API)

  SI CONIURA visibility_decide(VISIBILITY_FOLLOWERS, anon_html) != VISIBILITY_REQUIRE_LOGIN
    REDDE 1
  FIN SI
  SI CONIURA visibility_decide(VISIBILITY_FOLLOWERS, auth_html) != VISIBILITY_REQUIRE_RELATION
    REDDE 2
  FIN SI
  SI CONIURA visibility_decide(VISIBILITY_FOLLOWERS, follower_html) != VISIBILITY_ALLOW
    REDDE 3
  FIN SI
  SI CONIURA visibility_decide(VISIBILITY_FOLLOWERS, mod_api) != VISIBILITY_ALLOW
    REDDE 4
  FIN SI

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
