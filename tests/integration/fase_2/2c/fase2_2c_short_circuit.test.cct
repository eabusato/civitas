INCIPIT grimoire "fase2_2c_short_circuit_test"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/middleware.cct"
ADVOCARE "../../../../lib/civitas/request_core.cct"
ADVOCARE "../../../../lib/civitas/response.cct"
ADVOCARE "cct/fluxus.cct"
ADVOCARE "cct/verbum.cct"

RITUALE terminal(SPECULUM NIHIL req_ref, SPECULUM NIHIL out_ref) REDDE NIHIL
  EVOCA SPECULUM WebResponse out
  VINCIRE out AD out_ref
  CONIURA response_fill(out, CONIURA response_text("should-not-run"))
  REDDE
EXPLICIT RITUALE

RITUALE blocker(SPECULUM NIHIL req_ref, SPECULUM NIHIL ctx_ref, SPECULUM NIHIL next_ref, SPECULUM NIHIL out_ref) REDDE NIHIL
  EVOCA SPECULUM WebResponse out
  VINCIRE out AD out_ref
  CONIURA response_fill(out, CONIURA response_unauthorized("blocked"))
  REDDE
EXPLICIT RITUALE

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL middlewares AD CONIURA fluxus_init(MENSURA(MiddlewareBinding))
  CONIURA middleware_bindings_push(middlewares, "blocker", blocker)
  EVOCA WebResponse out AD CONIURA middleware_chain(middlewares, CONIURA phase2_request("GET", "/private"), terminal)
  SI out.status != 401
    REDDE 1
  FIN SI
  SI CONIURA compare(out.body, "blocked") != 0
    REDDE 2
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
