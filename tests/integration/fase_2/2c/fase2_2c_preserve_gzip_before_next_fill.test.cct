INCIPIT grimoire "fase2_2c_preserve_gzip_before_next_fill_test"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/middleware.cct"
ADVOCARE "../../../../lib/civitas/request_core.cct"
ADVOCARE "../../../../lib/civitas/response.cct"
ADVOCARE "cct/fluxus.cct"
ADVOCARE "cct/verbum.cct"

RITUALE terminal(SPECULUM NIHIL req_ref, SPECULUM NIHIL out_ref) REDDE NIHIL
  EVOCA SPECULUM WebResponse out
  VINCIRE out AD out_ref
  CONIURA response_fill(out, CONIURA response_text("ok"))
  REDDE
EXPLICIT RITUALE

RITUALE gzip_before_next(SPECULUM NIHIL req_ref, SPECULUM NIHIL ctx_ref, SPECULUM NIHIL next_ref, SPECULUM NIHIL out_ref) REDDE NIHIL
  EVOCA SPECULUM WebResponse out
  VINCIRE out AD out_ref
  CONIURA response_enable_gzip(out)
  CONIURA middleware_run(req_ref, ctx_ref, next_ref, out_ref)
  REDDE
EXPLICIT RITUALE

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL middlewares AD CONIURA fluxus_init(MENSURA(MiddlewareBinding))
  CONIURA middleware_bindings_push(middlewares, "gzip_before_next", gzip_before_next)
  EVOCA WebResponse out AD CONIURA middleware_chain(middlewares, CONIURA phase2_request("GET", "/gzip"), terminal)
  SI NON out.gzip_enabled
    REDDE 1
  FIN SI
  SI NON CONIURA response_should_use_gzip(out, VERUM)
    REDDE 2
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
