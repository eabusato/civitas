INCIPIT grimoire "fase28_28c_version_match_supports_ranges"

ADVOCARE "../../../../lib/civitas/dep_review.cct"
ADVOCARE "../../../../lib/civitas/dep_review/dep_review.cct"
ADVOCARE "cct/fluxus.cct"

RITUALE main() REDDE REX
  SI NON CONIURA dep_review_version_matches("3.44.0", "< 3.45.0")
    REDDE 1
  FIN SI
  SI NON CONIURA dep_review_version_matches("3.45.0", ">= 3.45.0")
    REDDE 2
  FIN SI
  SI CONIURA dep_review_version_matches("3.46.0", "< 3.45.0")
    REDDE 3
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
