INCIPIT grimoire "fase28_28c_apply_db_flags_high_cve"

ADVOCARE "../support.cct"
ADVOCARE "../../../../lib/civitas/dep_review.cct"
ADVOCARE "../../../../lib/civitas/dep_review/dep_review.cct"
ADVOCARE "cct/fluxus.cct"
ADVOCARE "cct/fs.cct"
ADVOCARE "cct/path.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM root AD CONIURA phase28_reset_root("28c_apply_db")
  EVOCA VERBUM db_path AD CONIURA path_join(root, "known_cves.json")
  CONIURA write_all(db_path, "{\"deps\":[{\"name\":\"libsqlite3\",\"cves\":[{\"id\":\"CVE-TEST-28C\",\"severity\":\"high\",\"description\":\"test\",\"affected\":\"< 3.45.0\",\"fixed\":\"3.45.0\",\"source\":\"local\"}]}]}")
  EVOCA SPECULUM NIHIL deps AD CONIURA fluxus_init(MENSURA(DepInfo))
  EVOCA DepInfo dep AD CONIURA dep_review_new_dep("libsqlite3", DEP_SYSTEM_LIB, "3.44.0", "3.38.0", "cct/db_sqlite", "SQLite surface")
  CONIURA fluxus_push(deps, SPECULUM dep)
  EVOCA DepReport report AD CONIURA dep_review_apply_db(deps, db_path)
  SI report.aprovado
    REDDE 1
  FIN SI
  SI report.deps_com_cve_alto != 1
    REDDE 2
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
