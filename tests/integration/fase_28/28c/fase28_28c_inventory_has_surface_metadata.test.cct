INCIPIT grimoire "fase28_28c_inventory_has_surface_metadata"

ADVOCARE "../../../../lib/civitas/dep_review.cct"
ADVOCARE "../../../../lib/civitas/dep_review/dep_review.cct"
ADVOCARE "cct/fluxus.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL deps AD CONIURA dep_review_inventory_civitas()
  SI CONIURA fluxus_len(deps) < 4
    REDDE 1
  FIN SI
  EVOCA SPECULUM DepInfo dep_ptr AD CONIURA fluxus_get(deps, 0)
  SI CONIURA len((*dep_ptr).surface) == 0
    REDDE 2
  FIN SI
  SI CONIURA len((*dep_ptr).modulo_cct) == 0
    REDDE 3
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
