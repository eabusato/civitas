INCIPIT grimoire "fase28_28a_scan_headers_passes_with_security_headers"

ADVOCARE "../support.cct"
ADVOCARE "../../../../lib/civitas/security_audit.cct"
ADVOCARE "../../../../lib/civitas/security_audit/security_audit.cct"
ADVOCARE "../../../../lib/civitas/response.cct"

RITUALE main() REDDE REX
  EVOCA ScanConfig cfg AD CONIURA security_audit_scan_config_default()
  EVOCA WebResponse res AD CONIURA phase28_security_response()
  EVOCA ScanResult report AD CONIURA security_audit_scan_headers(res, cfg)
  SI report.total != 0
    REDDE 1
  FIN SI
  SI NON report.approved
    REDDE 2
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
