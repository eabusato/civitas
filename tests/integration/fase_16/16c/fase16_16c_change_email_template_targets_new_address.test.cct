INCIPIT grimoire "fase16_16c_change_email_template_targets_new_address"

ADVOCARE "../../../../lib/civitas/mail_templates/mail_tpl_alterar_email.cct"
ADVOCARE "../../../../lib/civitas/mailer/mailer.cct"
ADVOCARE "../../../../lib/civitas/mailer/mailer_settings.cct"
ADVOCARE "cct/fluxus.cct"
ADVOCARE "cct/mail.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA MailerConfig cfg AD CONIURA mailer_config_memory("noreply@test.local", "Test App")
  EVOCA MailMessage msg AD CONIURA mail_tpl_alterar_email(cfg, "new@test.local", "Clara", "https://app.test/email-change?token=zzz", 30)
  SI CONIURA compare(msg.subject, "Confirm your new email address") != 0
    REDDE 1
  FIN SI
  EVOCA SPECULUM MailAddress to_ptr AD CONIURA fluxus_get(msg.to, 0)
  SI CONIURA compare((*to_ptr).email, "new@test.local") != 0
    REDDE 2
  FIN SI
  SI CONIURA find(msg.text_body, "Your current address will remain active") == -1
    REDDE 3
  FIN SI
  SI CONIURA find(msg.html_body, "Confirm new email") == -1
    REDDE 4
  FIN SI
  SI CONIURA find(msg.html_body, "new@test.local") == -1
    REDDE 5
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
