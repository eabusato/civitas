INCIPIT grimoire "fase16_16c_verify_template_link_and_subject"

ADVOCARE "../../../../lib/civitas/mail_templates/mail_tpl_verificar.cct"
ADVOCARE "../../../../lib/civitas/mailer/mailer.cct"
ADVOCARE "../../../../lib/civitas/mailer/mailer_settings.cct"
ADVOCARE "cct/mail.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA MailerConfig cfg AD CONIURA mailer_config_memory("noreply@test.local", "Test App")
  EVOCA MailMessage msg AD CONIURA mail_tpl_verificar_email(cfg, "bruno@test.local", "Bruno", "https://app.test/verify?token=tok123", 24)
  SI CONIURA compare(msg.subject, "Confirm your email address") != 0
    REDDE 1
  FIN SI
  SI CONIURA find(msg.text_body, "Confirm your email address") == -1
    REDDE 2
  FIN SI
  SI CONIURA find(msg.text_body, "https://app.test/verify?token=tok123") == -1
    REDDE 3
  FIN SI
  SI CONIURA find(msg.html_body, "Confirm email") == -1
    REDDE 4
  FIN SI
  SI CONIURA find(msg.html_body, "24 hours") == -1
    REDDE 5
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
