INCIPIT grimoire "fase16_16c_welcome_template_with_verification"

ADVOCARE "../../../../lib/civitas/mail_templates/mail_tpl_boas_vindas.cct"
ADVOCARE "../../../../lib/civitas/mailer/mailer.cct"
ADVOCARE "../../../../lib/civitas/mailer/mailer_settings.cct"
ADVOCARE "cct/mail.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA MailerConfig cfg AD CONIURA mailer_config_memory("noreply@test.local", "Test App")
  EVOCA MailMessage msg AD CONIURA mail_tpl_boas_vindas(cfg, "dani@test.local", "Dani", "https://app.test/verify?token=welc")
  SI CONIURA compare(msg.subject, "Welcome to Civitas") != 0
    REDDE 1
  FIN SI
  SI CONIURA find(msg.text_body, "https://app.test/verify?token=welc") == -1
    REDDE 2
  FIN SI
  SI CONIURA find(msg.html_body, "Confirm email") == -1
    REDDE 3
  FIN SI
  SI CONIURA find(msg.html_body, "unlock full access") == -1
    REDDE 4
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
