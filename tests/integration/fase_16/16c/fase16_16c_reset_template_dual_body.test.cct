INCIPIT grimoire "fase16_16c_reset_template_dual_body"

ADVOCARE "../../../../lib/civitas/mail_templates/mail_tpl_reset.cct"
ADVOCARE "../../../../lib/civitas/mailer/mailer.cct"
ADVOCARE "../../../../lib/civitas/mailer/mailer_settings.cct"
ADVOCARE "cct/fluxus.cct"
ADVOCARE "cct/mail.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA MailerConfig cfg AD CONIURA mailer_config_memory("noreply@test.local", "Test App")
  EVOCA MailMessage msg AD CONIURA mail_tpl_reset_senha(cfg, "ana@test.local", "Ana", "https://app.test/reset?t=abc123", 60)
  SI CONIURA compare(msg.subject, "Password reset") != 0
    REDDE 1
  FIN SI
  SI CONIURA compare(msg.from.email, "noreply@test.local") != 0
    REDDE 2
  FIN SI
  SI CONIURA fluxus_len(msg.to) != 1
    REDDE 3
  FIN SI
  EVOCA SPECULUM MailAddress to_ptr AD CONIURA fluxus_get(msg.to, 0)
  SI CONIURA compare((*to_ptr).email, "ana@test.local") != 0
    REDDE 4
  FIN SI
  SI CONIURA find(msg.text_body, "https://app.test/reset?t=abc123") == -1
    REDDE 5
  FIN SI
  SI CONIURA find(msg.html_body, "Reset password") == -1
    REDDE 6
  FIN SI
  SI CONIURA find(msg.html_body, "This link expires in 60 minutes") == -1
    REDDE 7
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
