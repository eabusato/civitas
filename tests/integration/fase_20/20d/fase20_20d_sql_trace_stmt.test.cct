INCIPIT grimoire "fase20_20d_sql_trace_stmt"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/trace/trace_sql.cct"
ADVOCARE "cct/db_sqlite.cct"
ADVOCARE "cct/instrument.cct"
ADVOCARE "cct/path.cct"
ADVOCARE "cct/trace.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM root AD CONIURA phase20_reset_root("20d_sql_trace_stmt")
  EVOCA VERBUM db_path AD CONIURA path_join(root, "trace.db")
  EVOCA SPECULUM NIHIL db AD CONIURA db_open(db_path)
  CONIURA instrument_enable(INSTR_MODE_FULL)
  CONIURA instrument_buffer_clear()

  CONIURA trace_sql_exec(db, "create", "posts", "CREATE TABLE posts(id INTEGER PRIMARY KEY, title TEXT);")
  CONIURA trace_sql_exec(db, "insert", "posts", "INSERT INTO posts(id, title) VALUES (1, 'Hello');")

  EVOCA TraceStmt stmt AD CONIURA trace_sql_prepare(db, "select", "posts", "SELECT COUNT(*) FROM posts;")
  SI NON CONIURA stmt_step(stmt.stmt)
    CONIURA db_close(db)
    CONIURA instrument_disable()
    REDDE 1
  FIN SI
  SI NON CONIURA stmt_has_row(stmt.stmt)
    CONIURA trace_sql_finalize(stmt, 0)
    CONIURA db_close(db)
    CONIURA instrument_disable()
    REDDE 2
  FIN SI
  EVOCA REX count AD CONIURA stmt_get_int(stmt.stmt, 0)
  CONIURA trace_sql_finalize(stmt, 1)
  SI count != 1
    CONIURA db_close(db)
    CONIURA instrument_disable()
    REDDE 3
  FIN SI

  EVOCA Trace trace AD CONIURA instrument_buffer_drain_trace("trace-20d-sql")
  SI CONIURA trace_span_count(trace) != 3
    CONIURA trace_free(SPECULUM trace)
    CONIURA db_close(db)
    CONIURA instrument_disable()
    REDDE 4
  FIN SI
  EVOCA Span span AD CONIURA trace_get_span(trace, 2)
  SI CONIURA compare(span.name, "select:posts") != 0
    CONIURA trace_free(SPECULUM trace)
    CONIURA db_close(db)
    CONIURA instrument_disable()
    REDDE 5
  FIN SI
  SI NON CONIURA contains(span.attributes_json, "\"db.rows_returned\":\"1\"")
    CONIURA trace_free(SPECULUM trace)
    CONIURA db_close(db)
    CONIURA instrument_disable()
    REDDE 6
  FIN SI

  CONIURA trace_free(SPECULUM trace)
  CONIURA db_close(db)
  CONIURA instrument_disable()
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
