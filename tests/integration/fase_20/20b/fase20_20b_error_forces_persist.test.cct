INCIPIT grimoire "fase20_20b_error_forces_persist"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/trace/trace_spans.cct"
ADVOCARE "../../../../lib/civitas/trace_collector/trace_collector.cct"
ADVOCARE "../../../../lib/civitas/request_core.cct"
ADVOCARE "../../../../lib/civitas/response.cct"
ADVOCARE "cct/fs.cct"
ADVOCARE "cct/instrument.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM dir AD CONIURA phase20_trace_dir("20b_error_persist")
  CONIURA instrument_enable(INSTR_MODE_FULL)
  EVOCA TraceCollectorConfig cfg AD CONIURA trace_collector_config_default()
  VINCIRE cfg.trace_dir AD dir
  VINCIRE cfg.sample_rate AD 50
  EVOCA WebRequest req AD CONIURA phase20_request("GET", "/boom")
  EVOCA WebResponse res AD CONIURA phase20_response(500)
  EVOCA TraceRequestContext tctx AD CONIURA trace_collector_begin(cfg, req, 1)
  EVOCA REX span_id AD CONIURA civitas_span_handler("ErrorView")
  CONIURA civitas_span_end(span_id)
  EVOCA TracePersistResult persisted AD CONIURA trace_collector_end(cfg, SPECULUM tctx, req, SPECULUM res)
  SI NON persisted.persisted
    REDDE 1
  FIN SI
  SI NON CONIURA exists(persisted.file_path)
    CONIURA instrument_disable()
    REDDE 2
  FIN SI
  CONIURA instrument_disable()
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
