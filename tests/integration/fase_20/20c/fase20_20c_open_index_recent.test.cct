INCIPIT grimoire "fase20_20c_open_index_recent"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/trace_store/trace_store.cct"
ADVOCARE "cct/fluxus.cct"
ADVOCARE "cct/path.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM root AD CONIURA phase20_reset_root("20c_open_recent")
  EVOCA VERBUM trace_dir AD CONIURA path_join(root, "traces")
  EVOCA TraceStore store AD CONIURA trace_store_open(CONIURA phase20_trace_db_path("20c_open_recent"), trace_dir, 10, 24)
  EVOCA VERBUM file_path AD CONIURA phase20_write_trace_file(trace_dir, "trace-open-1", "request")
  CONIURA trace_store_index_trace(SPECULUM store, "trace-open-1", "/posts", "GET", 200, 12, 1, "user-1", file_path, 100)
  EVOCA TraceResultSet rs AD CONIURA trace_store_query_recent(SPECULUM store, 5)
  SI rs.count != 1
    CONIURA trace_store_result_set_free(SPECULUM rs)
    CONIURA trace_store_close(SPECULUM store)
    REDDE 1
  FIN SI
  EVOCA SPECULUM TraceRow row_ptr AD CONIURA fluxus_get(rs.rows, 0)
  SI CONIURA compare((*row_ptr).trace_id, "trace-open-1") != 0
    CONIURA trace_store_result_set_free(SPECULUM rs)
    CONIURA trace_store_close(SPECULUM store)
    REDDE 2
  FIN SI
  CONIURA trace_store_result_set_free(SPECULUM rs)
  CONIURA trace_store_close(SPECULUM store)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
