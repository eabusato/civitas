INCIPIT grimoire "fase20_20c_load_trace"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/trace_store/trace_store.cct"
ADVOCARE "cct/path.cct"
ADVOCARE "cct/result.cct"
ADVOCARE "cct/trace.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM root AD CONIURA phase20_reset_root("20c_load_trace")
  EVOCA VERBUM trace_dir AD CONIURA path_join(root, "traces")
  EVOCA TraceStore store AD CONIURA trace_store_open(CONIURA phase20_trace_db_path("20c_load_trace"), trace_dir, 10, 24)
  EVOCA VERBUM file_path AD CONIURA phase20_write_trace_file(trace_dir, "t-load", "request")
  CONIURA trace_store_index_trace(SPECULUM store, "t-load", "/load", "GET", 200, 15, 1, "user-9", file_path, 100)
  EVOCA SPECULUM NIHIL loaded_res AD CONIURA trace_store_load_trace(SPECULUM store, "t-load")
  SI CONIURA result_is_err GENUS(Trace, TraceError)(loaded_res)
    CONIURA trace_store_close(SPECULUM store)
    REDDE 1
  FIN SI
  EVOCA Trace trace AD CONIURA result_unwrap GENUS(Trace, TraceError)(loaded_res)
  SI CONIURA trace_span_count(trace) != 1
    CONIURA trace_free(SPECULUM trace)
    CONIURA trace_store_close(SPECULUM store)
    REDDE 2
  FIN SI
  CONIURA trace_free(SPECULUM trace)
  CONIURA trace_store_close(SPECULUM store)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
