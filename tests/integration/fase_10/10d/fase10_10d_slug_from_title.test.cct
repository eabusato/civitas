INCIPIT grimoire "fase10_10d_slug_from_title"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/taxonomy/taxonomy.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  SI CONIURA compare(CONIURA taxonomy_slug_from_title("Olá, São Paulo!"), "ola-sao-paulo") != 0
    REDDE 1
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
