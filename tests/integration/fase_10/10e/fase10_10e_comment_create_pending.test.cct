INCIPIT grimoire "fase10_10e_comment_create_pending"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/social/social.cct"
ADVOCARE "../../../../lib/civitas/social/social_comment.cct"
ADVOCARE "cct/db_sqlite.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL db AD CONIURA phase10_db_open("10e_comment_create_pending")
  EVOCA Comment c AD CONIURA comment_create(db, "post", 3, "Ana", "ana@example.com", "Hello")
  SI c.id == 0 VEL c.state != CsPending
    REDDE 1
  FIN SI
  CONIURA db_close(db)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
