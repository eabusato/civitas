INCIPIT grimoire "fase10_10g_page_publish_list"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/authorship/authorship.cct"
ADVOCARE "../../../../lib/civitas/pages/pages.cct"
ADVOCARE "../../../../lib/civitas/pages/pages_crud.cct"
ADVOCARE "cct/db_sqlite.cct"
ADVOCARE "cct/fluxus.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL db AD CONIURA phase10_db_open("10g_page_publish_list")
  EVOCA ContentOrigin origin AD CONIURA content_origin_empty()
  VINCIRE origin.user_id AD "1"
  VINCIRE origin.request_id AD "req-1"
  EVOCA Page page AD CONIURA page_create(db, "en", "news", "News", "<p>N</p>", origin)
  CONIURA page_publish(db, page.id, origin)
  EVOCA SPECULUM NIHIL pages AD CONIURA page_list_published(db, "en")
  SI CONIURA fluxus_len(pages) != 1
    REDDE 1
  FIN SI
  CONIURA db_close(db)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
