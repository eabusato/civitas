INCIPIT grimoire "fase10_10c_migrator_last_applied"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/migrate/migrate.cct"
ADVOCARE "cct/db_sqlite.cct"
ADVOCARE "cct/verbum.cct"

RITUALE migration_0001_up(SPECULUM NIHIL db) REDDE NIHIL
  CONIURA db_exec(db, "CREATE TABLE z(id INTEGER PRIMARY KEY)")
  REDDE
EXPLICIT RITUALE

RITUALE migration_0001_down(SPECULUM NIHIL db) REDDE NIHIL
  CONIURA db_exec(db, "DROP TABLE IF EXISTS z")
  REDDE
EXPLICIT RITUALE

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL db AD CONIURA phase10_db_open("10c_migrator_last_applied")
  EVOCA Migrator mgr AD CONIURA migrator_new(db, NIHIL)
  CONIURA migrator_add(mgr, "0001", "create_z", migration_0001_up, migration_0001_down)
  CONIURA migrator_run(mgr)
  SI CONIURA compare(CONIURA migrator_last_applied_version(db), "0001") != 0
    REDDE 1
  FIN SI
  CONIURA db_close(db)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
