INCIPIT grimoire "fase10_10c_migrator_no_pending"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/migrate/migrate.cct"
ADVOCARE "cct/db_sqlite.cct"
ADVOCARE "cct/result.cct"

RITUALE migration_0001_up(SPECULUM NIHIL db) REDDE NIHIL
  CONIURA db_exec(db, "CREATE TABLE items(id INTEGER PRIMARY KEY)")
  REDDE
EXPLICIT RITUALE

RITUALE migration_0001_down(SPECULUM NIHIL db) REDDE NIHIL
  CONIURA db_exec(db, "DROP TABLE IF EXISTS items")
  REDDE
EXPLICIT RITUALE

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL db AD CONIURA phase10_db_open("10c_migrator_no_pending")
  EVOCA Migrator mgr AD CONIURA migrator_new(db, NIHIL)
  CONIURA migrator_add(mgr, "0001", "create_items", migration_0001_up, migration_0001_down)
  CONIURA migrator_run(mgr)
  EVOCA SPECULUM NIHIL res AD CONIURA migrator_run(mgr)
  SI NON CONIURA result_is_err GENUS(REX, MigrateError)(res)
    REDDE 1
  FIN SI
  SI CONIURA result_unwrap_err GENUS(REX, MigrateError)(res) != MeNenhumaPendente
    REDDE 2
  FIN SI
  CONIURA db_close(db)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
