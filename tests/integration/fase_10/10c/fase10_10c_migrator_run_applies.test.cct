INCIPIT grimoire "fase10_10c_migrator_run_applies"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/migrate/migrate.cct"
ADVOCARE "cct/db_sqlite.cct"
ADVOCARE "cct/result.cct"

RITUALE migration_0001_up(SPECULUM NIHIL db) REDDE NIHIL
  CONIURA db_exec(db, "CREATE TABLE users(id INTEGER PRIMARY KEY, email TEXT NOT NULL)")
  REDDE
EXPLICIT RITUALE

RITUALE migration_0001_down(SPECULUM NIHIL db) REDDE NIHIL
  CONIURA db_exec(db, "DROP TABLE IF EXISTS users")
  REDDE
EXPLICIT RITUALE

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL db AD CONIURA phase10_db_open("10c_migrator_run_applies")
  EVOCA Migrator mgr AD CONIURA migrator_new(db, NIHIL)
  CONIURA migrator_add(mgr, "0001", "create_users", migration_0001_up, migration_0001_down)
  EVOCA SPECULUM NIHIL res AD CONIURA migrator_run(mgr)
  SI CONIURA result_is_err GENUS(REX, MigrateError)(res)
    REDDE 1
  FIN SI
  SI CONIURA db_scalar_int(db, "SELECT COUNT(*) FROM sqlite_master WHERE type = 'table' AND name = 'users'") != 1
    REDDE 2
  FIN SI
  SI CONIURA migrator_is_applied(db, "0001") == FALSUM
    REDDE 3
  FIN SI
  CONIURA db_close(db)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
