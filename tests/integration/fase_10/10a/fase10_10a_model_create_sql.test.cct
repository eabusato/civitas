INCIPIT grimoire "fase10_10a_model_create_sql"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/model/model.cct"
ADVOCARE "../../../../lib/civitas/model/model_ddl.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA ModelDef def AD CONIURA model_def_new("users")
  CONIURA model_def_add_int(def, "id", VERUM, VERUM, VERUM)
  CONIURA model_def_add_text(def, "email", VERUM, VERUM)
  CONIURA model_def_add_fk(def, "author_id", "authors", "id", FALSUM)

  EVOCA VERBUM sql AD CONIURA model_def_sql_create(def)
  SI CONIURA contains(sql, "CREATE TABLE IF NOT EXISTS users") == FALSUM
    REDDE 1
  FIN SI
  SI CONIURA contains(sql, "id INTEGER PRIMARY KEY AUTOINCREMENT") == FALSUM
    REDDE 2
  FIN SI
  SI CONIURA contains(sql, "email TEXT NOT NULL UNIQUE") == FALSUM
    REDDE 3
  FIN SI
  SI CONIURA contains(sql, "author_id INTEGER REFERENCES authors(id)") == FALSUM
    REDDE 4
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
