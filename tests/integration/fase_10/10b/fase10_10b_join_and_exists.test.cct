INCIPIT grimoire "fase10_10b_join_and_exists"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/query/query.cct"
ADVOCARE "../../../../lib/civitas/query/query_exec.cct"
ADVOCARE "cct/db_sqlite.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL db AD CONIURA phase10_db_open("10b_join_and_exists")
  CONIURA db_exec(db, "CREATE TABLE users(id INTEGER PRIMARY KEY, name TEXT NOT NULL, active INTEGER NOT NULL)")
  CONIURA db_exec(db, "CREATE TABLE posts(id INTEGER PRIMARY KEY, user_id INTEGER NOT NULL, title TEXT NOT NULL)")
  CONIURA db_exec(db, "INSERT INTO users(id, name, active) VALUES(1, 'Ana', 1)")
  CONIURA db_exec(db, "INSERT INTO posts(id, user_id, title) VALUES(10, 1, 'Hello')")

  EVOCA Query q AD CONIURA query_from("users")
  CONIURA query_select(q, "users.id")
  CONIURA query_select(q, "posts.title")
  CONIURA query_join(q, Left, "posts", "users.id", "posts.user_id")
  CONIURA query_filter_int(q, "users.active", Eq, 1)
  SI NON CONIURA query_exists(db, q)
    REDDE 1
  FIN SI
  EVOCA VERBUM sql AD CONIURA query_build_sql(q)
  SI CONIURA contains(sql, "LEFT JOIN posts ON users.id = posts.user_id") == FALSUM
    REDDE 2
  FIN SI
  CONIURA db_close(db)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
