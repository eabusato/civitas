INCIPIT grimoire "fase14_14d_plural_json_catalog_to_gettext"

ADVOCARE "../../../../lib/civitas/i18n_catalog_json/i18n_catalog_json.cct"
ADVOCARE "../../../../lib/civitas/i18n_catalog_json/i18n_catalog_json_loader.cct"
ADVOCARE "cct/gettext.cct"
ADVOCARE "cct/result.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM raw AD "{\"locale\":\"pt-BR\",\"entries\":{\"nav.home\":\"Inicio\"},\"plurais\":{\"posts.count\":{\"singular\":\"{n} post\",\"plural\":\"{n} posts\"}}}"
  EVOCA SPECULUM NIHIL parsed AD CONIURA i18n_json_parse(raw)
  EVOCA JsonCatalog cat AD CONIURA result_unwrap GENUS(JsonCatalog, VERBUM)(parsed)
  EVOCA Catalog gt AD CONIURA i18n_json_to_catalog(cat)
  SI CONIURA compare(CONIURA gettext_translate(gt, "nav.home"), "Inicio") != 0
    REDDE 1
  FIN SI
  SI CONIURA compare(CONIURA gettext_translate_plural(gt, "posts.count", "posts.count", 2), "{n} posts") != 0
    REDDE 1
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
