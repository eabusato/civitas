INCIPIT grimoire "fase14_14e_relative_time"

ADVOCARE "../../../../lib/civitas/l10n_fmt/l10n_fmt.cct"
ADVOCARE "../../../../lib/civitas/l10n_fmt/l10n_fmt_rules.cct"
ADVOCARE "../../../../lib/civitas/l10n_fmt/l10n_fmt_reltime.cct"
ADVOCARE "cct/date.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA L10nFmtRules pt AD CONIURA l10n_fmt_rules_pt_br()
  EVOCA L10nFmtRules en AD CONIURA l10n_fmt_rules_en_us()
  EVOCA DateTime past AD CONIURA datetime_add_seconds(CONIURA datetime_now(), -180)
  EVOCA DateTime future AD CONIURA datetime_add_seconds(CONIURA datetime_now(), 7200)
  EVOCA VERBUM past_pt AD CONIURA l10n_reltime(past, SPECULUM pt)
  EVOCA VERBUM future_en AD CONIURA l10n_reltime(future, SPECULUM en)
  SI NON CONIURA contains(past_pt, "3 minutos")
    REDDE 1
  FIN SI
  SI NON CONIURA contains(future_en, "2 hours")
    REDDE 1
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
