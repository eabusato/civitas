INCIPIT grimoire "fase14_14e_date_long_and_month_name"

ADVOCARE "../../../../lib/civitas/l10n_fmt/l10n_fmt.cct"
ADVOCARE "../../../../lib/civitas/l10n_fmt/l10n_fmt_rules.cct"
ADVOCARE "../../../../lib/civitas/l10n_fmt/l10n_fmt_date_long.cct"
ADVOCARE "cct/date.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA L10nFmtRules pt AD CONIURA l10n_fmt_rules_pt_br()
  EVOCA L10nFmtRules en AD CONIURA l10n_fmt_rules_en_us()
  EVOCA Date d AD CONIURA date_make(2026, 3, 28)
  SI CONIURA compare(CONIURA l10n_month_name(3, SPECULUM pt, FALSUM), "marco") != 0
    REDDE 1
  FIN SI
  SI CONIURA compare(CONIURA l10n_format_date_long(d, SPECULUM pt), "28 de marco de 2026") != 0
    REDDE 1
  FIN SI
  SI CONIURA compare(CONIURA l10n_format_date_long(d, SPECULUM en), "March 28, 2026") != 0
    REDDE 1
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
