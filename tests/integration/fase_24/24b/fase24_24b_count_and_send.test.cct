INCIPIT grimoire "fase24_24b_count_and_send"

ADVOCARE "../../../../lib/civitas/test_mail/test_mail.cct"
ADVOCARE "cct/mail.cct"
ADVOCARE "cct/result.cct"

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL outbox AD CONIURA test_mail_outbox_new()
  EVOCA MailMessage msg AD CONIURA mail_message_new()
  CONIURA mail_message_set_from(SPECULUM msg, CONIURA mail_address("noreply@test.local", "Test"))
  CONIURA mail_message_add_to(SPECULUM msg, CONIURA mail_address("alice@example.com", "Alice"))
  CONIURA mail_message_set_subject(SPECULUM msg, "Welcome")
  CONIURA mail_message_set_text(SPECULUM msg, "hello alice")
  EVOCA SPECULUM NIHIL sent AD CONIURA mail_send(CONIURA test_mail_client(outbox), msg)
  SI CONIURA result_is_err GENUS(MailSendResult, VERBUM)(sent)
    REDDE 1
  FIN SI
  CONIURA assert_email_sent(outbox, 1)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
