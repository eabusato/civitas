INCIPIT grimoire "fase24_24c_retry_then_done"

ADVOCARE "../../../../lib/civitas/db_handle/db_handle.cct"
ADVOCARE "../../../../lib/civitas/test_tasks/test_tasks.cct"
ADVOCARE "../../../../lib/civitas/tasks/tasks.cct"
ADVOCARE "cct/verbum.cct"

RITUALE phase24_retry_task(DbHandle dbh, TaskRecord task) REDDE TaskCallbackResult
  SI task.attempts <= 1
    REDDE CONIURA task_callback_result_retry("retry_once", "{\"error\":\"retry_once\"}")
  FIN SI
  REDDE CONIURA task_callback_result_ok("{\"status\":\"ok\"}")
EXPLICIT RITUALE

RITUALE main() REDDE REX
  EVOCA SPECULUM NIHIL q AD CONIURA test_tasks_setup()
  CONIURA test_tasks_register(q, "retry_once", phase24_retry_task)
  SI CONIURA len(CONIURA test_tasks_enqueue(q, "retry_once", "{\"job\":1}")) == 0
    REDDE 1
  FIN SI
  SI CONIURA test_tasks_flush(q) != 2
    REDDE 1
  FIN SI
  CONIURA assert_task_ran(q, "retry_once")
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
