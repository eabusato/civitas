INCIPIT grimoire "fase12_12d_stampede_redis_claim_release"

ADVOCARE "support.cct"
ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/cache/cache.cct"
ADVOCARE "../../../../lib/civitas/cache_invalidation/stampede.cct"
ADVOCARE "cct/result.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA CacheHandle h AD CONIURA phase12_redis_cache("12d_stampede_redis", "12d-stampede-redis")
  EVOCA StampedeHandle sh AD CONIURA stampede_handle_redis(SPECULUM h, CONIURA phase12_12d_redis_ptr(h), "civitas:inflight:view")
  VINCIRE sh.poll_interval_ms AD 1
  VINCIRE sh.max_polls AD 1

  EVOCA StampedeResult first AD CONIURA stampede_try(sh, "redis-key")
  SI first.status != SsClaimed
    REDDE 1
  FIN SI
  EVOCA StampedeResult second AD CONIURA stampede_try(sh, "redis-key")
  SI second.status != SsTimeout
    REDDE 2
  FIN SI
  CONIURA result_unwrap GENUS(REX, VERBUM)(CONIURA stampede_release(sh, "redis-key", "done", 60))
  EVOCA StampedeResult after AD CONIURA stampede_try(sh, "redis-key")
  SI after.status != SsHit
    REDDE 3
  FIN SI
  SI CONIURA compare(after.valor, "done") != 0
    REDDE 4
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
