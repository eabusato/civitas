INCIPIT grimoire "fase12_12a_namespace_isolation"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/cache.cct"
ADVOCARE "../../../../lib/civitas/cache/cache.cct"
ADVOCARE "../../../../lib/civitas/cache/cache_arq.cct"
ADVOCARE "../../../../lib/civitas/cache/cache_api.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA CacheHandle h1 AD CONIURA phase12_file_cache("12a_namespace_iso", "ns1")
  EVOCA CacheHandle h2 AD CONIURA cache_arq_new(CONIURA phase12_tmp_dir("12a_namespace_iso"), "ns2")
  CONIURA cache_set(SPECULUM h1, "same", "one", 0)
  CONIURA cache_set(SPECULUM h2, "same", "two", 0)
  EVOCA CacheMaybeText one_maybe AD CONIURA cache_get(SPECULUM h1, "same")
  EVOCA CacheMaybeText two_maybe AD CONIURA cache_get(SPECULUM h2, "same")
  SI CONIURA compare(one_maybe.valor, "one") != 0
    REDDE 1
  FIN SI
  SI CONIURA compare(two_maybe.valor, "two") != 0
    REDDE 2
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
