INCIPIT grimoire "fase12_12a_get_or_set_and_metrics"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/cache.cct"
ADVOCARE "../../../../lib/civitas/cache/cache.cct"
ADVOCARE "../../../../lib/civitas/cache/cache_api.cct"
ADVOCARE "cct/fs.cct"
ADVOCARE "cct/path.cct"
ADVOCARE "cct/verbum.cct"

RITUALE phase12_12a_compute_value(SPECULUM NIHIL out_ref) REDDE NIHIL
  CONIURA append_all("tests/tmp/fase_12/get_or_set_calls.txt", "x")
  CONIURA cache_write_text_out(out_ref, "computed-value")
  REDDE
EXPLICIT RITUALE

RITUALE main() REDDE REX
  EVOCA CacheHandle h AD CONIURA phase12_mem_cache("get-or-set")
  CONIURA phase12_reset_dir("tests/tmp/fase_12")
  EVOCA VERBUM v1 AD CONIURA cache_get_ou_set(SPECULUM h, "compute", 60, phase12_12a_compute_value)
  EVOCA VERBUM v2 AD CONIURA cache_get_ou_set(SPECULUM h, "compute", 60, phase12_12a_compute_value)
  SI CONIURA compare(v1, "computed-value") != 0
    REDDE 1
  FIN SI
  SI CONIURA compare(v2, "computed-value") != 0
    REDDE 2
  FIN SI
  SI CONIURA len(CONIURA read_all("tests/tmp/fase_12/get_or_set_calls.txt")) != 1
    REDDE 3
  FIN SI
  EVOCA CacheMetrics met AD CONIURA cache_metrics(SPECULUM h)
  SI met.acertos < 1
    REDDE 4
  FIN SI
  SI met.falhas < 1
    REDDE 5
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
