INCIPIT grimoire "fase12_12a_file_persist_flush_multiline"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/cache.cct"
ADVOCARE "../../../../lib/civitas/cache/cache.cct"
ADVOCARE "../../../../lib/civitas/cache/cache_arq.cct"
ADVOCARE "../../../../lib/civitas/cache/cache_api.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA CacheHandle h1 AD CONIURA phase12_file_cache("12a_file_persist", "file-ns")
  EVOCA VERBUM payload AD "line1\nline2\nline3"
  CONIURA cache_set(SPECULUM h1, "multi", payload, 0)

  EVOCA CacheHandle h2 AD CONIURA cache_arq_new(CONIURA phase12_tmp_dir("12a_file_persist"), "file-ns")
  EVOCA CacheMaybeText maybe AD CONIURA cache_get(SPECULUM h2, "multi")
  SI NON maybe.found
    REDDE 1
  FIN SI
  SI CONIURA compare(maybe.valor, payload) != 0
    REDDE 2
  FIN SI
  CONIURA cache_flush(SPECULUM h2)
  SI CONIURA cache_exists(SPECULUM h2, "multi")
    REDDE 3
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
