INCIPIT grimoire "fase12_12b_invalidar_tag_multiple_entries"

ADVOCARE "support.cct"
ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/cache/cache.cct"
ADVOCARE "../../../../lib/civitas/cache_view/cache_view.cct"
ADVOCARE "../../../../lib/civitas/cache_view/cache_view_ops.cct"
ADVOCARE "../../../../lib/civitas/cache_view/cache_view_tags.cct"
ADVOCARE "../../../../lib/civitas/request_core.cct"
ADVOCARE "../../../../lib/civitas/response.cct"

RITUALE main() REDDE REX
  EVOCA CacheHandle h AD CONIURA phase12_mem_cache("12b-invalidate")
  EVOCA SPECULUM NIHIL cv AD CONIURA cache_view_new(SPECULUM h, CONIURA phase12_12b_cfg("cv12b", 60), NIHIL)
  CONIURA cache_view_set(cv, CONIURA phase12_12b_request("GET", "/posts"), CONIURA response_html("page1"), 60, "posts")
  CONIURA cache_view_set(cv, CONIURA phase12_12b_request("GET", "/posts?page=2"), CONIURA response_html("page2"), 60, "posts")
  CONIURA cache_view_set(cv, CONIURA phase12_12b_request("GET", "/perfil/42"), CONIURA response_html("profile"), 60, "usuario:42")
  CONIURA cache_view_invalidar_tag(cv, "posts")
  EVOCA CacheMaybeViewEntry first AD CONIURA cache_view_get(cv, CONIURA phase12_12b_request("GET", "/posts"))
  EVOCA CacheMaybeViewEntry second AD CONIURA cache_view_get(cv, CONIURA phase12_12b_request("GET", "/posts?page=2"))
  EVOCA CacheMaybeViewEntry third AD CONIURA cache_view_get(cv, CONIURA phase12_12b_request("GET", "/perfil/42"))
  SI first.found
    REDDE 1
  FIN SI
  SI second.found
    REDDE 2
  FIN SI
  SI NON third.found
    REDDE 3
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
