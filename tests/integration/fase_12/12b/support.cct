INCIPIT grimoire "fase12_12b_support"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/cache_view/cache_view.cct"
ADVOCARE "../../../../lib/civitas/cache_view/cache_view_middleware.cct"
ADVOCARE "../../../../lib/civitas/middleware.cct"
ADVOCARE "../../../../lib/civitas/request_core.cct"
ADVOCARE "../../../../lib/civitas/response.cct"
ADVOCARE "cct/fluxus.cct"
ADVOCARE "cct/map.cct"
ADVOCARE "cct/result.cct"

RITUALE phase12_12b_cfg(VERBUM namespace, REX ttl) REDDE CacheViewConfig
  EVOCA CacheViewConfig cfg
  VINCIRE cfg.namespace AD namespace
  VINCIRE cfg.ttl_padrao AD ttl
  VINCIRE cfg.vary_headers AD CONIURA fluxus_init(MENSURA(VERBUM))
  REDDE cfg
EXPLICIT RITUALE

RITUALE phase12_12b_request(VERBUM method, VERBUM target) REDDE WebRequest
  EVOCA SPECULUM NIHIL res AD CONIURA request_build(method, target, "HTTP/1.1", CONIURA request_empty_headers(), "", "127.0.0.1", "http", "example.test", "req-12b", "", "", "")
  REDDE CONIURA result_unwrap GENUS(WebRequest, VERBUM)(res)
EXPLICIT RITUALE

RITUALE phase12_12b_request_with_headers(VERBUM method, VERBUM target, SPECULUM NIHIL headers) REDDE WebRequest
  EVOCA SPECULUM NIHIL res AD CONIURA request_build(method, target, "HTTP/1.1", headers, "", "127.0.0.1", "http", "example.test", "req-12b", "", "", "")
  REDDE CONIURA result_unwrap GENUS(WebRequest, VERBUM)(res)
EXPLICIT RITUALE

RITUALE phase12_12b_ctx(SPECULUM NIHIL cv_ptr, REX ttl) REDDE RequestContext
  EVOCA RequestContext ctx AD CONIURA middleware_context_new()
  CONIURA cache_view_context_set(SPECULUM ctx, cv_ptr, ttl)
  REDDE ctx
EXPLICIT RITUALE

RITUALE phase12_12b_reset_dir(VERBUM path) REDDE NIHIL
  CONIURA phase12_reset_dir(path)
  REDDE
EXPLICIT RITUALE

EXPLICIT grimoire
