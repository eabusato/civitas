INCIPIT grimoire "fase12_12b_middleware_get_hit"

ADVOCARE "support.cct"
ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/cache/cache.cct"
ADVOCARE "../../../../lib/civitas/cache_view/cache_view.cct"
ADVOCARE "../../../../lib/civitas/cache_view/cache_view_middleware.cct"
ADVOCARE "../../../../lib/civitas/middleware.cct"
ADVOCARE "../../../../lib/civitas/request_core.cct"
ADVOCARE "../../../../lib/civitas/response.cct"
ADVOCARE "cct/fluxus.cct"
ADVOCARE "cct/fs.cct"
ADVOCARE "cct/path.cct"
ADVOCARE "cct/verbum.cct"

RITUALE phase12_12b_terminal_hit(SPECULUM NIHIL req_ref, SPECULUM NIHIL out_ref) REDDE NIHIL
  CONIURA append_all("tests/tmp/fase_12/12b/hit_calls.txt", "x")
  EVOCA SPECULUM WebResponse out AD out_ref
  CONIURA response_fill(out, CONIURA response_html("<h1>cached</h1>"))
  REDDE
EXPLICIT RITUALE

RITUALE main() REDDE REX
  CONIURA phase12_12b_reset_dir("tests/tmp/fase_12/12b")
  EVOCA CacheHandle h AD CONIURA phase12_mem_cache("12b-mw")
  EVOCA SPECULUM NIHIL cv AD CONIURA cache_view_new(SPECULUM h, CONIURA phase12_12b_cfg("cv12b", 60), NIHIL)
  EVOCA SPECULUM NIHIL middlewares AD CONIURA fluxus_init(MENSURA(MiddlewareBinding))
  CONIURA middleware_bindings_push(middlewares, "cache_view", cache_view_middleware)

  EVOCA RequestContext ctx1 AD CONIURA phase12_12b_ctx(cv, 60)
  EVOCA RequestContext ctx2 AD CONIURA phase12_12b_ctx(cv, 60)
  EVOCA WebRequest req AD CONIURA phase12_12b_request("GET", "/posts")
  EVOCA WebResponse first AD CONIURA middleware_chain_with_context(middlewares, req, SPECULUM ctx1, phase12_12b_terminal_hit)
  EVOCA WebResponse second AD CONIURA middleware_chain_with_context(middlewares, req, SPECULUM ctx2, phase12_12b_terminal_hit)

  SI CONIURA compare(CONIURA response_header_or(first, "x-cache", ""), "MISS") != 0
    REDDE 1
  FIN SI
  SI CONIURA compare(CONIURA response_header_or(second, "x-cache", ""), "HIT") != 0
    REDDE 2
  FIN SI
  SI CONIURA len(CONIURA read_all("tests/tmp/fase_12/12b/hit_calls.txt")) != 1
    REDDE 3
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
