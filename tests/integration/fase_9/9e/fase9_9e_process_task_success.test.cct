INCIPIT grimoire "fase9_9e_process_task_success"

ADVOCARE "support.cct"
ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/media_video/video.cct"
ADVOCARE "../../../../lib/civitas/media_video/video_types.cct"
ADVOCARE "cct/fs.cct"
ADVOCARE "cct/media_store.cct"
ADVOCARE "cct/path.cct"
ADVOCARE "cct/result.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE NIHIL
  EVOCA VERBUM root AD CONIURA phase9_9e_root("process_task")
  CONIURA phase9_reset_dir(root)
  EVOCA MediaStore store AD CONIURA phase9_9e_open_store(root)
  EVOCA VERBUM path AD CONIURA phase9_9e_make_video(root, "clip.mp4", 1.0, 320, 240)
  EVOCA SPECULUM NIHIL ingest_res AD CONIURA video_ingest(path, "clip.mp4", "user-1", CONIURA phase9_9e_config_default(), store)
  SI CONIURA result_is_err GENUS(VideoRecord, VERBUM)(ingest_res)
    IACE CONIURA result_unwrap_err GENUS(VideoRecord, VERBUM)(ingest_res)
  FIN SI
  EVOCA VideoRecord record AD CONIURA result_unwrap GENUS(VideoRecord, VERBUM)(ingest_res)

  EVOCA SPECULUM NIHIL process_res AD CONIURA video_process_task(record.artifact_id, CONIURA phase9_9e_config_default(), store, SPECULUM record)
  SI CONIURA result_is_err GENUS(REX, VERBUM)(process_res)
    IACE CONIURA result_unwrap_err GENUS(REX, VERBUM)(process_res)
  FIN SI
  SI record.process_state != VpsReady
    IACE "video should finish in ready state"
  FIN SI
  SI record.zone != MEDIA_ZONE_PROCESSED
    IACE "video original should be promoted to processed zone"
  FIN SI
  SI NON CONIURA exists(CONIURA path_join(CONIURA media_store_zone_dir(store, MEDIA_ZONE_PROCESSED), CONIURA concat(record.artifact_id, "_thumb.jpg")))
    IACE "processed thumbnail should exist"
  FIN SI
EXPLICIT RITUALE

EXPLICIT grimoire
