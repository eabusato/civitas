INCIPIT grimoire "fase9_9a_field_limit_error"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/request_core.cct"
ADVOCARE "../../../../lib/civitas/upload/upload.cct"
ADVOCARE "../../../../lib/civitas/upload/upload_types.cct"
ADVOCARE "cct/fluxus.cct"
ADVOCARE "cct/fs.cct"
ADVOCARE "cct/map.cct"
ADVOCARE "cct/path.cct"
ADVOCARE "cct/result.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE NIHIL
  EVOCA VERBUM root AD CONIURA phase9_tmp_dir("9a_field_limit")
  EVOCA VERBUM upload_dir AD CONIURA path_join(root, "uploads")
  CONIURA phase9_reset_dir(root)
  CONIURA mkdir_all(upload_dir)

  EVOCA SPECULUM NIHIL parts AD CONIURA fluxus_init(MENSURA(VERBUM))
  EVOCA VERBUM file_part AD CONIURA phase9_file_part("avatar", "photo.jpg", "image/jpeg", CONIURA concat(CONIURA phase9_fake_jpeg(), "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"))
  CONIURA fluxus_push(parts, SPECULUM file_part)
  EVOCA VERBUM boundary AD "phase9-boundary"
  EVOCA VERBUM body AD CONIURA phase9_multipart_body(boundary, parts)
  EVOCA SPECULUM NIHIL headers AD CONIURA phase9_headers()
  CONIURA map_insert GENUS(VERBUM, VERBUM)(headers, "content-type", CONIURA concat("multipart/form-data; boundary=", boundary))
  EVOCA WebRequest req AD CONIURA phase9_request("POST", "/upload", headers, body)
  EVOCA UploadConfig cfg AD CONIURA phase9_upload_config(upload_dir)
  VINCIRE cfg.max_tamanho_campo AD 8
  CONIURA upload_config_allow_type(SPECULUM cfg, "image/jpeg")

  EVOCA SPECULUM NIHIL res AD CONIURA upload_parse(req, cfg)
  SI NON CONIURA result_is_err GENUS(MultipartResult, UploadError)(res)
    IACE "field limit should fail"
  FIN SI
  EVOCA UploadError err AD CONIURA result_unwrap_err GENUS(MultipartResult, UploadError)(res)
  SI err != UeExcedeuLimite
    IACE "wrong limit error"
  FIN SI
EXPLICIT RITUALE

EXPLICIT grimoire
