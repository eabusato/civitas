INCIPIT grimoire "fase9_9f_serve_direct_full_body"

ADVOCARE "support.cct"
ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/media_delivery/delivery.cct"
ADVOCARE "../../../../lib/civitas/media_delivery/delivery_range.cct"
ADVOCARE "../../../../lib/civitas/response.cct"
ADVOCARE "cct/result.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE NIHIL
  EVOCA VERBUM root AD CONIURA phase9_9f_root("direct_full")
  EVOCA VERBUM content AD CONIURA phase9_9f_big_text()
  CONIURA phase9_reset_dir(root)
  EVOCA VERBUM path AD CONIURA phase9_9f_source_file(root, "data.txt", content)
  EVOCA SPECULUM NIHIL serve_res AD CONIURA delivery_serve_direct(path, "text/plain", CONIURA phase9_9f_direct_cfg(), CONIURA phase9_9f_headers())
  SI CONIURA result_is_err GENUS(WebResponse, DeliveryError)(serve_res)
    IACE "direct full response should succeed"
  FIN SI
  EVOCA WebResponse res AD CONIURA result_unwrap GENUS(WebResponse, DeliveryError)(serve_res)
  SI res.status != 200
    IACE "full delivery should return 200"
  FIN SI
  SI CONIURA compare(res.body, content) != 0
    IACE "full body must match file content"
  FIN SI
  SI CONIURA compare(CONIURA response_header_or(res, "accept-ranges", ""), "bytes") != 0
    IACE "full response should advertise byte ranges"
  FIN SI
EXPLICIT RITUALE

EXPLICIT grimoire
