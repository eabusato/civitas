INCIPIT grimoire "fase9_9f_support"

ADVOCARE "../support/common.cct"
ADVOCARE "../9c/support.cct"
ADVOCARE "../../../../lib/civitas/media_delivery/delivery.cct"
ADVOCARE "../../../../lib/civitas/media_delivery/delivery_accel.cct"
ADVOCARE "../../../../lib/civitas/media_delivery/delivery_range.cct"
ADVOCARE "../../../../lib/civitas/request_core.cct"
ADVOCARE "../../../../lib/civitas/storage/storage.cct"
ADVOCARE "../../../../lib/civitas/storage/storage_url.cct"
ADVOCARE "cct/fs.cct"
ADVOCARE "cct/map.cct"
ADVOCARE "cct/media_store.cct"
ADVOCARE "cct/path.cct"
ADVOCARE "cct/result.cct"
ADVOCARE "cct/verbum.cct"

RITUALE phase9_9f_root(VERBUM test_name) REDDE VERBUM
  REDDE CONIURA phase9_tmp_dir(CONIURA concat("9f_", test_name))
EXPLICIT RITUALE

RITUALE phase9_9f_config(VERBUM root) REDDE StorageConfig
  REDDE CONIURA storage_config_make(
    CONIURA path_join(root, "media"),
    "/media",
    "/media/private",
    60,
    MEDIA_NAMING_UUID_WITH_EXT
  )
EXPLICIT RITUALE

RITUALE phase9_9f_open_store(VERBUM root) REDDE MediaStore
  EVOCA SPECULUM NIHIL open_res AD CONIURA storage_open(CONIURA phase9_9f_config(root))
  SI CONIURA result_is_err GENUS(MediaStore, VERBUM)(open_res)
    IACE CONIURA result_unwrap_err GENUS(MediaStore, VERBUM)(open_res)
  FIN SI
  REDDE CONIURA result_unwrap GENUS(MediaStore, VERBUM)(open_res)
EXPLICIT RITUALE

RITUALE phase9_9f_source_file(VERBUM root, VERBUM filename, VERBUM content) REDDE VERBUM
  EVOCA VERBUM uploads_dir AD CONIURA path_join(root, "uploads")
  EVOCA VERBUM source_path AD CONIURA path_join(uploads_dir, filename)
  CONIURA mkdir_all(uploads_dir)
  CONIURA write_all(source_path, content)
  REDDE source_path
EXPLICIT RITUALE

RITUALE phase9_9f_private_artifact(VERBUM root, VERBUM filename, VERBUM content) REDDE MediaArtifact
  EVOCA MediaStore store AD CONIURA phase9_9f_open_store(root)
  EVOCA VERBUM source_path AD CONIURA phase9_9f_source_file(root, filename, content)
  EVOCA SPECULUM NIHIL put_res AD CONIURA storage_put_tmp(store, source_path, filename)
  SI CONIURA result_is_err GENUS(MediaArtifact, VERBUM)(put_res)
    IACE CONIURA result_unwrap_err GENUS(MediaArtifact, VERBUM)(put_res)
  FIN SI
  EVOCA MediaArtifact tmp_artifact AD CONIURA result_unwrap GENUS(MediaArtifact, VERBUM)(put_res)
  EVOCA SPECULUM NIHIL promote_res AD CONIURA storage_promote(store, tmp_artifact, MEDIA_ZONE_PRIVATE)
  SI CONIURA result_is_err GENUS(MediaArtifact, VERBUM)(promote_res)
    IACE CONIURA result_unwrap_err GENUS(MediaArtifact, VERBUM)(promote_res)
  FIN SI
  REDDE CONIURA result_unwrap GENUS(MediaArtifact, VERBUM)(promote_res)
EXPLICIT RITUALE

RITUALE phase9_9f_registry() REDDE SPECULUM NIHIL
  REDDE CONIURA phase9_9c_registry("tmp-secret-active", "tmp-secret-previous")
EXPLICIT RITUALE

RITUALE phase9_9f_signed_cfg() REDDE SignedUrlConfig
  REDDE CONIURA signed_url_config_default("/media/private")
EXPLICIT RITUALE

RITUALE phase9_9f_direct_cfg() REDDE DeliveryConfig
  REDDE CONIURA delivery_config_new(DmDirect, "", 0, "inline")
EXPLICIT RITUALE

RITUALE phase9_9f_accel_cfg() REDDE DeliveryConfig
  REDDE CONIURA delivery_config_new(DmAccelRedirect, "/media-internal/", 0, "inline")
EXPLICIT RITUALE

RITUALE phase9_9f_sendfile_cfg() REDDE DeliveryConfig
  REDDE CONIURA delivery_config_new(DmSendfile, "", 0, "attachment")
EXPLICIT RITUALE

RITUALE phase9_9f_headers() REDDE SPECULUM NIHIL
  REDDE CONIURA map_init GENUS(VERBUM, VERBUM)()
EXPLICIT RITUALE

RITUALE phase9_9f_request(VERBUM target) REDDE WebRequest
  REDDE CONIURA phase9_request("GET", target, CONIURA phase9_headers(), "")
EXPLICIT RITUALE

RITUALE phase9_9f_request_with_path_artifact(VERBUM target, VERBUM artifact_id) REDDE WebRequest
  EVOCA WebRequest req AD CONIURA phase9_9f_request(target)
  EVOCA SPECULUM NIHIL params AD CONIURA map_init GENUS(VERBUM, VERBUM)()
  CONIURA map_insert GENUS(VERBUM, VERBUM)(params, "artifact_id", artifact_id)
  CONIURA request_set_path_params(SPECULUM req, params)
  REDDE req
EXPLICIT RITUALE

RITUALE phase9_9f_big_text() REDDE VERBUM
  EVOCA VERBUM out AD "0123456789"
  VINCIRE out AD CONIURA concat(out, "abcdefghij")
  VINCIRE out AD CONIURA concat(out, "KLMNOPQRST")
  VINCIRE out AD CONIURA concat(out, "uvwxyzABCD")
  VINCIRE out AD CONIURA concat(out, "EFGHIJKLMN")
  VINCIRE out AD CONIURA concat(out, "opqrstuvwx")
  VINCIRE out AD CONIURA concat(out, "YZ01234567")
  VINCIRE out AD CONIURA concat(out, "8901234567")
  VINCIRE out AD CONIURA concat(out, "abcdefghij")
  VINCIRE out AD CONIURA concat(out, "klmnopqrst")
  REDDE out
EXPLICIT RITUALE

EXPLICIT grimoire
