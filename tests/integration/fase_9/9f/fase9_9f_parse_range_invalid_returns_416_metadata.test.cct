INCIPIT grimoire "fase9_9f_parse_range_invalid_returns_416_metadata"

ADVOCARE "support.cct"
ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/media_delivery/delivery.cct"
ADVOCARE "../../../../lib/civitas/media_delivery/delivery_range.cct"
ADVOCARE "../../../../lib/civitas/response.cct"
ADVOCARE "cct/fs.cct"
ADVOCARE "cct/fmt.cct"
ADVOCARE "cct/map.cct"
ADVOCARE "cct/result.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE NIHIL
  EVOCA VERBUM root AD CONIURA phase9_9f_root("invalid_range")
  CONIURA phase9_reset_dir(root)
  EVOCA VERBUM path AD CONIURA phase9_9f_source_file(root, "data.txt", CONIURA phase9_9f_big_text())
  EVOCA SPECULUM NIHIL headers AD CONIURA phase9_9f_headers()
  CONIURA map_insert GENUS(VERBUM, VERBUM)(headers, "range", "bytes=999-1200")
  EVOCA SPECULUM NIHIL serve_res AD CONIURA delivery_serve_direct(path, "text/plain", CONIURA phase9_9f_direct_cfg(), headers)
  SI CONIURA result_is_err GENUS(WebResponse, DeliveryError)(serve_res)
    IACE "invalid range should return 416 response, not hard error"
  FIN SI
  EVOCA WebResponse res AD CONIURA result_unwrap GENUS(WebResponse, DeliveryError)(serve_res)
  SI res.status != 416
    IACE "invalid range should return 416"
  FIN SI
  SI CONIURA compare(CONIURA response_header_or(res, "content-range", ""), CONIURA concat("bytes */", CONIURA stringify_int(CONIURA size(path)))) != 0
    IACE "416 response should include bytes */TOTAL"
  FIN SI
EXPLICIT RITUALE

EXPLICIT grimoire
