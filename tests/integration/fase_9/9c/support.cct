INCIPIT grimoire "fase9_9c_support"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/core/keyring.cct"
ADVOCARE "../../../../lib/civitas/core/secrets.cct"
ADVOCARE "../../../../lib/civitas/core/settings.cct"
ADVOCARE "../../../../lib/civitas/core/settings_schema.cct"
ADVOCARE "../../../../lib/civitas/storage/storage.cct"
ADVOCARE "../../../../lib/civitas/storage/storage_gc.cct"
ADVOCARE "../../../../lib/civitas/storage/storage_url.cct"
ADVOCARE "cct/fs.cct"
ADVOCARE "cct/fluxus.cct"
ADVOCARE "cct/media_store.cct"
ADVOCARE "cct/path.cct"
ADVOCARE "cct/result.cct"
ADVOCARE "cct/verbum.cct"

RITUALE phase9_9c_root(VERBUM test_name) REDDE VERBUM
  REDDE CONIURA phase9_tmp_dir(CONIURA concat("9c_", test_name))
EXPLICIT RITUALE

RITUALE phase9_9c_source_file(VERBUM root, VERBUM filename, VERBUM content) REDDE VERBUM
  EVOCA VERBUM uploads_dir AD CONIURA path_join(root, "uploads")
  EVOCA VERBUM source_path AD CONIURA path_join(uploads_dir, filename)
  CONIURA mkdir_all(uploads_dir)
  CONIURA write_all(source_path, content)
  REDDE source_path
EXPLICIT RITUALE

RITUALE phase9_9c_config(VERBUM root) REDDE StorageConfig
  REDDE CONIURA storage_config_make(
    CONIURA path_join(root, "media"),
    "/media",
    "/media/private",
    60,
    MEDIA_NAMING_UUID_WITH_EXT
  )
EXPLICIT RITUALE

RITUALE phase9_9c_open_store(VERBUM root) REDDE MediaStore
  EVOCA SPECULUM NIHIL open_res AD CONIURA storage_open(CONIURA phase9_9c_config(root))
  SI CONIURA result_is_err GENUS(MediaStore, VERBUM)(open_res)
    IACE CONIURA result_unwrap_err GENUS(MediaStore, VERBUM)(open_res)
  FIN SI
  REDDE CONIURA result_unwrap GENUS(MediaStore, VERBUM)(open_res)
EXPLICIT RITUALE

RITUALE phase9_9c_put_tmp(VERBUM root, VERBUM filename, VERBUM content) REDDE MediaArtifact
  EVOCA MediaStore store AD CONIURA phase9_9c_open_store(root)
  EVOCA VERBUM source_path AD CONIURA phase9_9c_source_file(root, filename, content)
  EVOCA SPECULUM NIHIL put_res AD CONIURA storage_put_tmp(store, source_path, filename)
  SI CONIURA result_is_err GENUS(MediaArtifact, VERBUM)(put_res)
    IACE CONIURA result_unwrap_err GENUS(MediaArtifact, VERBUM)(put_res)
  FIN SI
  REDDE CONIURA result_unwrap GENUS(MediaArtifact, VERBUM)(put_res)
EXPLICIT RITUALE

RITUALE phase9_9c_load_settings(VERBUM root, VERBUM content) REDDE Settings
  EVOCA VERBUM config_path AD CONIURA path_join(root, "civitas.toml")
  EVOCA SPECULUM NIHIL load_res
  CONIURA phase9_reset_dir(root)
  CONIURA write_all(config_path, content)
  VINCIRE load_res AD CONIURA settings_load(root)
  SI CONIURA result_is_err GENUS(Settings, SettingsError)(load_res)
    IACE CONIURA settings_error_message(CONIURA result_unwrap_err GENUS(Settings, SettingsError)(load_res))
  FIN SI
  REDDE CONIURA result_unwrap GENUS(Settings, SettingsError)(load_res)
EXPLICIT RITUALE

RITUALE phase9_9c_registry(VERBUM active_secret, VERBUM previous_secret) REDDE SPECULUM NIHIL
  EVOCA SecretRegistry registry
  EVOCA SPECULUM NIHIL registry_ptr AD OBSECRO mem_alloc(MENSURA(SecretRegistry))
  EVOCA SecretKeyRing session_ring AD CONIURA secret_keyring_disabled(SECRET_DOMAIN_SESSION, FALSUM, "")
  EVOCA SecretKeyRing csrf_ring AD CONIURA secret_keyring_disabled(SECRET_DOMAIN_CSRF, FALSUM, "")
  EVOCA SecretKeyRing signed_cookie_ring AD CONIURA secret_keyring_disabled(SECRET_DOMAIN_SIGNED_COOKIE, FALSUM, "")
  EVOCA SecretKeyRing token_ring AD CONIURA secret_keyring_disabled(SECRET_DOMAIN_TOKEN, FALSUM, "")
  EVOCA SecretKeyRing temporary_link_ring AD CONIURA secret_keyring_disabled(SECRET_DOMAIN_TEMPORARY_LINK, FALSUM, "")
  EVOCA SecretKey active_key AD CONIURA secret_key_make("tmp_current", active_secret, "test", "", "active")

  CONIURA secret_keyring_fill_from_ptr(SPECULUM registry.session, SPECULUM session_ring)
  CONIURA secret_keyring_fill_from_ptr(SPECULUM registry.csrf, SPECULUM csrf_ring)
  CONIURA secret_keyring_fill_from_ptr(SPECULUM registry.signed_cookie, SPECULUM signed_cookie_ring)
  CONIURA secret_keyring_fill_from_ptr(SPECULUM registry.token, SPECULUM token_ring)
  CONIURA secret_keyring_fill_from_ptr(SPECULUM registry.temporary_link, SPECULUM temporary_link_ring)
  VINCIRE registry.legacy_global_key_enabled AD FALSUM
  VINCIRE registry.temporary_link.enabled AD VERUM
  VINCIRE registry.temporary_link.active_key AD active_key
  VINCIRE registry.temporary_link.rotation_policy AD CONIURA secret_rotation_policy_make(300, 1, FALSUM, "")
  VINCIRE registry.temporary_link.verify_candidates AD CONIURA fluxus_init(MENSURA(SecretKey))

  EVOCA SPECULUM SecretKey active_key_ptr AD OBSECRO mem_alloc(MENSURA(SecretKey))
  CONIURA secret_key_fill(active_key_ptr, active_key)
  CONIURA fluxus_push(registry.temporary_link.verify_candidates, active_key_ptr)

  SI CONIURA len(previous_secret) != 0
    EVOCA SecretKey previous_key AD CONIURA secret_key_make("tmp_previous", previous_secret, "test", "", "previous")
    EVOCA SPECULUM SecretKey previous_key_ptr AD OBSECRO mem_alloc(MENSURA(SecretKey))
    CONIURA secret_key_fill(previous_key_ptr, previous_key)
    CONIURA fluxus_push(registry.temporary_link.verify_candidates, previous_key_ptr)
  FIN SI

  CONIURA secret_registry_fill_from_opaque(registry_ptr, registry)
  REDDE registry_ptr
EXPLICIT RITUALE

RITUALE phase9_9c_gc_checker_drop_all(VERBUM artifact_id) REDDE VERUM
  REDDE FALSUM
EXPLICIT RITUALE

RITUALE phase9_9c_gc_checker_keep_marked(VERBUM artifact_id) REDDE VERUM
  REDDE CONIURA starts_with(artifact_id, "keep")
EXPLICIT RITUALE

EXPLICIT grimoire
