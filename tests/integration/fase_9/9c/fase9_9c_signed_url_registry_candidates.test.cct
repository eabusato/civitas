INCIPIT grimoire "fase9_9c_signed_url_registry_candidates"

ADVOCARE "support.cct"
ADVOCARE "../../../../lib/civitas/storage/storage.cct"
ADVOCARE "../../../../lib/civitas/storage/storage_url.cct"
ADVOCARE "cct/media_store.cct"
ADVOCARE "cct/result.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE NIHIL
  EVOCA VERBUM root AD CONIURA phase9_9c_root("registry_candidates")
  EVOCA MediaStore store AD CONIURA phase9_9c_open_store(root)
  EVOCA SPECULUM NIHIL registry_ref AD CONIURA phase9_9c_registry("active-secret", "previous-secret")
  EVOCA MediaArtifact artifact AD CONIURA phase9_9c_put_tmp(root, "hidden.txt", "hidden")
  EVOCA SPECULUM NIHIL promote_res AD CONIURA storage_promote(store, artifact, MEDIA_ZONE_PRIVATE)
  SI CONIURA result_is_err GENUS(MediaArtifact, VERBUM)(promote_res)
    IACE CONIURA result_unwrap_err GENUS(MediaArtifact, VERBUM)(promote_res)
  FIN SI
  EVOCA MediaArtifact private_artifact AD CONIURA result_unwrap GENUS(MediaArtifact, VERBUM)(promote_res)
  EVOCA SignedUrlConfig cfg AD CONIURA signed_url_config_default("/media/private")
  EVOCA SPECULUM NIHIL signed_res AD CONIURA storage_sign_url_from_registry(cfg, registry_ref, private_artifact, 1700000000)
  SI CONIURA result_is_err GENUS(SignedUrl, VERBUM)(signed_res)
    IACE CONIURA result_unwrap_err GENUS(SignedUrl, VERBUM)(signed_res)
  FIN SI
  EVOCA SignedUrl active_signed AD CONIURA result_unwrap GENUS(SignedUrl, VERBUM)(signed_res)
  EVOCA SignedUrl previous_signed AD CONIURA storage_sign_url(cfg, "previous-secret", private_artifact, 1700000300)

  SI NON CONIURA storage_verify_signed_url_candidates(registry_ref, cfg, private_artifact.artifact_id, active_signed.token, active_signed.expires_unix, 1700000001)
    IACE "active registry key should verify"
  FIN SI
  SI NON CONIURA storage_verify_signed_url_candidates(registry_ref, cfg, private_artifact.artifact_id, previous_signed.token, previous_signed.expires_unix, 1700000001)
    IACE "previous registry key should also verify"
  FIN SI
EXPLICIT RITUALE

EXPLICIT grimoire
