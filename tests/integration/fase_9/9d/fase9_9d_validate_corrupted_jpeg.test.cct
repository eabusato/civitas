INCIPIT grimoire "fase9_9d_validate_corrupted_jpeg"

ADVOCARE "support.cct"
ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/media_image/image.cct"
ADVOCARE "../../../../lib/civitas/media_image/image_types.cct"
ADVOCARE "cct/filetype.cct"
ADVOCARE "cct/fs.cct"
ADVOCARE "cct/result.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE NIHIL
  EVOCA VERBUM root AD CONIURA phase9_9d_root("validate_corrupted")
  EVOCA VERBUM file_path AD CONIURA concat(root, "/broken.jpg")
  CONIURA phase9_reset_dir(root)
  CONIURA mkdir_all(root)
  CONIURA write_all(file_path, CONIURA phase9_fake_jpeg())

  EVOCA SPECULUM NIHIL res AD CONIURA image_validate(file_path, 2048)
  SI NON CONIURA result_is_err GENUS(FileType, ImageValidateError)(res)
    IACE "fake jpeg should be rejected as corrupted"
  FIN SI
  SI CONIURA result_unwrap_err GENUS(FileType, ImageValidateError)(res) != IveCorrupted
    IACE "expected IveCorrupted"
  FIN SI
EXPLICIT RITUALE

EXPLICIT grimoire
