INCIPIT grimoire "fase5_5a_rate_limiter_refill_test"

ADVOCARE "../../../../lib/civitas/security.cct"
ADVOCARE "cct/time.cct"

RITUALE main() REDDE REX
  EVOCA RateLimiter limiter AD CONIURA rate_limiter_new(5, 1)
  SI NON CONIURA rate_limiter_check(SPECULUM limiter, "10.0.0.1")
    REDDE 1
  FIN SI
  SI CONIURA rate_limiter_check(SPECULUM limiter, "10.0.0.1")
    REDDE 2
  FIN SI
  SI NON CONIURA rate_limiter_check(SPECULUM limiter, "10.0.0.2")
    REDDE 3
  FIN SI
  CONIURA sleep_ms(250)
  SI NON CONIURA rate_limiter_check(SPECULUM limiter, "10.0.0.1")
    REDDE 4
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
