INCIPIT grimoire "mural_expandido_example_actions_smoke_test"

ADVOCARE "../../fase_1/support/common.cct"
ADVOCARE "cct/fmt.cct"
ADVOCARE "cct/fs.cct"
ADVOCARE "cct/http.cct"
ADVOCARE "cct/path.cct"
ADVOCARE "cct/process.cct"
ADVOCARE "cct/socket.cct"
ADVOCARE "cct/time.cct"
ADVOCARE "cct/verbum.cct"

RITUALE muralx_actions_root() REDDE VERBUM
  REDDE "tests/tmp/examples/mural_expandido/actions_smoke"
EXPLICIT RITUALE

RITUALE muralx_actions_file(VERBUM name) REDDE VERBUM
  REDDE CONIURA path_join(CONIURA muralx_actions_root(), name)
EXPLICIT RITUALE

RITUALE muralx_actions_db_path() REDDE VERBUM
  REDDE CONIURA resolve(CONIURA path_join(CONIURA muralx_actions_root(), "mural_expandido.db"))
EXPLICIT RITUALE

RITUALE muralx_actions_cleanup_file(VERBUM path) REDDE NIHIL
  CONIURA run(CONIURA concat("rm -f ", path))
  REDDE
EXPLICIT RITUALE

RITUALE muralx_actions_stop_existing_server() REDDE NIHIL
  EVOCA VERBUM pid_path AD CONIURA muralx_actions_file("pid.txt")
  EVOCA VERBUM cmd AD ""
  SI CONIURA exists(pid_path)
    VINCIRE cmd AD "kill -0 "
    VINCIRE cmd AD CONIURA concat(cmd, CONIURA trim(CONIURA read_all(pid_path)))
    VINCIRE cmd AD CONIURA concat(cmd, " >/dev/null 2>&1 && kill -TERM ")
    VINCIRE cmd AD CONIURA concat(cmd, CONIURA trim(CONIURA read_all(pid_path)))
    VINCIRE cmd AD CONIURA concat(cmd, " >/dev/null 2>&1 || true")
    CONIURA run(cmd)
    CONIURA sleep_ms(250)
    CONIURA muralx_actions_cleanup_file(pid_path)
  FIN SI
  REDDE
EXPLICIT RITUALE

RITUALE muralx_actions_pick_port() REDDE REX
  REDDE 25000 + (CONIURA now_ms() % 5000)
EXPLICIT RITUALE

RITUALE muralx_status_line(VERBUM raw_response) REDDE VERBUM
  EVOCA REX crlf_idx AD CONIURA find(raw_response, CONIURA crlf())
  SI crlf_idx == -1
    REDDE raw_response
  FIN SI
  REDDE CONIURA substring(raw_response, 0, crlf_idx)
EXPLICIT RITUALE

RITUALE muralx_header_value(VERBUM raw_response, VERBUM header_name) REDDE VERBUM
  EVOCA VERBUM lower_raw AD CONIURA to_lower(raw_response)
  EVOCA VERBUM marker AD CONIURA concat(CONIURA to_lower(header_name), ": ")
  EVOCA REX idx AD CONIURA find(lower_raw, marker)
  SI idx == -1
    REDDE ""
  FIN SI
  EVOCA REX start AD idx + CONIURA len(marker)
  EVOCA REX end_idx AD CONIURA find(CONIURA substring(raw_response, start, CONIURA len(raw_response)), CONIURA crlf())
  SI end_idx == -1
    REDDE CONIURA substring(raw_response, start, CONIURA len(raw_response))
  FIN SI
  REDDE CONIURA substring(raw_response, start, start + end_idx)
EXPLICIT RITUALE

RITUALE muralx_extract_cookie_value(VERBUM set_cookie_header, VERBUM cookie_name) REDDE VERBUM
  EVOCA VERBUM prefix AD CONIURA concat(cookie_name, "=")
  EVOCA REX semi AD 0
  SI NON CONIURA starts_with(set_cookie_header, prefix)
    REDDE ""
  FIN SI
  VINCIRE semi AD CONIURA find(set_cookie_header, ";")
  SI semi == -1
    REDDE CONIURA substring(set_cookie_header, CONIURA len(prefix), CONIURA len(set_cookie_header))
  FIN SI
  REDDE CONIURA substring(set_cookie_header, CONIURA len(prefix), semi)
EXPLICIT RITUALE

RITUALE muralx_raw_http(REX port, VERBUM payload) REDDE VERBUM
  EVOCA SPECULUM NIHIL sock AD CONIURA open_local_socket_with_timeout(port, 1500)
  SI CONIURA send_raw(sock, payload) != 0
    IACE "failed to send raw request"
  FIN SI
  REDDE CONIURA http_read_response_raw(sock)
EXPLICIT RITUALE

RITUALE muralx_post_request(VERBUM path, VERBUM cookie_value, VERBUM body) REDDE VERBUM
  EVOCA VERBUM out AD CONIURA concat("POST ", path)
  VINCIRE out AD CONIURA concat(out, " HTTP/1.1")
  VINCIRE out AD CONIURA concat(out, CONIURA crlf())
  VINCIRE out AD CONIURA concat(out, "Host: 127.0.0.1")
  VINCIRE out AD CONIURA concat(out, CONIURA crlf())
  VINCIRE out AD CONIURA concat(out, "Connection: close")
  VINCIRE out AD CONIURA concat(out, CONIURA crlf())
  VINCIRE out AD CONIURA concat(out, "Authorization: Basic YWRtaW46Y2hhbmdlLW1lLWV4cGFuZGVkLWFkbWluLXNlY3JldA==")
  VINCIRE out AD CONIURA concat(out, CONIURA crlf())
  VINCIRE out AD CONIURA concat(out, "Content-Type: application/x-www-form-urlencoded")
  VINCIRE out AD CONIURA concat(out, CONIURA crlf())
  VINCIRE out AD CONIURA concat(out, "Content-Length: ")
  VINCIRE out AD CONIURA concat(out, CONIURA stringify_int(CONIURA len(body)))
  VINCIRE out AD CONIURA concat(out, CONIURA crlf())
  VINCIRE out AD CONIURA concat(out, "Cookie: muralx_session=")
  VINCIRE out AD CONIURA concat(out, cookie_value)
  VINCIRE out AD CONIURA concat(out, CONIURA crlf())
  VINCIRE out AD CONIURA concat(out, CONIURA crlf())
  VINCIRE out AD CONIURA concat(out, body)
  REDDE out
EXPLICIT RITUALE

RITUALE muralx_get_request(VERBUM path, VERBUM cookie_value) REDDE VERBUM
  EVOCA VERBUM out AD CONIURA concat("GET ", path)
  VINCIRE out AD CONIURA concat(out, " HTTP/1.1")
  VINCIRE out AD CONIURA concat(out, CONIURA crlf())
  VINCIRE out AD CONIURA concat(out, "Host: 127.0.0.1")
  VINCIRE out AD CONIURA concat(out, CONIURA crlf())
  VINCIRE out AD CONIURA concat(out, "Connection: keep-alive")
  VINCIRE out AD CONIURA concat(out, CONIURA crlf())
  VINCIRE out AD CONIURA concat(out, "Authorization: Basic YWRtaW46Y2hhbmdlLW1lLWV4cGFuZGVkLWFkbWluLXNlY3JldA==")
  VINCIRE out AD CONIURA concat(out, CONIURA crlf())
  VINCIRE out AD CONIURA concat(out, "Cookie: muralx_session=")
  VINCIRE out AD CONIURA concat(out, cookie_value)
  VINCIRE out AD CONIURA concat(out, CONIURA crlf())
  VINCIRE out AD CONIURA concat(out, CONIURA crlf())
  REDDE out
EXPLICIT RITUALE

RITUALE muralx_compile_or_fail(VERBUM source_path, VERBUM log_name) REDDE NIHIL
  EVOCA VERBUM cmd AD CONIURA concat(CONIURA compiler_bin(), " ")
  VINCIRE cmd AD CONIURA concat(cmd, source_path)
  SI CONIURA run_to_log(cmd, CONIURA muralx_actions_file(log_name)) != 0
    IACE CONIURA concat("compile failed: ", source_path)
  FIN SI
  REDDE
EXPLICIT RITUALE

RITUALE muralx_prepare() REDDE NIHIL
  CONIURA mkdir_all(CONIURA muralx_actions_root())
  CONIURA muralx_actions_stop_existing_server()
  CONIURA muralx_actions_cleanup_file(CONIURA muralx_actions_file("ready.txt"))
  CONIURA muralx_actions_cleanup_file(CONIURA muralx_actions_file("done.txt"))
  CONIURA muralx_actions_cleanup_file(CONIURA muralx_actions_file("pid.txt"))
  CONIURA muralx_actions_cleanup_file(CONIURA muralx_actions_db_path())
  REDDE
EXPLICIT RITUALE

RITUALE muralx_bootstrap_db() REDDE NIHIL
  EVOCA VERBUM cmd AD "MURAL_EXPANDIDO_PROJECT_ROOT=examples/mural_expandido MURAL_EXPANDIDO_DATABASE_PATH="
  VINCIRE cmd AD CONIURA concat(cmd, CONIURA muralx_actions_db_path())
  VINCIRE cmd AD CONIURA concat(cmd, " ./examples/mural_expandido/bootstrap_db >")
  VINCIRE cmd AD CONIURA concat(cmd, CONIURA muralx_actions_file("bootstrap_run.log"))
  VINCIRE cmd AD CONIURA concat(cmd, " 2>&1")
  SI CONIURA run(cmd) != 0
    IACE "bootstrap_db failed"
  FIN SI
  REDDE
EXPLICIT RITUALE

RITUALE muralx_start_server(REX port) REDDE NIHIL
  EVOCA VERBUM cmd AD "MURAL_EXPANDIDO_PROJECT_ROOT=examples/mural_expandido"
  VINCIRE cmd AD CONIURA concat(cmd, " MURAL_EXPANDIDO_DATABASE_PATH=")
  VINCIRE cmd AD CONIURA concat(cmd, CONIURA muralx_actions_db_path())
  VINCIRE cmd AD CONIURA concat(cmd, " CIVITAS_HTTP__HOST=127.0.0.1")
  VINCIRE cmd AD CONIURA concat(cmd, " CIVITAS_HTTP__PORT=")
  VINCIRE cmd AD CONIURA concat(cmd, CONIURA stringify_int(port))
  VINCIRE cmd AD CONIURA concat(cmd, " CIVITAS_APP__ALLOWED_HOSTS=127.0.0.1,localhost")
  VINCIRE cmd AD CONIURA concat(cmd, " CIVITAS_READY_FILE=")
  VINCIRE cmd AD CONIURA concat(cmd, CONIURA muralx_actions_file("ready.txt"))
  VINCIRE cmd AD CONIURA concat(cmd, " CIVITAS_DONE_FILE=")
  VINCIRE cmd AD CONIURA concat(cmd, CONIURA muralx_actions_file("done.txt"))
  VINCIRE cmd AD CONIURA concat(cmd, " CIVITAS_MAX_REQUESTS=5")
  VINCIRE cmd AD CONIURA concat(cmd, " ./examples/mural_expandido/main")
  SI CONIURA spawn_to_log_with_pid(cmd, CONIURA muralx_actions_file("server.log"), CONIURA muralx_actions_file("pid.txt")) != 0
    IACE "failed to start mural_expandido server"
  FIN SI
  SI NON CONIURA wait_for_file(CONIURA muralx_actions_file("ready.txt"), 4000)
    IACE "mural_expandido server did not become ready"
  FIN SI
  CONIURA sleep_ms(150)
  REDDE
EXPLICIT RITUALE

RITUALE main() REDDE REX
  EVOCA REX port AD CONIURA muralx_actions_pick_port()
  EVOCA VERBUM raw_home AD ""
  EVOCA VERBUM raw_login AD ""
  EVOCA VERBUM raw_like AD ""
  EVOCA VERBUM raw_home_after_login AD ""
  EVOCA VERBUM raw_post_after_like AD ""
  EVOCA VERBUM cookie_value AD ""
  EVOCA VERBUM login_cookie AD ""
  EVOCA VERBUM login_body AD "email=admin%40mural.expandido&password=abc123"

  CONIURA muralx_prepare()
  CONIURA muralx_compile_or_fail("examples/mural_expandido/bootstrap_db.cct", "bootstrap_build.log")
  CONIURA muralx_bootstrap_db()
  CONIURA muralx_compile_or_fail("examples/mural_expandido/main.cct", "main_build.log")
  CONIURA muralx_start_server(port)

  VINCIRE raw_home AD CONIURA muralx_raw_http(
    port,
    CONIURA concat("GET / HTTP/1.1", CONIURA concat(CONIURA crlf(), CONIURA concat("Host: 127.0.0.1", CONIURA concat(CONIURA crlf(), CONIURA concat("Connection: close", CONIURA concat(CONIURA crlf(), CONIURA concat(CONIURA crlf(), "")))))))
  )
  SI CONIURA compare(CONIURA muralx_status_line(raw_home), "HTTP/1.1 200 OK") != 0
    IACE "expected 200 OK on home before actions"
  FIN SI
  VINCIRE cookie_value AD CONIURA muralx_extract_cookie_value(CONIURA muralx_header_value(raw_home, "set-cookie"), "muralx_session")
  SI CONIURA len(cookie_value) == 0
    IACE "home should issue session cookie before login"
  FIN SI

  VINCIRE raw_login AD CONIURA muralx_raw_http(
    port,
    CONIURA muralx_post_request("/entrar", cookie_value, login_body)
  )
  CONIURA write_all(CONIURA muralx_actions_file("raw_login.txt"), raw_login)
  SI CONIURA compare(CONIURA muralx_status_line(raw_login), "HTTP/1.1 302 Found") != 0
    IACE "expected 302 Found on login"
  FIN SI
  SI CONIURA find(CONIURA to_lower(raw_login), "location: /") == -1
    IACE "login should redirect to /"
  FIN SI
  VINCIRE login_cookie AD CONIURA muralx_extract_cookie_value(CONIURA muralx_header_value(raw_login, "set-cookie"), "muralx_session")
  SI CONIURA len(login_cookie) == 0
    VINCIRE login_cookie AD cookie_value
  FIN SI

  VINCIRE raw_home_after_login AD CONIURA muralx_raw_http(
    port,
    CONIURA muralx_get_request("/", login_cookie)
  )
  CONIURA write_all(CONIURA muralx_actions_file("raw_home_after_login.txt"), raw_home_after_login)
  SI CONIURA compare(CONIURA muralx_status_line(raw_home_after_login), "HTTP/1.1 200 OK") != 0
    IACE "expected 200 OK on home after login redirect target"
  FIN SI
  SI CONIURA find(raw_home_after_login, "Signed in.") == -1
    IACE "expected flash banner after login redirect target"
  FIN SI

  VINCIRE raw_like AD CONIURA muralx_raw_http(
    port,
    CONIURA muralx_post_request("/posts/neon-bridge-session/reagir/like", login_cookie, "")
  )
  CONIURA write_all(CONIURA muralx_actions_file("raw_like.txt"), raw_like)
  SI CONIURA compare(CONIURA muralx_status_line(raw_like), "HTTP/1.1 302 Found") != 0
    IACE "expected 302 Found on like action"
  FIN SI
  SI CONIURA find(CONIURA to_lower(raw_like), "location: /posts/neon-bridge-session") == -1
    IACE "like should redirect back to the post detail"
  FIN SI

  VINCIRE raw_post_after_like AD CONIURA muralx_raw_http(
    port,
    CONIURA muralx_get_request("/posts/neon-bridge-session", login_cookie)
  )
  CONIURA write_all(CONIURA muralx_actions_file("raw_post_after_like.txt"), raw_post_after_like)
  SI CONIURA compare(CONIURA muralx_status_line(raw_post_after_like), "HTTP/1.1 200 OK") != 0
    IACE "expected 200 OK on post detail after like redirect target"
  FIN SI
  SI CONIURA find(raw_post_after_like, "Neon bridge session") == -1
    IACE "post detail after like should remain renderable"
  FIN SI

  SI NON CONIURA wait_for_file(CONIURA muralx_actions_file("done.txt"), 3000)
    IACE "server did not finish after action flow"
  FIN SI
  SI CONIURA compare(CONIURA trim(CONIURA read_all(CONIURA muralx_actions_file("done.txt"))), "ok") != 0
    IACE "server did not finish cleanly after action flow"
  FIN SI

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
