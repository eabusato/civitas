INCIPIT grimoire "fase7_7e_class_merge_test"

ADVOCARE "support.cct"
ADVOCARE "../7c/support.cct"
ADVOCARE "../../../../lib/civitas/forms/forms.cct"
ADVOCARE "../../../../lib/civitas/forms/render.cct"
ADVOCARE "../../../../lib/civitas/validate/validate.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA FieldDef field AD CONIURA field_def_new("email", "E-mail", IkEmail)
  EVOCA FormData fd AD CONIURA phase7_render_form_data()
  EVOCA ValidationResult vr AD CONIURA phase7_render_validation_ok()
  EVOCA VERBUM html

  VINCIRE field.css_class AD "wide"
  CONIURA field_def_add_wrapper_attr(SPECULUM field, "class", "js-enhanced")
  VINCIRE html AD CONIURA render_field(field, vr, fd)

  SI CONIURA find(html, "form-group wide js-enhanced") == -1
    REDDE 1
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
