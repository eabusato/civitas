INCIPIT grimoire "fase7_7c_password_and_csrf_test"

ADVOCARE "support.cct"
ADVOCARE "../../../../lib/civitas/forms/forms.cct"
ADVOCARE "../../../../lib/civitas/forms/render.cct"
ADVOCARE "../../../../lib/civitas/validate/validate.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA FormData fd AD CONIURA phase7_render_form_data()
  EVOCA ValidationResult vr AD CONIURA phase7_render_validation_ok()
  EVOCA FormDef def AD CONIURA form_def_new("/cadastro", CONIURA phase7_render_csrf("\"<abc>&"))
  EVOCA FieldDef senha AD CONIURA field_def_new("senha", "Senha", IkPassword)
  EVOCA VERBUM html

  CONIURA form_data_put_text(SPECULUM fd, "senha", "s3cr3t0!")
  CONIURA form_def_add_field(SPECULUM def, senha)
  VINCIRE html AD CONIURA render_form(def, vr, fd)

  SI CONIURA find(html, "name=\"civitas_csrf_token\"") == -1
    REDDE 1
  FIN SI
  SI CONIURA find(html, "&quot;&lt;abc&gt;&amp;") == -1
    REDDE 2
  FIN SI
  SI CONIURA find(html, "type=\"password\"") == -1
    REDDE 3
  FIN SI
  SI CONIURA find(html, "value=\"s3cr3t0!\"") != -1
    REDDE 4
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
