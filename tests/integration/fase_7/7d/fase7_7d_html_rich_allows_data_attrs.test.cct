INCIPIT grimoire "fase7_7d_html_rich_allows_data_attrs_test"

ADVOCARE "support.cct"
ADVOCARE "../../../../lib/civitas/sanitize/html.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA HtmlAllowList al AD CONIURA allowlist_rich()
  EVOCA HtmlSanitizeConfig cfg AD CONIURA html_sanitize_config_default(al)
  EVOCA VERBUM raw AD "<span data-mask='cpf' aria-label='CPF' onclick='evil()'>123</span>"
  EVOCA VERBUM clean AD CONIURA html_sanitize(raw, cfg)
  CONIURA html_sanitize_config_free(SPECULUM cfg)

  SI CONIURA find(clean, "data-mask=\"cpf\"") == -1
    REDDE 1
  FIN SI
  SI CONIURA find(clean, "aria-label=\"CPF\"") == -1
    REDDE 2
  FIN SI
  SI CONIURA find(clean, "onclick") != -1
    REDDE 3
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
