INCIPIT grimoire "fase7_7d_embed_policy_exact_host_test"

ADVOCARE "support.cct"
ADVOCARE "../../../../lib/civitas/sanitize/url.cct"

RITUALE main() REDDE REX
  EVOCA EmbedPolicy policy AD CONIURA embed_policy_default()
  EVOCA EmbedCheckResult ok AD CONIURA embed_check("https://www.youtube.com/watch?v=abc", policy)
  EVOCA EmbedCheckResult bad_host AD CONIURA embed_check("https://youtube.com.evil.com/watch?v=abc", policy)
  EVOCA EmbedCheckResult bad_scheme AD CONIURA embed_check("http://www.youtube.com/watch?v=abc", policy)
  CONIURA embed_policy_free(SPECULUM policy)

  SI ok != EcrAllowed
    REDDE 1
  FIN SI
  SI bad_host != EcrDomainNotAllowed
    REDDE 2
  FIN SI
  SI bad_scheme != EcrSchemeNotAllowed
    REDDE 3
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
