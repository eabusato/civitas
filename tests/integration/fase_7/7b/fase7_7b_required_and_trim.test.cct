INCIPIT grimoire "fase7_7b_required_and_trim_test"

ADVOCARE "support.cct"
ADVOCARE "../../../../lib/civitas/forms/forms.cct"
ADVOCARE "../../../../lib/civitas/validate/validate.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA FormSchema schema AD CONIURA form_schema_new()
  EVOCA FieldSchema fs AD CONIURA field_schema_new("nome")
  EVOCA FormData fd AD CONIURA phase7_validation_fd()

  CONIURA field_schema_add_rule(SPECULUM fs, CONIURA rule_required())
  CONIURA form_schema_add_field(SPECULUM schema, fs)
  CONIURA phase7_validation_put(SPECULUM fd, "nome", "   ")
  EVOCA ValidationResult vr AD CONIURA validate_form(schema, fd)

  SI CONIURA phase7_validation_error_count(vr, "nome") != 1
    REDDE 1
  FIN SI
  SI CONIURA compare(CONIURA validation_default_message(VrkRequired, CONIURA rule_required()), "Este campo e obrigatorio.") != 0
    REDDE 2
  FIN SI
  SI CONIURA compare(CONIURA validation_first_error(vr, "nome"), "Este campo e obrigatorio.") != 0
    REDDE 3
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
