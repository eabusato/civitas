INCIPIT grimoire "fase7_7b_sanitize_helpers_test"

ADVOCARE "../../../../lib/civitas/validate/sanitize.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  SI CONIURA compare(CONIURA sanitize_trim("  Ana  "), "Ana") != 0
    REDDE 1
  FIN SI
  SI CONIURA compare(CONIURA sanitize_normalize_email("  USER@Example.COM "), "user@example.com") != 0
    REDDE 2
  FIN SI
  SI CONIURA compare(CONIURA sanitize_strip_tags("<b>ola</b><script>x</script>"), "olax") != 0
    REDDE 3
  FIN SI
  SI CONIURA compare(CONIURA sanitize_normalize_spaces("  Ana   Maria \n  Silva\t"), "Ana Maria Silva") != 0
    REDDE 4
  FIN SI
  SI CONIURA compare(CONIURA sanitize_upper("abc"), "ABC") != 0
    REDDE 5
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
