INCIPIT grimoire "fase19_19d_static_pages"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/seo/seo.cct"
ADVOCARE "../../../../lib/civitas/request_core.cct"
ADVOCARE "../../../../lib/civitas/response.cct"
ADVOCARE "cct/verbum.cct"

RITUALE test_static_page_handler() REDDE NIHIL
  EVOCA Phase19Stack stack AD CONIURA phase19_stack_open("19d_static")
  EVOCA SeoPublicConfig cfg AD CONIURA seo_public_config_default("https://example.test")
  EVOCA SeoStaticPage page
  CONIURA seo_schema_up(stack.db)
  VINCIRE page.path AD "/privacy"
  VINCIRE page.template_name AD "privacy"
  VINCIRE page.title AD "Privacy"
  VINCIRE page.meta_description AD "Policy"
  VINCIRE page.canonical_override AD ""
  VINCIRE page.locale AD "en"
  VINCIRE page.published AD VERUM
  CONIURA seo_static_page_upsert(stack.db, page)
  EVOCA WebRequest req AD CONIURA phase19_request("GET", "/privacy", "")
  EVOCA WebResponse res AD CONIURA seo_static_page_handler(stack.db, cfg, req)
  SI res.status != 200 VEL CONIURA find(res.body, "<h1>Privacy</h1>") == -1
    IACE "static page handler mismatch"
  FIN SI
  CONIURA phase19_stack_close(stack)
  REDDE
EXPLICIT RITUALE

RITUALE principalis() REDDE NIHIL
  CONIURA test_static_page_handler()
  REDDE
EXPLICIT RITUALE

EXPLICIT grimoire
