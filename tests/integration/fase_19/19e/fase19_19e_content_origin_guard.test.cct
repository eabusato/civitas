INCIPIT grimoire "fase19_19e_content_origin_guard"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/embed/embed.cct"
ADVOCARE "../../../../lib/civitas/request_core.cct"
ADVOCARE "../../../../lib/civitas/response.cct"
ADVOCARE "cct/db_sqlite.cct"
ADVOCARE "cct/map.cct"

RITUALE test_content_origin_guard() REDDE NIHIL
  EVOCA Phase19Stack stack AD CONIURA phase19_stack_open("19e_content_guard")
  EVOCA EmbedConfig cfg AD CONIURA embed_config_default("content", "content_items", "id", "Civitas", "https://example.test")
  VINCIRE cfg.allowed_origins AD "https://allowed.test"
  CONIURA embed_schema_up(stack.db)
  CONIURA db_exec(stack.db, "CREATE TABLE IF NOT EXISTS content_items (id TEXT PRIMARY KEY, title TEXT NOT NULL, body TEXT NOT NULL, media_url TEXT NOT NULL)")
  CONIURA db_exec(stack.db, "INSERT INTO content_items (id, title, body, media_url) VALUES ('1', 'Article', '<p>Body</p>', '')")
  CONIURA embed_config_register(stack.db, cfg)
  EVOCA WebRequest req AD CONIURA phase19_request("GET", "/embed/content/1/", "")
  CONIURA phase19_request_set_param(SPECULUM req, "pk", "1")
  CONIURA map_insert GENUS(VERBUM, VERBUM)(req.headers, "origin", "https://blocked.test")
  EVOCA WebResponse res AD CONIURA embed_content_handler(stack.db, "content", req)
  SI res.status != 403
    IACE "blocked origin should be 403"
  FIN SI
  CONIURA phase19_stack_close(stack)
  REDDE
EXPLICIT RITUALE

RITUALE principalis() REDDE NIHIL
  CONIURA test_content_origin_guard()
  REDDE
EXPLICIT RITUALE

EXPLICIT grimoire
