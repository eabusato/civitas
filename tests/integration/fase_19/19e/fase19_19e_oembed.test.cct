INCIPIT grimoire "fase19_19e_oembed"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/embed/embed.cct"
ADVOCARE "../../../../lib/civitas/request_core.cct"
ADVOCARE "../../../../lib/civitas/response.cct"
ADVOCARE "cct/db_sqlite.cct"
ADVOCARE "cct/verbum.cct"

RITUALE test_oembed() REDDE NIHIL
  EVOCA Phase19Stack stack AD CONIURA phase19_stack_open("19e_oembed")
  EVOCA EmbedConfig cfg AD CONIURA embed_config_default("content", "content_items", "id", "Civitas", "https://example.test")
  CONIURA embed_schema_up(stack.db)
  CONIURA db_exec(stack.db, "CREATE TABLE IF NOT EXISTS content_items (id TEXT PRIMARY KEY, title TEXT NOT NULL, body TEXT NOT NULL, media_url TEXT NOT NULL)")
  CONIURA db_exec(stack.db, "INSERT INTO content_items (id, title, body, media_url) VALUES ('1', 'Article', '<p>Body</p>', '')")
  CONIURA embed_config_register(stack.db, cfg)
  EVOCA WebRequest req AD CONIURA phase19_request("GET", "/oembed/?url=https://example.test/embed/content/1/&maxwidth=600", "")
  EVOCA WebResponse res AD CONIURA oembed_handler(stack.db, req)
  SI res.status != 200
    IACE "oembed status mismatch"
  FIN SI
  SI CONIURA find(res.body, "\"type\":\"rich\"") == -1 VEL CONIURA find(res.body, "\"width\":600") == -1
    IACE "oembed body mismatch"
  FIN SI
  CONIURA phase19_stack_close(stack)
  REDDE
EXPLICIT RITUALE

RITUALE principalis() REDDE NIHIL
  CONIURA test_oembed()
  REDDE
EXPLICIT RITUALE

EXPLICIT grimoire
