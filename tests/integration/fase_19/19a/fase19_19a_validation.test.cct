INCIPIT grimoire "fase19_19a_validation"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/api/api.cct"
ADVOCARE "cct/verbum.cct"

RITUALE test_validation_required_unknown_and_nested() REDDE NIHIL
  EVOCA Phase19Stack stack AD CONIURA phase19_stack_open("19a_validation")
  EVOCA SPECULUM SerializerConfig post_cfg AD CONIURA phase19_get_post_serializer(stack.serializers)
  EVOCA VERBUM input_json AD "{\"body\":\"Hidden\",\"published_at\":999,\"author\":{\"id\":10,\"email\":\"ana@example.com\"},\"rogue\":\"x\"}"
  EVOCA ValidationResult vr AD CONIURA serializer_validate(stack.serializers, *post_cfg, input_json)
  SI vr.is_valid
    IACE "validation should fail for missing title and rogue field"
  FIN SI
  EVOCA VERBUM err_json AD CONIURA api_validation_errors_to_json(vr.errors)
  SI CONIURA find(err_json, "\"field\":\"rogue\"") == -1
    IACE "unknown field error missing"
  FIN SI
  SI CONIURA find(err_json, "\"field\":\"title\"") == -1
    IACE "required title error missing"
  FIN SI
  SI CONIURA find(err_json, "\"field\":\"author.name\"") == -1
    IACE "nested required field error missing"
  FIN SI
  CONIURA phase19_stack_close(stack)
  REDDE
EXPLICIT RITUALE

RITUALE principalis() REDDE NIHIL
  CONIURA test_validation_required_unknown_and_nested()
  REDDE
EXPLICIT RITUALE

EXPLICIT grimoire
