INCIPIT grimoire "fase26_26c_middleware_persists_request_leak"

ADVOCARE "../support.cct"
ADVOCARE "../../../../lib/civitas/memory_profiler.cct"
ADVOCARE "../../../../lib/civitas/memory_profiler/memory_profiler.cct"
ADVOCARE "../../../../lib/civitas/router.cct"
ADVOCARE "../../../../lib/civitas/test_client.cct"
ADVOCARE "../../../../lib/civitas/test_client/test_client.cct"
ADVOCARE "cct/db_sqlite.cct"
ADVOCARE "cct/path.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM root AD CONIURA phase26_reset_root("26c_middleware_persists_request_leak")
  EVOCA SPECULUM NIHIL db AD CONIURA db_open(CONIURA path_join(root, "mem.db"))
  EVOCA MemProfilerState state AD CONIURA mem_profiler_state_new(db, 0)
  EVOCA Router router AD CONIURA phase26_memory_router()
  CONIURA mem_profiler_enable(SPECULUM state)
  CONIURA mem_profiler_middleware_add(SPECULUM router, SPECULUM state)
  EVOCA TestClient client AD CONIURA test_client_new(SPECULUM router)
  EVOCA TestResponse res AD CONIURA test_client_get(SPECULUM client, "/mem-leaky")
  CONIURA test_client_free(SPECULUM client)
  CONIURA mem_profiler_disable(SPECULUM state)
  SI res.status != 200
    CONIURA db_close(db)
    REDDE 1
  FIN SI
  SI CONIURA compare(CONIURA tc_header_or(res, "x-civitas-mem-leak", ""), "1") != 0
    CONIURA db_close(db)
    REDDE 2
  FIN SI
  SI CONIURA mem_profiler_count(SPECULUM state) != 1
    CONIURA db_close(db)
    REDDE 3
  FIN SI
  SI CONIURA db_scalar_int(db, "SELECT suspected_leak FROM mem_deltas LIMIT 1") != 1
    CONIURA db_close(db)
    REDDE 4
  FIN SI
  CONIURA db_close(db)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
