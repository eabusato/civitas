INCIPIT grimoire "fase22_22a_collect_watch_files"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/dev_server/dev_server.cct"
ADVOCARE "cct/fs.cct"
ADVOCARE "cct/fluxus.cct"
ADVOCARE "cct/path.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM root AD CONIURA phase22_reset_root("22a_collect_watch_files")
  CONIURA mkdir_all(CONIURA path_join(root, "src/nested"))
  CONIURA mkdir_all(CONIURA path_join(root, "build"))
  CONIURA mkdir_all(CONIURA path_join(root, ".hidden"))
  CONIURA write_all(CONIURA path_join(root, "src/main.cct"), "main")
  CONIURA write_all(CONIURA path_join(root, "src/nested/inner.cct"), "inner")
  CONIURA write_all(CONIURA path_join(root, "src/nested/skip.txt"), "skip")
  CONIURA write_all(CONIURA path_join(root, "build/gen.cct"), "skip")
  CONIURA write_all(CONIURA path_join(root, ".hidden/secret.cct"), "skip")
  EVOCA SPECULUM NIHIL files AD CONIURA dev_server_collect_cct_files(root)
  SI CONIURA fluxus_len(files) != 2
    REDDE 1
  FIN SI
  EVOCA SPECULUM VERBUM a AD CONIURA fluxus_get(files, 0)
  EVOCA SPECULUM VERBUM b AD CONIURA fluxus_get(files, 1)
  SI CONIURA ends_with(*a, "main.cct") == FALSUM ET CONIURA ends_with(*b, "main.cct") == FALSUM
    REDDE 2
  FIN SI
  SI CONIURA ends_with(*a, "inner.cct") == FALSUM ET CONIURA ends_with(*b, "inner.cct") == FALSUM
    REDDE 3
  FIN SI
  EVOCA SPECULUM NIHIL watchers AD CONIURA dev_server_open_watchers(root)
  SI CONIURA fluxus_len(watchers) != 2
    REDDE 4
  FIN SI
  CONIURA dev_server_close_watchers(watchers)
  CONIURA fluxus_free(files)
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
