INCIPIT grimoire "fase22_common"

ADVOCARE "cct/fs.cct"
ADVOCARE "cct/env.cct"
ADVOCARE "cct/fluxus.cct"
ADVOCARE "cct/path.cct"
ADVOCARE "cct/trace.cct"
ADVOCARE "cct/verbum.cct"
ADVOCARE "../../../../lib/civitas/trace_render/trace_render.cct"

RITUALE phase22_root(VERBUM test_name) REDDE VERBUM
  REDDE CONIURA path_join("tests/tmp/fase_22", test_name)
EXPLICIT RITUALE

RITUALE phase22_delete_tree(VERBUM path) REDDE NIHIL
  SI NON CONIURA exists(path)
    REDDE
  FIN SI
  SI CONIURA is_file(path)
    CONIURA delete_file(path)
    REDDE
  FIN SI
  EVOCA SPECULUM NIHIL entries AD CONIURA list_dir(path)
  EVOCA REX i AD 0
  EVOCA REX n AD CONIURA fluxus_len(entries)
  DUM i < n
    EVOCA SPECULUM VERBUM name_ptr AD CONIURA fluxus_get(entries, i)
    CONIURA phase22_delete_tree(CONIURA path_join(path, *name_ptr))
    VINCIRE i AD i + 1
  FIN DUM
  CONIURA fluxus_free(entries)
  CONIURA delete_dir(path)
  REDDE
EXPLICIT RITUALE

RITUALE phase22_reset_root(VERBUM test_name) REDDE VERBUM
  EVOCA VERBUM root AD CONIURA phase22_root(test_name)
  SI CONIURA exists(root)
    CONIURA phase22_delete_tree(root)
  FIN SI
  CONIURA mkdir_all(root)
  REDDE root
EXPLICIT RITUALE

RITUALE phase22_sample_trace(VERBUM trace_id) REDDE Trace
  EVOCA Trace trace AD CONIURA trace_new_with_id(trace_id)
  EVOCA VERBUM root_id AD CONIURA span_start(SPECULUM trace, "request.feed")
  EVOCA VERBUM sql_a AD CONIURA span_start_child(SPECULUM trace, root_id, "db.select.posts")
  EVOCA VERBUM sql_b AD CONIURA span_start_child(SPECULUM trace, root_id, "db.select.posts")
  EVOCA VERBUM sql_c AD CONIURA span_start_child(SPECULUM trace, root_id, "db.select.posts")
  EVOCA VERBUM cache_id AD CONIURA span_start_child(SPECULUM trace, root_id, "cache.get")
  CONIURA span_set_attribute(SPECULUM trace, sql_a, "span.category", "db")
  CONIURA span_set_attribute(SPECULUM trace, sql_a, "db.statement", "SELECT * FROM posts WHERE author_id = 10")
  CONIURA span_set_attribute(SPECULUM trace, sql_b, "span.category", "db")
  CONIURA span_set_attribute(SPECULUM trace, sql_b, "db.statement", "SELECT * FROM posts WHERE author_id = 11")
  CONIURA span_set_attribute(SPECULUM trace, sql_c, "span.category", "db")
  CONIURA span_set_attribute(SPECULUM trace, sql_c, "db.statement", "SELECT * FROM posts WHERE author_id = 12")
  CONIURA span_set_attribute(SPECULUM trace, cache_id, "span.category", "cache")
  CONIURA span_set_attribute(SPECULUM trace, cache_id, "cache.key", "feed:home")
  CONIURA span_set_attribute(SPECULUM trace, cache_id, "cache.hit", "true")
  EVOCA SPECULUM Span root_ptr AD CONIURA fluxus_get(trace.spans, 0)
  EVOCA SPECULUM Span sql_a_ptr AD CONIURA fluxus_get(trace.spans, 1)
  EVOCA SPECULUM Span sql_b_ptr AD CONIURA fluxus_get(trace.spans, 2)
  EVOCA SPECULUM Span sql_c_ptr AD CONIURA fluxus_get(trace.spans, 3)
  EVOCA SPECULUM Span cache_ptr AD CONIURA fluxus_get(trace.spans, 4)
  VINCIRE (*root_ptr).start_time_ms AD 1000
  VINCIRE (*root_ptr).end_time_ms AD 1160
  VINCIRE (*sql_a_ptr).start_time_ms AD 1010
  VINCIRE (*sql_a_ptr).end_time_ms AD 1030
  VINCIRE (*sql_b_ptr).start_time_ms AD 1035
  VINCIRE (*sql_b_ptr).end_time_ms AD 1055
  VINCIRE (*sql_c_ptr).start_time_ms AD 1060
  VINCIRE (*sql_c_ptr).end_time_ms AD 1080
  VINCIRE (*cache_ptr).start_time_ms AD 1090
  VINCIRE (*cache_ptr).end_time_ms AD 1100
  REDDE trace
EXPLICIT RITUALE

RITUALE phase22_render_config(VERBUM test_name) REDDE TraceRenderConfig
  EVOCA TraceRenderConfig cfg AD CONIURA trace_render_default_config()
  CONIURA mkdir_all(CONIURA phase22_root(test_name))
  SI CONIURA has_env("CCT_BIN")
    VINCIRE cfg.cct_bin AD CONIURA getenv("CCT_BIN")
  FIN SI
  VINCIRE cfg.sigil_path AD "tests/integration/fase_22/22b/fase22_22b_render_html_includes_real_sigilo.test.sigil"
  VINCIRE cfg.sigil_view AD "routes"
  VINCIRE cfg.hide_timeline AD VERUM
  VINCIRE cfg.animation_loop AD VERUM
  VINCIRE cfg.work_dir AD CONIURA path_join(CONIURA phase22_root(test_name), "render")
  REDDE cfg
EXPLICIT RITUALE

RITUALE phase22_toolbar_trace(VERBUM trace_id) REDDE Trace
  EVOCA Trace trace AD CONIURA trace_new_with_id(trace_id)
  EVOCA VERBUM root_id AD CONIURA span_start(SPECULUM trace, "request.feed")
  EVOCA VERBUM handler_id AD CONIURA span_start_child(SPECULUM trace, root_id, "handler.feed_home")
  EVOCA VERBUM sql_a AD CONIURA span_start_child(SPECULUM trace, handler_id, "db.query.posts")
  EVOCA VERBUM sql_b AD CONIURA span_start_child(SPECULUM trace, handler_id, "db.query.posts")
  EVOCA VERBUM sql_c AD CONIURA span_start_child(SPECULUM trace, handler_id, "db.query.posts")
  EVOCA VERBUM cache_hit_id AD CONIURA span_start_child(SPECULUM trace, handler_id, "cache.get")
  EVOCA VERBUM cache_miss_id AD CONIURA span_start_child(SPECULUM trace, handler_id, "cache.get")

  CONIURA span_set_attribute(SPECULUM trace, root_id, "route_id", "site.feed.home")
  CONIURA span_set_attribute(SPECULUM trace, root_id, "http.method", "GET")
  CONIURA span_set_attribute(SPECULUM trace, root_id, "http.path", "/feed")
  CONIURA span_set_attribute(SPECULUM trace, root_id, "category", "handler")
  CONIURA span_set_attribute(SPECULUM trace, handler_id, "route_id", "site.feed.home")
  CONIURA span_set_attribute(SPECULUM trace, handler_id, "module", "tests/integration/sigilo_routes_basic_35a.cct")
  CONIURA span_set_attribute(SPECULUM trace, handler_id, "handler", "feed_home")
  CONIURA span_set_attribute(SPECULUM trace, handler_id, "category", "handler")

  CONIURA span_set_attribute(SPECULUM trace, sql_a, "span.category", "db")
  CONIURA span_set_attribute(SPECULUM trace, sql_a, "db.statement", "SELECT * FROM posts WHERE author_id = 10")
  CONIURA span_set_attribute(SPECULUM trace, sql_b, "span.category", "db")
  CONIURA span_set_attribute(SPECULUM trace, sql_b, "db.statement", "SELECT * FROM posts WHERE author_id = 11")
  CONIURA span_set_attribute(SPECULUM trace, sql_c, "span.category", "db")
  CONIURA span_set_attribute(SPECULUM trace, sql_c, "db.statement", "SELECT * FROM posts WHERE author_id = 12")

  CONIURA span_set_attribute(SPECULUM trace, cache_hit_id, "span.category", "cache")
  CONIURA span_set_attribute(SPECULUM trace, cache_hit_id, "cache.key", "feed:home")
  CONIURA span_set_attribute(SPECULUM trace, cache_hit_id, "cache.hit", "true")
  CONIURA span_set_attribute(SPECULUM trace, cache_miss_id, "span.category", "cache")
  CONIURA span_set_attribute(SPECULUM trace, cache_miss_id, "cache.key", "feed:author:22")
  CONIURA span_set_attribute(SPECULUM trace, cache_miss_id, "cache.hit", "false")

  EVOCA SPECULUM Span root_ptr AD CONIURA fluxus_get(trace.spans, 0)
  EVOCA SPECULUM Span handler_ptr AD CONIURA fluxus_get(trace.spans, 1)
  EVOCA SPECULUM Span sql_a_ptr AD CONIURA fluxus_get(trace.spans, 2)
  EVOCA SPECULUM Span sql_b_ptr AD CONIURA fluxus_get(trace.spans, 3)
  EVOCA SPECULUM Span sql_c_ptr AD CONIURA fluxus_get(trace.spans, 4)
  EVOCA SPECULUM Span cache_hit_ptr AD CONIURA fluxus_get(trace.spans, 5)
  EVOCA SPECULUM Span cache_miss_ptr AD CONIURA fluxus_get(trace.spans, 6)

  VINCIRE (*root_ptr).start_time_ms AD 1000
  VINCIRE (*root_ptr).end_time_ms AD 1220
  VINCIRE (*handler_ptr).start_time_ms AD 1010
  VINCIRE (*handler_ptr).end_time_ms AD 1200
  VINCIRE (*sql_a_ptr).start_time_ms AD 1030
  VINCIRE (*sql_a_ptr).end_time_ms AD 1050
  VINCIRE (*sql_b_ptr).start_time_ms AD 1060
  VINCIRE (*sql_b_ptr).end_time_ms AD 1080
  VINCIRE (*sql_c_ptr).start_time_ms AD 1090
  VINCIRE (*sql_c_ptr).end_time_ms AD 1110
  VINCIRE (*cache_hit_ptr).start_time_ms AD 1120
  VINCIRE (*cache_hit_ptr).end_time_ms AD 1130
  VINCIRE (*cache_miss_ptr).start_time_ms AD 1140
  VINCIRE (*cache_miss_ptr).end_time_ms AD 1155
  REDDE trace
EXPLICIT RITUALE

EXPLICIT grimoire
