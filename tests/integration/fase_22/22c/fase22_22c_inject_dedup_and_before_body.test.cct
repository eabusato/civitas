INCIPIT grimoire "fase22_22c_inject_dedup_and_before_body"

ADVOCARE "../../../../lib/civitas/dev_livereload/dev_livereload.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM html AD "<html><body><main>feed</main></body></html>"
  EVOCA VERBUM once AD CONIURA livereload_inject(html, "/civitas/livereload")
  SI CONIURA find(once, "id=\"civitas-livereload\"") == -1
    REDDE 1
  FIN SI
  SI CONIURA find(once, "fetch(url,{cache:'no-store'})") == -1
    REDDE 2
  FIN SI
  SI CONIURA find(once, "id=\"civitas-livereload\"") > CONIURA find(once, "</body>")
    REDDE 3
  FIN SI
  EVOCA VERBUM twice AD CONIURA livereload_inject(once, "/civitas/livereload")
  SI CONIURA compare(once, twice) != 0
    REDDE 4
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
