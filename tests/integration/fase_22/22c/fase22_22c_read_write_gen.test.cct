INCIPIT grimoire "fase22_22c_read_write_gen"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/dev_livereload/dev_livereload.cct"
ADVOCARE "cct/path.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM root AD CONIURA phase22_reset_root("22c_read_write_gen")
  EVOCA VERBUM gen_file AD CONIURA path_join(root, ".civitas-gen")
  SI CONIURA len(CONIURA livereload_read_gen(gen_file)) != 0
    REDDE 1
  FIN SI
  EVOCA VERBUM written AD CONIURA livereload_write_gen(gen_file)
  SI CONIURA len(written) == 0
    REDDE 2
  FIN SI
  SI CONIURA compare(CONIURA livereload_read_gen(gen_file), written) != 0
    REDDE 3
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
