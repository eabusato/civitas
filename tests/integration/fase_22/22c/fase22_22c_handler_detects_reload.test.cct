INCIPIT grimoire "fase22_22c_handler_detects_reload"

ADVOCARE "../support/common.cct"
ADVOCARE "../../../../lib/civitas/dev_livereload/dev_livereload.cct"
ADVOCARE "../../../../lib/civitas/request.cct"
ADVOCARE "../../../../lib/civitas/response.cct"
ADVOCARE "cct/fs.cct"
ADVOCARE "cct/map.cct"
ADVOCARE "cct/path.cct"
ADVOCARE "cct/result.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM root AD CONIURA phase22_reset_root("22c_handler_detects_reload")
  EVOCA VERBUM gen_file AD CONIURA path_join(root, ".civitas-gen")
  CONIURA write_all(gen_file, "2000")
  EVOCA LivereloadConfig cfg AD CONIURA livereload_config_default()
  VINCIRE cfg.gen_file AD gen_file
  EVOCA SPECULUM NIHIL headers AD CONIURA map_init GENUS(VERBUM, VERBUM)()
  EVOCA SPECULUM NIHIL req_res AD CONIURA request_build("GET", "/civitas/livereload?gen=1000", "HTTP/1.1", headers, "", "127.0.0.1", "http", "dev.local", "rid-22c-reload", "", "", "")
  EVOCA WebRequest req AD CONIURA result_unwrap GENUS(WebRequest, VERBUM)(req_res)
  EVOCA WebResponse res AD CONIURA livereload_handler(req, cfg)
  SI res.status != 200
    REDDE 1
  FIN SI
  SI CONIURA find(res.body, "\"gen\":\"2000\"") == -1
    REDDE 2
  FIN SI
  SI CONIURA find(res.body, "\"reload\":true") == -1
    REDDE 3
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
