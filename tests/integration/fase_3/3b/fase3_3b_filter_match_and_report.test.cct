INCIPIT grimoire "fase3_3b_filter_match_and_report_test"

ADVOCARE "support.cct"
ADVOCARE "../../../../lib/civitas/events.cct"
ADVOCARE "cct/verbum.cct"

RITUALE public_handler(SPECULUM NIHIL env_ref) REDDE NIHIL
  EVOCA SPECULUM EventEnvelope env
  VINCIRE env AD env_ref
  SI CONIURA compare((*env).event_type, "content.published") != 0
    IACE "event_type inesperado"
  FIN SI
  REDDE
EXPLICIT RITUALE

RITUALE main() REDDE REX
  EVOCA EventBus bus
  EVOCA EventEnvelope env
  EVOCA EventDispatchReport report
  EVOCA EventFilter filter AD CONIURA event_filter_new("scope", "public")
  EVOCA SPECULUM NIHIL attrs AD CONIURA event_attributes_new()

  CONIURA event_bus_init(SPECULUM bus, "filter-bus")
  CONIURA phase3_3b_ok_or_fail(CONIURA event_subscribe_filtered(SPECULUM bus, "content.published", "public_handler", filter, public_handler))

  CONIURA event_attributes_set(attrs, "scope", "public")
  CONIURA event_envelope_fill(SPECULUM env, "content.published", "evt-public", "2026-03-27T10:00:00+0000", "req-3b-public", "actor-2", attrs, "{\"slug\":\"pub\"}")
  SI NON CONIURA event_filter_match(filter, env)
    REDDE 1
  FIN SI
  VINCIRE report AD CONIURA event_publish(bus, env)
  SI report.delivered_count != 1
    REDDE 2
  FIN SI
  SI report.filtered_out_count != 0
    REDDE 3
  FIN SI

  CONIURA event_attributes_set(attrs, "scope", "private")
  VINCIRE report AD CONIURA event_publish(bus, env)
  SI report.delivered_count != 0
    REDDE 4
  FIN SI
  SI report.filtered_out_count != 1
    REDDE 5
  FIN SI

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
