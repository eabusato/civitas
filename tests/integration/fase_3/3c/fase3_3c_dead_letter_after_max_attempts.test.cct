INCIPIT grimoire "fase3_3c_dead_letter_after_max_attempts_test"

ADVOCARE "support.cct"
ADVOCARE "../../../../lib/civitas/events.cct"
ADVOCARE "../../../../lib/civitas/outbox.cct"
ADVOCARE "cct/time.cct"

RITUALE always_fail(SPECULUM NIHIL env_ref) REDDE NIHIL
  IACE "permanent failure"
EXPLICIT RITUALE

RITUALE main() REDDE REX
  EVOCA VERBUM dir AD CONIURA phase3_3c_tmp_dir("3c_dead_letter")
  EVOCA OutboxStore store
  EVOCA EventBus bus
  EVOCA VERBUM entry_id
  EVOCA OutboxPublishReport first_report
  EVOCA OutboxPublishReport second_report
  EVOCA OutboxEntry entry
  EVOCA REX base_now AD 0

  CONIURA phase3_3c_reset_dir(dir)
  VINCIRE store AD CONIURA phase3_3c_ok_or_fail_store(CONIURA outbox_store_open(dir, 2))
  CONIURA event_bus_init(SPECULUM bus, "dead-letter-bus")
  CONIURA phase3_3c_ok_or_fail_unit(CONIURA event_subscribe(SPECULUM bus, "webhook.delivery_requested", "always_fail", always_fail))

  VINCIRE entry_id AD CONIURA phase3_3c_ok_or_fail_entry_id(CONIURA outbox_enqueue(SPECULUM store, CONIURA phase3_3c_event("webhook.delivery_requested", "req-dead", "actor-d", "{\"hook\":\"x\"}", "public"), "webhook:x"))
  VINCIRE base_now AD CONIURA now_ms()
  VINCIRE first_report AD CONIURA phase3_3c_ok_or_fail_report(CONIURA outbox_after_commit_publish(SPECULUM store, bus, 10, 100, base_now))
  VINCIRE second_report AD CONIURA phase3_3c_ok_or_fail_report(CONIURA outbox_after_commit_publish(SPECULUM store, bus, 10, 100, base_now + 200))
  VINCIRE entry AD CONIURA phase3_3c_ok_or_fail_entry(CONIURA outbox_get_entry(SPECULUM store, entry_id))

  SI first_report.failed_count != 1
    REDDE 1
  FIN SI
  SI second_report.dead_letter_count != 1
    REDDE 2
  FIN SI
  SI entry.status != OUTBOX_DEAD_LETTER VEL entry.attempts != 2
    REDDE 3
  FIN SI

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
