INCIPIT grimoire "fase3_3c_claim_lease_and_reclaim_after_expiry_test"

ADVOCARE "support.cct"
ADVOCARE "../../../../lib/civitas/outbox.cct"
ADVOCARE "cct/time.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM dir AD CONIURA phase3_3c_tmp_dir("3c_claim_lease")
  EVOCA OutboxStore store
  EVOCA VERBUM entry_id
  EVOCA REX first_count AD 0
  EVOCA REX second_count AD 0
  EVOCA REX third_count AD 0
  EVOCA REX base_now AD 0
  EVOCA OutboxEntry loaded

  CONIURA phase3_3c_reset_dir(dir)
  VINCIRE store AD CONIURA phase3_3c_ok_or_fail_store(CONIURA outbox_store_open(dir, 3))
  VINCIRE entry_id AD CONIURA phase3_3c_ok_or_fail_entry_id(CONIURA outbox_enqueue(SPECULUM store, CONIURA phase3_3c_event("cache.invalidate_requested", "req-lease", "actor-l", "{\"key\":\"home\"}", "public"), "cache:home"))
  VINCIRE base_now AD CONIURA now_ms()

  VINCIRE first_count AD CONIURA phase3_3c_claim_count(CONIURA outbox_claim_batch(SPECULUM store, 10, 100, base_now))
  VINCIRE second_count AD CONIURA phase3_3c_claim_count(CONIURA outbox_claim_batch(SPECULUM store, 10, 100, base_now + 50))
  VINCIRE third_count AD CONIURA phase3_3c_claim_count(CONIURA outbox_claim_batch(SPECULUM store, 10, 100, base_now + 200))

  SI first_count != 1
    REDDE 1
  FIN SI
  SI second_count != 0
    REDDE 2
  FIN SI
  SI third_count != 1
    REDDE 3
  FIN SI
  VINCIRE loaded AD CONIURA phase3_3c_ok_or_fail_entry(CONIURA outbox_get_entry(SPECULUM store, entry_id))
  SI CONIURA compare(loaded.entry_id, entry_id) != 0
    REDDE 4
  FIN SI

  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
