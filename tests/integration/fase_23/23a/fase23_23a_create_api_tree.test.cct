INCIPIT grimoire "fase23_23a_create_api_tree"

ADVOCARE "../support.cct"
ADVOCARE "../../../../lib/civitas/civitas_new/civitas_new.cct"
ADVOCARE "cct/fs.cct"
ADVOCARE "cct/path.cct"
ADVOCARE "cct/result.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM root AD CONIURA phase23_reset_root("23a_create_api_tree")
  EVOCA CivitasNewConfig cfg AD CONIURA civitas_new_cfg("helios", TemplateApi, root, FALSUM)
  EVOCA SPECULUM NIHIL res AD CONIURA civitas_new_create(cfg)
  SI CONIURA result_is_err GENUS(REX, VERBUM)(res)
    REDDE 1
  FIN SI
  SI NON CONIURA exists(CONIURA path_join(root, "helios/apps/core/serializers/index.cct"))
    REDDE 2
  FIN SI
  SI CONIURA exists(CONIURA path_join(root, "helios/templates"))
    REDDE 3
  FIN SI
  SI NON CONIURA phase23_contains(CONIURA path_join(root, "helios/civitas.toml"), "serializers = \"apps/core/serializers\"")
    REDDE 4
  FIN SI
  SI NON CONIURA phase23_contains(CONIURA path_join(root, "helios/README.md"), "Template: `api`.")
    REDDE 5
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
