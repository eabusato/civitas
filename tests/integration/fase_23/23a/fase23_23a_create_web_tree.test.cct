INCIPIT grimoire "fase23_23a_create_web_tree"

ADVOCARE "../support.cct"
ADVOCARE "../../../../lib/civitas/civitas_new/civitas_new.cct"
ADVOCARE "cct/path.cct"
ADVOCARE "cct/result.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM root AD CONIURA phase23_reset_root("23a_create_web_tree")
  EVOCA CivitasNewConfig cfg AD CONIURA civitas_new_cfg("aurora", TemplateWeb, root, FALSUM)
  EVOCA SPECULUM NIHIL res AD CONIURA civitas_new_create(cfg)
  SI CONIURA result_is_err GENUS(REX, VERBUM)(res)
    REDDE 1
  FIN SI
  SI NON CONIURA phase23_contains(CONIURA path_join(root, "aurora/project/main.cct"), "ADVOCARE \"urls.cct\"")
    REDDE 2
  FIN SI
  SI NON CONIURA phase23_contains(CONIURA path_join(root, "aurora/templates/base.html"), "<link rel=\"stylesheet\" href=\"/static/css/main.css\">")
    REDDE 3
  FIN SI
  SI NON CONIURA phase23_contains(CONIURA path_join(root, "aurora/static/css/main.css"), "--accent:#56c2ff")
    REDDE 4
  FIN SI
  SI NON CONIURA phase23_contains(CONIURA path_join(root, "aurora/apps/core/urls.cct"), "core_urls_register")
    REDDE 5
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
