INCIPIT grimoire "fase23_23a_existing_target_requires_force"

ADVOCARE "../support.cct"
ADVOCARE "../../../../lib/civitas/civitas_new/civitas_new.cct"
ADVOCARE "cct/fs.cct"
ADVOCARE "cct/path.cct"
ADVOCARE "cct/result.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM root AD CONIURA phase23_reset_root("23a_existing_target_requires_force")
  CONIURA mkdir_all(CONIURA path_join(root, "ember"))
  CONIURA write_all(CONIURA path_join(root, "ember/README.md"), "old")
  EVOCA CivitasNewConfig cfg AD CONIURA civitas_new_cfg("ember", TemplateMinimal, root, FALSUM)
  EVOCA SPECULUM NIHIL res AD CONIURA civitas_new_create(cfg)
  SI NON CONIURA result_is_err GENUS(REX, VERBUM)(res)
    REDDE 1
  FIN SI
  SI NON CONIURA phase23_contains(CONIURA path_join(root, "ember/README.md"), "old")
    REDDE 2
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
