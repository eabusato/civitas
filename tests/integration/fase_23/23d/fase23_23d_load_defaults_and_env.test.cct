INCIPIT grimoire "fase23_23d_load_defaults_and_env"

ADVOCARE "../support.cct"
ADVOCARE "../../../../lib/civitas/civitas_config/civitas_config.cct"
ADVOCARE "cct/env.cct"
ADVOCARE "cct/fs.cct"
ADVOCARE "cct/path.cct"
ADVOCARE "cct/verbum.cct"

RITUALE main() REDDE REX
  EVOCA VERBUM root AD CONIURA phase23_reset_root("23d_load_defaults_and_env")
  CONIURA mkdir_all(CONIURA path_join(root, "project"))
  CONIURA write_all(CONIURA path_join(root, "project/main.cct"), "INCIPIT grimoire \"main\"\nEXPLICIT grimoire\n")
  EVOCA VERBUM home AD CONIURA getenv("HOME")
  CONIURA write_all(CONIURA path_join(root, "civitas.toml"), "[project]\nname = \"atlas\"\nentry = \"project/main.cct\"\n\n[database]\ndriver = \"sqlite\"\nurl = \"${HOME}/phase23.db\"\n")
  EVOCA CivitasProject proj AD CONIURA civitas_project_load(CONIURA path_join(root, "civitas.toml"))
  SI CONIURA compare(proj.name, "atlas") != 0
    REDDE 1
  FIN SI
  SI CONIURA compare(proj.db_url, CONIURA concat(home, "/phase23.db")) != 0
    REDDE 2
  FIN SI
  SI CONIURA compare(proj.host, "0.0.0.0") != 0 VEL proj.port != 8080
    REDDE 3
  FIN SI
  SI CONIURA compare(proj.static_url_prefix, "/static") != 0
    REDDE 4
  FIN SI
  REDDE 0
EXPLICIT RITUALE

EXPLICIT grimoire
