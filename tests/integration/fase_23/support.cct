INCIPIT grimoire "fase23_support"

ADVOCARE "cct/fs.cct"
ADVOCARE "cct/env.cct"
ADVOCARE "cct/fluxus.cct"
ADVOCARE "cct/path.cct"
ADVOCARE "cct/process.cct"
ADVOCARE "cct/verbum.cct"

RITUALE phase23_root(VERBUM test_name) REDDE VERBUM
  REDDE CONIURA path_join("tests/tmp/fase_23", test_name)
EXPLICIT RITUALE

RITUALE phase23_delete_tree(VERBUM path) REDDE NIHIL
  SI NON CONIURA exists(path)
    REDDE
  FIN SI
  SI CONIURA is_file(path)
    CONIURA delete_file(path)
    REDDE
  FIN SI
  EVOCA VERBUM hidden_gitignore AD CONIURA path_join(path, ".gitignore")
  EVOCA VERBUM hidden_civitas AD CONIURA path_join(path, ".civitas")
  EVOCA VERBUM hidden_ds_store AD CONIURA path_join(path, ".DS_Store")
  SI CONIURA exists(hidden_gitignore)
    CONIURA phase23_delete_tree(hidden_gitignore)
  FIN SI
  SI CONIURA exists(hidden_civitas)
    CONIURA phase23_delete_tree(hidden_civitas)
  FIN SI
  SI CONIURA exists(hidden_ds_store)
    CONIURA phase23_delete_tree(hidden_ds_store)
  FIN SI
  EVOCA SPECULUM NIHIL entries AD CONIURA list_dir(path)
  EVOCA REX i AD 0
  EVOCA REX n AD CONIURA fluxus_len(entries)
  DUM i < n
    EVOCA SPECULUM VERBUM name_ptr AD CONIURA fluxus_get(entries, i)
    CONIURA phase23_delete_tree(CONIURA path_join(path, *name_ptr))
    VINCIRE i AD i + 1
  FIN DUM
  CONIURA fluxus_free(entries)
  CONIURA delete_dir(path)
  REDDE
EXPLICIT RITUALE

RITUALE phase23_reset_root(VERBUM test_name) REDDE VERBUM
  EVOCA VERBUM root AD CONIURA phase23_root(test_name)
  SI CONIURA exists(root)
    CONIURA phase23_delete_tree(root)
  FIN SI
  CONIURA mkdir_all(root)
  REDDE root
EXPLICIT RITUALE

RITUALE phase23_compile_file(VERBUM source_path) REDDE REX
  EVOCA VERBUM compiler AD "cct-host"
  SI CONIURA has_env("CCT_BIN")
    EVOCA VERBUM candidate AD CONIURA trim(CONIURA getenv("CCT_BIN"))
    SI CONIURA len(candidate) > 0
      VINCIRE compiler AD candidate
    FIN SI
  ALITER
    SI CONIURA run("command -v cct-host >/dev/null 2>&1") == 0
      VINCIRE compiler AD "cct-host"
    ALITER
      SI CONIURA run("command -v cct >/dev/null 2>&1") == 0
        VINCIRE compiler AD "cct"
      FIN SI
    FIN SI
  FIN SI
  EVOCA VERBUM cmd AD CONIURA concat(compiler, " ")
  VINCIRE cmd AD CONIURA concat(cmd, source_path)
  REDDE CONIURA run(cmd)
EXPLICIT RITUALE

RITUALE phase23_contains(VERBUM path, VERBUM needle) REDDE VERUM
  SI NON CONIURA exists(path)
    REDDE FALSUM
  FIN SI
  REDDE CONIURA find(CONIURA read_all(path), needle) != -1
EXPLICIT RITUALE

EXPLICIT grimoire
